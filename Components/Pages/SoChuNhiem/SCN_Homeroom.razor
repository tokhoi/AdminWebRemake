@page "/school/homeroom"
@rendermode InteractiveServer

<PageTitle>Sổ Chủ Nhiệm Điện Tử</PageTitle>

<div class="scn-container animate-fade-in">
    <div class="scn-sidebar">
        <div class="scn-sidebar-header">
            <div class="scn-icon-box"><span class="material-icons-round">book</span></div>
            <div>
                <div class="scn-sidebar-title">SỔ CHỦ NHIỆM</div>
                <div style="font-size: 0.8rem; color: var(--text-muted);">Năm học 2025-2026</div>
            </div>
        </div>
        
        <div class="scn-nav-wrapper">
            <ul class="scn-nav-group">
                <li class="scn-nav-label">THÔNG TIN CHUNG</li>
                <li class="scn-nav-item @(ActiveTab == "index" ? "active" : "")" @onclick='() => ActiveTab = "index"'>
                    <span class="material-icons-round scn-nav-icon">dashboard</span> Tổng quan
                </li>
                <li class="scn-nav-item @(ActiveTab == "hocsinh" ? "active" : "")" @onclick='() => ActiveTab = "hocsinh"'>
                    <span class="material-icons-round scn-nav-icon">groups</span> Danh sách Học sinh
                </li>
                <li class="scn-nav-item @(ActiveTab == "sodo" ? "active" : "")" @onclick='() => ActiveTab = "sodo"'>
                    <span class="material-icons-round scn-nav-icon">grid_view</span> Sơ đồ lớp học
                </li>
                <li class="scn-nav-item @(ActiveTab == "to" ? "active" : "")" @onclick='() => ActiveTab = "to"'>
                    <span class="material-icons-round scn-nav-icon">safety_divider</span> Quản lý HS theo tổ
                </li>
                <li class="scn-nav-item @(ActiveTab == "cmhs" ? "active" : "")" @onclick='() => ActiveTab = "cmhs"'>
                    <span class="material-icons-round scn-nav-icon">family_restroom</span> Ban đại diện CMHS
                </li>
            </ul>

            <ul class="scn-nav-group">
                <li class="scn-nav-label">KẾ HOẠCH & ĐÁNH GIÁ</li>
                <li class="scn-nav-item @(ActiveTab == "kh_chunhiem" ? "active" : "")" @onclick='() => ActiveTab = "kh_chunhiem"'>
                    <span class="material-icons-round scn-nav-icon">menu_book</span> Kế hoạch Chủ nhiệm
                </li>
                <li class="scn-nav-item @(ActiveTab == "kh_giaoduc" ? "active" : "")" @onclick='() => ActiveTab = "kh_giaoduc"'>
                    <span class="material-icons-round scn-nav-icon">auto_stories</span> Kế hoạch Giáo dục
                </li>
                <li class="scn-nav-item @(ActiveTab == "kh_thang" ? "active" : "")" @onclick='() => ActiveTab = "kh_thang"'>
                    <span class="material-icons-round scn-nav-icon">calendar_month</span> Kế hoạch Tháng
                </li>
            </ul>

            <ul class="scn-nav-group">
                <li class="scn-nav-label">THEO DÕI KỶ LUẬT</li>
                <li class="scn-nav-item @(ActiveTab == "tienbo" ? "active" : "")" @onclick='() => ActiveTab = "tienbo"'>
                    <span class="material-icons-round scn-nav-icon">trending_up</span> Theo dõi Tiến bộ
                </li>
                <li class="scn-nav-item @(ActiveTab == "nhacnho" ? "active" : "")" @onclick='() => ActiveTab = "nhacnho"'>
                    <span class="material-icons-round scn-nav-icon">warning_amber</span> Hiện tượng & Nhắc nhở
                </li>
                <li class="scn-nav-item @(ActiveTab == "hieutruong" ? "active" : "")" @onclick='() => ActiveTab = "hieutruong"'>
                    <span class="material-icons-round scn-nav-icon">verified</span> Hiệu trưởng nhận xét
                </li>
            </ul>
        </div>
    </div>

    <div class="scn-main-area">
        <div class="scn-content-body">
            @switch (ActiveTab)
            {
                case "index":
                    <SCN_Index />
                    break;
                case "hocsinh":
                    <SCN_HocSinh />
                    break;
                case "sodo":
                    <SCN_SoDoLopHoc />
                    break;
                case "to":
                    <SCN_QuanLyHocSinhTheoTo />
                    break;
                case "cmhs":
                    <SCN_BanDaiDienChaMeHocSinh />
                    break;
                case "kh_chunhiem":
                    <SCN_KeHoachChuNhiem />
                    break;
                case "kh_giaoduc":
                    <SCN_KeHoachGiaoDuc />
                    break;
                case "kh_thang":
                    <SCN_KeHoachThang />
                    break;
                case "tienbo":
                    <SCN_TienBo />
                    break;
                case "nhacnho":
                    <SCN_HienTuongNhacNho />
                    break;
                case "hieutruong":
                    <SCN_HieuTruongNhanXet />
                    break;
                default:
                    <div style="padding: 2rem; text-align: center; color: var(--text-muted);">
                        Đang tải nội dung...
                    </div>
                    break;
            }
        </div>
    </div>
</div>

@code {
    private string ActiveTab = "index";
}

