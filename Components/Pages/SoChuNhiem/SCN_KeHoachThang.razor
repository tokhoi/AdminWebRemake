<div class="scn-child-container animate-fade-in">
    <div class="toolbar flex-between">
        <h2 class="page-title">Kế hoạch công tác Tháng</h2>
        <select class="input-control" style="width: 200px; font-weight: bold; color: var(--primary);" @bind="SelectedMonth">
            <option value="9">Tháng 9/2025</option>
            <option value="10">Tháng 10/2025</option>
            <option value="11">Tháng 11/2025</option>
        </select>
    </div>

    <div class="month-plan-grid">
        <div class="plan-card">
            <div class="card-header"><span class="material-icons-round" style="color: #f59e0b;">emoji_events</span> Mục tiêu trọng tâm</div>
            <div class="card-body">
                <textarea class="plan-textarea" placeholder="Nhập mục tiêu trọng tâm của tháng... (Vd: Duy trì sĩ số, đạt giải văn nghệ trường)">
1. 100% học sinh đi học đúng giờ.
2. Hoàn thành thu BHYT.
3. Thi đua hoa điểm tốt chào mừng 20/11.
                </textarea>
                <div style="text-align: right; margin-top: 10px;">
                    <button class="btn-outline">Cập nhật mục tiêu</button>
                </div>
            </div>
        </div>

        <div class="plan-card">
            <div class="card-header"><span class="material-icons-round" style="color: #10b981;">fact_check</span> Nhiệm vụ chi tiết</div>
            <div class="card-body">
                <div style="display: flex; gap: 10px; margin-bottom: 1rem;">
                    <input type="text" class="input-control" placeholder="Thêm công việc mới..." @bind="NewTask" />
                    <button class="btn-primary" @onclick="AddTask"><span class="material-icons-round">add</span></button>
                </div>

                <div class="task-list">
                    @foreach (var task in Tasks)
                    {
                        <div class="task-item @(task.IsDone ? "task-done" : "")">
                            <input type="checkbox" checked="@task.IsDone" @onchange="() => task.IsDone = !task.IsDone" class="task-checkbox" />
                            <span class="task-text">@task.Name</span>
                            <button class="icon-btn text-danger" @onclick="() => Tasks.Remove(task)"><span class="material-icons-round" style="font-size: 18px;">close</span></button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string SelectedMonth = "11";
    private string NewTask = "";

    class TaskItem { public string Name { get; set; } = ""; public bool IsDone { get; set; } }
    List<TaskItem> Tasks = new()
    {
        new TaskItem { Name = "Họp phụ huynh đầu năm", IsDone = true },
        new TaskItem { Name = "Thu các khoản phí đầu năm", IsDone = false },
        new TaskItem { Name = "Xếp sơ đồ lớp học", IsDone = true },
        new TaskItem { Name = "Bầu ban cán sự lớp", IsDone = false }
    };

    private void AddTask()
    {
        if (!string.IsNullOrWhiteSpace(NewTask))
        {
            Tasks.Add(new TaskItem { Name = NewTask, IsDone = false });
            NewTask = "";
        }
    }
}

<style>
    .scn-child-container {
        padding: 0.5rem;
