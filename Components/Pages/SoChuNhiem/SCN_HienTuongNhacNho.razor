<div class="scn-child-container animate-fade-in">
    <h2 class="page-title" style="margin-bottom: 1.5rem;">Hiện tượng & Nhắc nhở Kỷ luật</h2>

    <div class="form-card">
        <h3 class="card-title">Ghi nhận vi phạm mới</h3>
        <div class="form-grid">
            <div class="form-group">
                <label>Học sinh vi phạm</label>
                <select class="input-control"><option>-- Chọn học sinh --</option><option>Nguyễn Văn A</option></select>
            </div>
            <div class="form-group">
                <label>Ngày vi phạm</label>
                <input type="date" class="input-control" value="2026-03-10" />
            </div>
            <div class="form-group" style="grid-column: span 2;">
                <label>Lý do vi phạm / Nhắc nhở</label>
                <input type="text" class="input-control" placeholder="Ví dụ: Đi học trễ, không đồng phục..." />
            </div>
        </div>
        <div style="text-align: right; margin-top: 1rem;">
            <button class="btn-primary" @onclick="ShowToast"><span class="material-icons-round">add</span> Lưu ghi nhận</button>
        </div>
    </div>

    <h3 class="card-title" style="margin: 1.5rem 0 1rem 0;">Lịch sử nhắc nhở</h3>
    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 100px;">Ngày</th>
                    <th>Học sinh</th>
                    <th>Nội dung vi phạm</th>
                    <th style="text-align: center;">Hình thức</th>
                    <th style="text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-muted">08/03/2026</td>
                    <td style="font-weight: 600;">Lê Trần C</td>
                    <td>Sử dụng điện thoại trong giờ học</td>
                    <td style="text-align: center;"><span class="tag tag-red">Tịch thu ĐT</span></td>
                    <td style="text-align: center;"><button class="icon-btn"><span class="material-icons-round">delete</span></button></td>
                </tr>
                <tr>
                    <td class="text-muted">05/03/2026</td>
                    <td style="font-weight: 600;">Nguyễn Văn A</td>
                    <td>Không thuộc bài cũ</td>
                    <td style="text-align: center;"><span class="tag tag-warning">Nhắc nhở</span></td>
                    <td style="text-align: center;"><button class="icon-btn"><span class="material-icons-round">delete</span></button></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@code {
    private void ShowToast()
    {
        // Trong dự án thực tế chỗ này sẽ gọi Toastr/SweetAlert
    }
}

