<div class="scn-child-container animate-fade-in">
    <div class="toolbar flex-between">
        <div>
            <h2 class="page-title">Sơ đồ chỗ ngồi - Lớp 10A1</h2>
            <span class="text-muted">Sĩ số: @TotalStudents HS | Đã xếp: @SeatedStudents.Count | Chưa xếp: @UnassignedStudents.Count</span>
        </div>
        <div style="display: flex; gap: 10px;">
            @if (IsEditMode)
            {
                <button class="btn-outline" @onclick="ToggleEditMode">Hủy</button>
                <button class="btn-primary" @onclick="ToggleEditMode"><span class="material-icons-round">save</span> Lưu sơ đồ</button>
            }
            else
            {
                <button class="btn-outline" @onclick="ShuffleSeats"><span class="material-icons-round">shuffle</span> Sắp xếp ngẫu nhiên</button>
                <button class="btn-primary" @onclick="ToggleEditMode"><span class="material-icons-round">settings</span> Cấu hình & Xếp chỗ</button>
            }
        </div>
    </div>

    @if (IsEditMode)
    {
        <div class="config-panel animate-slide-down">
            <div style="font-weight: 600; margin-right: 15px;">Cấu hình không gian:</div>
            <div class="config-item">
                <label>Số Dãy (Cột):</label>
                <input type="number" class="input-control" style="width: 80px;" min="1" max="6" @bind="Cols" @bind:after="RebuildGrid" />
            </div>
            <div class="config-item">
                <label>Số Bàn/Dãy (Hàng):</label>
                <input type="number" class="input-control" style="width: 80px;" min="1" max="10" @bind="Rows" @bind:after="RebuildGrid" />
            </div>
            <div style="margin-left: auto; color: var(--c-orange); font-size: 0.85rem; font-style: italic;">
                <span class="material-icons-round" style="font-size: 16px; vertical-align: bottom;">info</span>
                Chọn HS bên dưới, sau đó click vào ghế trống để xếp chỗ.
            </div>
        </div>
    }

    <div class="workspace-layout">
        @if (IsEditMode)
        {
            <div class="waiting-list-panel">
                <h3 style="font-size: 1rem; margin: 0 0 10px 0; color: var(--text-main);">Danh sách chưa xếp (@UnassignedStudents.Count)</h3>
                <div class="student-list">
                    @foreach (var hs in UnassignedStudents)
                    {
                        <div class="student-list-item @(SelectedStudentToAssign?.Id == hs.Id ? "selected" : "")"
                             @onclick="() => SelectStudentForAssignment(hs)">
                            <div class="avatar-mini">@hs.Name.Substring(0, 1)</div>
                            <span>@hs.Name</span>
                        </div>
                    }
                    @if (UnassignedStudents.Count == 0)
                    {
                        <div style="text-align: center; color: var(--text-muted); padding: 2rem 0; font-size: 0.9rem;">
                            Đã xếp hết học sinh!
                        </div>
                    }
                </div>
            </div>
        }

        <div class="grid-panel">
            <div class="teachers-desk">BÀN GIÁO VIÊN</div>

            <div class="classroom-grid" style="grid-template-columns: repeat(@Cols, 1fr);">
                @for (int row = 0; row < Rows; row++)
                {
                    @for (int col = 0; col < Cols; col++)
                    {
                        var currentRow = row;
                        var currentCol = col;
                        var seat = Seats.FirstOrDefault(s => s.Row == currentRow && s.Col == currentCol);

                        <div class="desk-slot @(IsEditMode ? "edit-mode" : "") @(seat != null && seat.Student != null ? "occupied" : "empty")"
                             @onclick="() => HandleSeatClick(currentRow, currentCol)">

                            @if (seat != null && seat.Student != null)
                            {
                                <div class="desk-avatar">@seat.Student.Name.Substring(0, 1)</div>
                                <div class="desk-name">@seat.Student.Name</div>

                                @if (IsEditMode)
                                {
                                    <div class="remove-badge" title="Gỡ học sinh này"><span class="material-icons-round">close</span></div>
                                }
                            }
                            else
                            {
                                @if (IsEditMode)
                                {
                                    <span class="material-icons-round empty-icon">add</span>
                                    <div class="empty-text">Trống</div>
                                }
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private bool IsEditMode = false;
    private int Rows = 5;
    private int Cols = 4; // 4 Dãy, mỗi dãy 5 bàn = 20 chỗ (Giả lập mỗi bàn 2 HS thì có thể chia 8 cột)
    private int TotalStudents = 18;

    class StudentMock { public string Id { get; set; } = ""; public string Name { get; set; } = ""; }
    class Seat { public int Row { get; set; } public int Col { get; set; } public StudentMock? Student { get; set; } }

    List<StudentMock> AllStudents = new();
    List<StudentMock> UnassignedStudents = new();
    List<StudentMock> SeatedStudents => Seats.Where(s => s.Student != null).Select(s => s.Student!).ToList();
    List<Seat> Seats = new();

    StudentMock? SelectedStudentToAssign;

    protected override void OnInitialized()
    {
        // Khởi tạo 18 học sinh giả lập
        for (int i = 1; i <= TotalStudents; i++)
        {
            AllStudents.Add(new StudentMock { Id = $"HS{i}", Name = $"Học sinh {i}" });
        }

        // Khởi tạo danh sách chờ ban đầu
        UnassignedStudents = AllStudents.ToList();

        RebuildGrid();
        ShuffleSeats(); // Xếp ngẫu nhiên lần đầu cho có dữ liệu
    }

    // Xây dựng lại lưới dựa trên cấu hình Dãy x Bàn
    private void RebuildGrid()
    {
        var oldSeats = Seats.ToList();
        Seats.Clear();

        for (int r = 0; r < Rows; r++)
        {
            for (int c = 0; c < Cols; c++)
            {
                // Giữ lại học sinh cũ nếu ghế đó vẫn nằm trong giới hạn lưới mới
                var existingSeat = oldSeats.FirstOrDefault(s => s.Row == r && s.Col == c);
                Seats.Add(new Seat { Row = r, Col = c, Student = existingSeat?.Student });
            }
        }

        // Đẩy những học sinh bị mất ghế (do thu hẹp lưới) về lại danh sách chờ
        var validSeatStudents = Seats.Where(s => s.Student != null).Select(s => s.Student!.Id).ToList();
        UnassignedStudents = AllStudents.Where(hs => !validSeatStudents.Contains(hs.Id)).ToList();
    }

    private void ToggleEditMode()
    {
        IsEditMode = !IsEditMode;
        SelectedStudentToAssign = null;
    }

    // Xếp ngẫu nhiên
    private void ShuffleSeats()
    {
        UnassignedStudents = AllStudents.ToList();
        foreach (var seat in Seats) { seat.Student = null; }

        var rnd = new Random();
        var randomStudents = AllStudents.OrderBy(x => rnd.Next()).ToList();

        int studentIndex = 0;
        foreach (var seat in Seats)
        {
            if (studentIndex < randomStudents.Count)
            {
                seat.Student = randomStudents[studentIndex];
                UnassignedStudents.Remove(randomStudents[studentIndex]);
                studentIndex++;
            }
        }
    }

    // ===== LOGIC CHỌN VÀ GẮN CHỖ (EDIT MODE) =====

    private void SelectStudentForAssignment(StudentMock student)
    {
        // Bấm chọn HS trong danh sách chờ
        if (SelectedStudentToAssign == student)
            SelectedStudentToAssign = null; // Bỏ chọn nếu bấm lại
        else
            SelectedStudentToAssign = student;
    }

    private void HandleSeatClick(int row, int col)
    {
        if (!IsEditMode) return;

        var seat = Seats.First(s => s.Row == row && s.Col == col);

        if (seat.Student != null)
        {
            // Ghế đã có người -> Bấm vào để gỡ học sinh ra khỏi ghế, đưa về danh sách chờ
            UnassignedStudents.Add(seat.Student);
            seat.Student = null;
        }
        else if (SelectedStudentToAssign != null)
        {
            // Ghế trống và đang có học sinh được chọn -> Gắn vào ghế
            seat.Student = SelectedStudentToAssign;
            UnassignedStudents.Remove(SelectedStudentToAssign);
            SelectedStudentToAssign = null; // Reset lựa chọn
        }
    }
}

