<div class="scn-child-container animate-fade-in">
    <div class="toolbar flex-between">
        <div>
            <h2 class="page-title">Kế hoạch Giáo dục & Hoạt động NGLL</h2>
            <span class="text-muted">Năm học: 2025 - 2026</span>
        </div>
        <button class="btn-primary" @onclick="OpenModal"><span class="material-icons-round">add_task</span> Thêm hoạt động</button>
    </div>

    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 100px;">Thời gian</th>
                    <th>Chủ đề giáo dục / Tên hoạt động</th>
                    <th>Hình thức tổ chức</th>
                    <th>Người phụ trách</th>
                    <th style="text-align: center;">Trạng thái</th>
                    <th style="text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var plan in EduPlans)
                {
                    <tr>
                        <td class="fw-bold" style="color: var(--primary);">Tháng @plan.Month</td>
                        <td style="font-weight: 600; color: var(--text-main);">@plan.Topic</td>
                        <td>@plan.Format</td>
                        <td>@plan.Assignee</td>
                        <td style="text-align: center;">
                            @if (plan.Status == "Đã hoàn thành")
                            {
                                <span class="tag tag-green">Đã hoàn thành</span>
                            }
                            else if (plan.Status == "Đang diễn ra")
                            {

                                <span class="tag tag-blue">Đang diễn ra</span>
                            }
                            else
                            {

                                <span class="tag tag-gray">Chưa thực hiện</span>
                            }
                        </td>
                        <td style="text-align: center;">
                            <button class="icon-btn" title="Sửa"><span class="material-icons-round">edit</span></button>
                            <button class="icon-btn text-danger" title="Xóa"><span class="material-icons-round">delete</span></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Modal Thêm Hoạt động (Mô phỏng) *@
@if (IsModalOpen)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-content animate-slide-down" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="margin: 0; font-size: 1.1rem;">Thêm Hoạt Động Giáo Dục</h3>
                <button class="icon-btn" @onclick="CloseModal"><span class="material-icons-round">close</span></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                <div><label class="modal-label">Chủ đề/Tên hoạt động</label><input type="text" class="input-control" placeholder="Vd: Chào mừng ngày 20/11..." /></div>
                <div style="display: flex; gap: 1rem;">
                    <div style="flex:1;"><label class="modal-label">Tháng thực hiện</label><select class="input-control"><option>Tháng 11</option><option>Tháng 12</option></select></div>
                    <div style="flex:1;"><label class="modal-label">Hình thức</label><select class="input-control"><option>Sinh hoạt lớp</option><option>Dã ngoại</option></select></div>
                </div>
            </div>
            <div class="modal-footer" style="padding: 1rem 1.5rem; background: #f8fafc; border-top: 1px solid var(--border); text-align: right;">
                <button class="btn-outline" style="margin-right: 8px;" @onclick="CloseModal">Hủy</button>
                <button class="btn-primary" @onclick="CloseModal">Lưu hoạt động</button>
            </div>
        </div>
    </div>
}

@code {
    private bool IsModalOpen = false;
    private void OpenModal() => IsModalOpen = true;
    private void CloseModal() => IsModalOpen = false;

    class EduPlan { public int Month { get; set; } public string Topic { get; set; } = ""; public string Format { get; set; } = ""; public string Assignee { get; set; } = ""; public string Status { get; set; } = ""; }
    List<EduPlan> EduPlans = new()
    {
        new EduPlan { Month = 9, Topic = "Truyền thống nhà trường", Format = "Sinh hoạt dưới cờ", Assignee = "GVCN", Status = "Đã hoàn thành" },
        new EduPlan { Month = 10, Topic = "Chăm sóc sức khỏe tuổi vị thành niên", Format = "Chuyên đề", Assignee = "Cán bộ Y tế", Status = "Đã hoàn thành" },
        new EduPlan { Month = 11, Topic = "Tôn sư trọng đạo", Format = "Hội diễn văn nghệ", Assignee = "Ban Cán sự lớp", Status = "Đang diễn ra" },
        new EduPlan { Month = 12, Topic = "Uống nước nhớ nguồn", Format = "Thăm khu di tích", Assignee = "GVCN & Ban ĐD CMHS", Status = "Chưa thực hiện" }
    };
}

