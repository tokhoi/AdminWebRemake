        margin: 0 0 0.25rem 0;
        font-size: 1.15rem;
        color: var(--text-main);
    }

    .text-muted {
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .input-control {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        outline: none;
    }

        .input-control:focus {
            border-color: #1b6ec2;
        }

    .btn-primary {
        background: #1b6ec2;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        font-weight: 600;
    }

    .btn-outline {
        background: white;
        color: var(--text-main);
        border: 1px solid var(--border);
        padding: 8px 16px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
    }

    .table-wrapper {
        background: white;
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th {
            background: #f8fafc;
            padding: 12px 1rem;
            text-align: left;
            font-size: 0.85rem;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border);
        }

        .data-table td {
            padding: 12px 1rem;
            border-bottom: 1px solid #f1f5f9;
        }

        .data-table tr:hover td {
            background: #f8fafc;
        }

    .tag {
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: bold;
        display: inline-block;
    }

    .tag-gray {
        background: #f1f5f9;
        color: #475569;
    }

    .tag-red {
        background: #fee2e2;
        color: #ef4444;
    }

    .tag-blue {
        background: #eff6ff;
        color: #3b82f6;
    }

    .icon-btn {
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 4px;
        border-radius: 4px;
    }

        .icon-btn:hover {
            color: #1b6ec2;
            background: #f1f5f9;
        }

    .text-danger:hover {
        color: #ef4444;
    }

    /* Modal CSS (Chỉ ảnh hưởng trong component này) */
    .modal-backdrop {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(15,23,42,0.5);
        backdrop-filter: blur(2px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
    }

    .modal-content {
        background: white;
        width: 450px;
        border-radius: 12px;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .modal-header {
        padding: 1rem 1.5rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .modal-header h3 {
            margin: 0;
            font-size: 1.1rem;
        }

    .modal-body {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-group label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 0.5rem;
    }

    .modal-footer {
        padding: 1rem 1.5rem;
        background: #f8fafc;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .animate-slide-down {
        animation: slideDown 0.2s ease-out forwards;
    }
    @@keyframes slideDown {
        from

    {
        opacity: 0;
        transform: translateY(-20px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }
</style>