<div class="scn-child-container animate-fade-in">
    <div class="toolbar flex-between">
        <div>
            <h2 class="page-title">Ban đại diện CMHS - Lớp 10A1</h2>
            <span class="text-muted">Nhiệm kỳ: 2025 - 2026</span>
        </div>
        <button class="btn-primary" @onclick="OpenModal"><span class="material-icons-round">person_add</span> Thêm thành viên</button>
    </div>

    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 60px; text-align: center;">STT</th>
                    <th>Chức vụ</th>
                    <th>Họ tên Phụ huynh</th>
                    <th>Phụ huynh của em</th>
                    <th>Số điện thoại</th>
                    <th style="text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Members.Select((value, index) => new { value, index }))
                {
                    <tr>
                        <td style="text-align: center; color: var(--text-muted);">@(item.index + 1)</td>
                        <td><span class="tag @GetRoleColor(item.value.Role)">@item.value.Role</span></td>
                        <td style="font-weight: 600; color: var(--text-main);">@item.value.ParentName</td>
                        <td>@item.value.StudentName</td>
                        <td style="font-family: monospace;">@item.value.Phone</td>
                        <td style="text-align: center;">
                            <button class="icon-btn" @onclick="OpenModal" title="Sửa"><span class="material-icons-round">edit</span></button>
                            <button class="icon-btn text-danger" title="Xóa"><span class="material-icons-round">delete</span></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* ================= MODAL THÊM/SỬA ================= *@
@if (IsModalOpen)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-content animate-slide-down" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Cập nhật thành viên Ban đại diện</h3>
                <button class="icon-btn" @onclick="CloseModal"><span class="material-icons-round">close</span></button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Chức vụ trong ban</label>
                    <select class="input-control"><option>Trưởng ban</option><option>Phó ban</option><option>Thành viên</option></select>
                </div>
                <div class="form-group">
                    <label>Họ tên Phụ huynh</label>
                    <input type="text" class="input-control" placeholder="Nhập họ tên..." />
                </div>
                <div class="form-group">
                    <label>Số điện thoại</label>
                    <input type="text" class="input-control" placeholder="Nhập số điện thoại..." />
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-outline" @onclick="CloseModal">Hủy</button>
                <button class="btn-primary" @onclick="SaveData"><span class="material-icons-round">save</span> Lưu lại</button>
            </div>
        </div>
    </div>
}

@code {
    private bool IsModalOpen = false;

    private void OpenModal() => IsModalOpen = true;
    private void CloseModal() => IsModalOpen = false;
    private async Task SaveData()
    {
        // Giả lập lưu dữ liệu delay 0.5s rồi đóng
        await Task.Delay(500);
        IsModalOpen = false;
    }

    class ParentMember { public string Role { get; set; } = ""; public string ParentName { get; set; } = ""; public string StudentName { get; set; } = ""; public string Phone { get; set; } = ""; }
    List<ParentMember> Members = new()
    {
        new ParentMember { Role = "Trưởng ban", ParentName = "Nguyễn Văn Cha", StudentName = "Nguyễn Văn Học Sinh 1", Phone = "0909 123 456" },
        new ParentMember { Role = "Phó ban", ParentName = "Trần Thị Mẹ", StudentName = "Lê Trần Học Sinh 5", Phone = "0988 765 432" },
        new ParentMember { Role = "Thành viên", ParentName = "Lê Văn Phụ Huynh", StudentName = "Lê Học Sinh 12", Phone = "0912 345 678" }
    };

    private string GetRoleColor(string role) => role == "Trưởng ban" ? "tag-red" : role == "Phó ban" ? "tag-blue" : "tag-gray";
}

<style>
    /* Dùng chung cho trang con */
    .scn-child-container {
        padding: 0.5rem;
    }

    .flex-between {
        display: flex;
