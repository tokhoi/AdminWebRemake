<div class="scn-child-container animate-fade-in">
    <div style="display: flex; justify-content: space-between; margin-bottom: 1.5rem;">
        <h2 style="margin: 0; font-size: 1.1rem; color: var(--text-main);">Kế hoạch Chủ nhiệm Năm học</h2>
        <div style="display: flex; align-items: center; gap: 10px;">
            @if (ShowSaveSuccess)
            {
                <span style="color: var(--kg-success); font-weight: 600; font-size: 0.9rem;">Đã lưu thành công!</span>
            }
            <button class="btn-primary" @onclick="SavePlan" disabled="@IsSaving">
                <span class="material-icons-round">@(IsSaving ? "sync" : "save")</span> @(IsSaving ? "Đang lưu..." : "Lưu kế hoạch")
            </button>
        </div>
    </div>

    <div class="editor-wrapper">
        <div class="editor-toolbar">
            <button class="editor-btn fw-bold @(IsBold ? "active" : "")" @onclick="() => IsBold = !IsBold">B</button>
            <button class="editor-btn @(IsItalic ? "active" : "")" style="font-style: italic;" @onclick="() => IsItalic = !IsItalic">I</button>
            <button class="editor-btn @(IsUnderline ? "active" : "")" style="text-decoration: underline;" @onclick="() => IsUnderline = !IsUnderline">U</button>
            <div class="editor-divider"></div>
            <button class="editor-btn"><span class="material-icons-round" style="font-size: 18px;">format_list_bulleted</span></button>
            <button class="editor-btn"><span class="material-icons-round" style="font-size: 18px;">format_list_numbered</span></button>
            <div class="editor-divider"></div>
            <button class="editor-btn"><span class="material-icons-round" style="font-size: 18px;">format_align_left</span></button>
            <button class="editor-btn"><span class="material-icons-round" style="font-size: 18px;">format_align_center</span></button>
        </div>

        <textarea class="editor-textarea"
                  style="font-weight: @(IsBold ? "bold" : "normal"); font-style: @(IsItalic ? "italic" : "normal"); text-decoration: @(IsUnderline ? "underline" : "none");"
                  @bind="PlanContent" @bind:event="oninput"
                  placeholder="Nhập nội dung kế hoạch chủ nhiệm của bạn tại đây..."></textarea>
    </div>
</div>

@code {
    private string PlanContent = "1. MỤC TIÊU PHẤN ĐẤU:\n- 100% học sinh đạt hạnh kiểm Tốt.\n- Duy trì nề nếp kỷ luật lớp học...";

    // Formatting states
    private bool IsBold = false;
    private bool IsItalic = false;
    private bool IsUnderline = false;

    // Save states
    private bool IsSaving = false;
    private bool ShowSaveSuccess = false;

    private async Task SavePlan()
    {
        IsSaving = true;
        ShowSaveSuccess = false;
        await Task.Delay(1000); // Giả lập call API lưu DB
        IsSaving = false;
        ShowSaveSuccess = true;

        // Ẩn thông báo sau 3 giây
        await Task.Delay(3000);
        ShowSaveSuccess = false;
        StateHasChanged();
    }
}


