<div class="scn-child-container animate-fade-in">
    <div class="toolbar flex-between">
        <div style="display:flex; gap: 1rem;">
            <select class="input-control"><option>Tất cả các tổ</option><option>Tổ 1</option><option>Tổ 2</option></select>
            <input type="text" class="input-control" placeholder="Tìm tên hoặc mã học sinh..." style="width: 280px;" @bind="SearchQuery" @bind:event="oninput" />
        </div>
        <button class="btn-primary" @onclick="OpenAddModal"><span class="material-icons-round">person_add</span> Thêm học sinh</button>
    </div>

    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 60px; text-align: center;">STT</th>
                    <th>Mã HS</th>
                    <th>Họ và tên</th>
                    <th>Ngày sinh</th>
                    <th>Giới tính</th>
                    <th style="text-align: center;">Trạng thái</th>
                    <th style="text-align: center;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (!FilteredStudents.Any())
                {
                    <tr><td colspan="7" style="text-align: center; padding: 2rem; color: var(--text-muted);">Không tìm thấy học sinh nào</td></tr>
                }
                @foreach (var s in FilteredStudents.Select((val, i) => new { val, i }))
                {
                    <tr>
                        <td style="text-align: center; color: var(--text-muted);">@(s.i + 1)</td>
                        <td><span class="tag tag-gray">@s.val.Code</span></td>
                        <td style="font-weight: 600; color: var(--text-main);">@s.val.Name</td>
                        <td>@s.val.Dob</td>
                        <td>@s.val.Gender</td>
                        <td style="text-align: center;"><span class="tag tag-green">Đang học</span></td>
                        <td style="text-align: center;">
                            <button class="icon-btn"><span class="material-icons-round">edit</span></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Modal Thêm Học Sinh *@
@if (ShowModal)
{
    <div class="modal-backdrop" @onclick="CloseAddModal">
        <div class="modal-content animate-slide-down" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="margin:0; font-size:1.1rem;">Thêm Học Sinh Mới</h3>
                <button class="icon-btn" @onclick="CloseAddModal"><span class="material-icons-round">close</span></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                <div><label style="font-weight:600; font-size:0.85rem;">Họ và tên</label><input type="text" class="input-control" style="width:100%; margin-top:4px;" /></div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div><label style="font-weight:600; font-size:0.85rem;">Ngày sinh</label><input type="date" class="input-control" style="width:100%; margin-top:4px;" /></div>
                    <div><label style="font-weight:600; font-size:0.85rem;">Giới tính</label><select class="input-control" style="width:100%; margin-top:4px;"><option>Nam</option><option>Nữ</option></select></div>
                </div>
            </div>
            <div class="modal-footer" style="padding: 1rem 1.5rem; background: #f8fafc; border-top: 1px solid var(--border); text-align: right;">
                <button class="btn-outline" style="margin-right: 8px;" @onclick="CloseAddModal">Hủy</button>
                <button class="btn-primary" @onclick="CloseAddModal">Lưu thông tin</button>
            </div>
        </div>
    </div>
}

@code {
    class StudentMock { public string Code { get; set; } = ""; public string Name { get; set; } = ""; public string Dob { get; set; } = ""; public string Gender { get; set; } = ""; }
    List<StudentMock> Students = new();
    string SearchQuery = "";
    bool ShowModal = false;

    protected override void OnInitialized()
    {
        for (int i = 1; i <= 10; i++)
        {
            Students.Add(new StudentMock
            {
                Code = $"HS2025_00{i}",
                Name = $"Nguyễn Văn Học Sinh {i}",
                Dob = $"15/08/2010",
                Gender = i % 2 == 0 ? "Nữ" : "Nam"
            });
        }
    }

    IEnumerable<StudentMock> FilteredStudents => Students.Where(s => string.IsNullOrEmpty(SearchQuery) || s.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || s.Code.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    void OpenAddModal() => ShowModal = true;
    void CloseAddModal() => ShowModal = false;
}

<style>
