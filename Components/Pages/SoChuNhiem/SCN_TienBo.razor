<div class="scn-child-container animate-fade-in">
    <div class="toolbar flex-between">
        <div>
            <h2 class="page-title">Theo dõi Tiến bộ của Học sinh</h2>
            <span class="text-muted">So sánh giữa Đầu kỳ và Hiện tại</span>
        </div>
        <div style="display: flex; gap: 10px;">
            <select class="input-control"><option>Môn Toán học</option><option>Môn Ngữ Văn</option><option>Hạnh kiểm</option></select>
            <button class="btn-primary"><span class="material-icons-round">edit_note</span> Cập nhật điểm</button>
        </div>
    </div>

    <div class="table-wrapper">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 60px; text-align: center;">STT</th>
                    <th>Họ và tên</th>
                    <th style="text-align: center;">Đầu kỳ</th>
                    <th style="text-align: center;">Hiện tại</th>
                    <th style="text-align: center;">Xu hướng</th>
                    <th>Nhận xét của GV</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in ProgressList.Select((val, i) => new { val, i }))
                {
                    <tr>
                        <td style="text-align: center; color: var(--text-muted);">@(s.i + 1)</td>
                        <td style="font-weight: 600; color: var(--text-main);">@s.val.Name</td>
                        <td style="text-align: center; font-family: monospace; font-size: 1.1rem;">@s.val.OldScore</td>
                        <td style="text-align: center; font-family: monospace; font-size: 1.1rem; font-weight: bold;">@s.val.NewScore</td>
                        <td style="text-align: center;">
                            @if (s.val.NewScore > s.val.OldScore)
                            {
                                <span class="trend-icon text-success" title="Tiến bộ"><span class="material-icons-round">trending_up</span></span>
                            }
                            else if (s.val.NewScore < s.val.OldScore)
                            {
                                <span class="trend-icon text-danger" title="Sa sút"><span class="material-icons-round">trending_down</span></span>
                            }
                            else
                            {
                                <span class="trend-icon text-warning" title="Giữ vững"><span class="material-icons-round">trending_flat</span></span>
                            }
                        </td>
                        <td style="font-size: 0.85rem; color: var(--text-muted);">@s.val.Comment</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    class Progress { public string Name { get; set; } = ""; public double OldScore { get; set; } public double NewScore { get; set; } public string Comment { get; set; } = ""; }
    List<Progress> ProgressList = new()
    {
        new Progress { Name = "Nguyễn Văn A", OldScore = 6.5, NewScore = 8.0, Comment = "Có cố gắng làm bài tập đầy đủ, thái độ học tốt hơn." },
        new Progress { Name = "Trần Thị B", OldScore = 9.0, NewScore = 9.0, Comment = "Giữ vững phong độ học tập." },
        new Progress { Name = "Lê Văn C", OldScore = 8.5, NewScore = 6.0, Comment = "Gần đây hay mất tập trung, cần phụ huynh đôn đốc thêm." },
        new Progress { Name = "Hoàng Mai D", OldScore = 5.0, NewScore = 7.5, Comment = "Tiến bộ vượt bậc, đã nắm được kiến thức nền tảng." }
    };
}

<style>
    .scn-child-container {
        padding: 0.5rem;
    }

    .flex-between {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .toolbar {
        padding-bottom: 1rem;
        margin-bottom: 1rem;
        border-bottom: 1px solid var(--border);
    }

    .page-title {
        margin: 0 0 0.25rem 0;
        font-size: 1.15rem;
        color: var(--text-main);
    }

    .text-muted {
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .input-control {
        padding: 8px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 6px;
        outline: none;
    }

    .btn-primary {
        background: #1b6ec2;
        color: white;
        border: none;
        padding: 8px 16px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        font-weight: 600;
    }

    .table-wrapper {
        background: white;
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

        .data-table th {
            background: #f8fafc;
            padding: 12px 1rem;
            text-align: left;
            font-size: 0.85rem;
            color: var(--text-muted);
            border-bottom: 1px solid var(--border);
        }

        .data-table td {
            padding: 12px 1rem;
            border-bottom: 1px solid #f1f5f9;
            vertical-align: middle;
        }

        .data-table tr:hover td {
            background: #f8fafc;
        }

    .trend-icon {
        padding: 4px 8px;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .text-success {
        color: #10b981;
        background: #d1fae5;
    }

    .text-danger {
        color: #ef4444;
        background: #fee2e2;
    }

    .text-warning {
        color: #f59e0b;
        background: #fef3c7;
    }
</style>