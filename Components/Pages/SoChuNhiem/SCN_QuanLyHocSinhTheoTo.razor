<div class="scn-child-container animate-fade-in">
    <div class="toolbar flex-between">
        <div>
            <h2 class="page-title">Quản lý học sinh theo Tổ</h2>
            <span class="text-muted">Tổng số: 4 Tổ - 40 Học sinh</span>
        </div>
        <button class="btn-outline"><span class="material-icons-round">shuffle</span> Sắp xếp ngẫu nhiên</button>
    </div>

    <div class="team-grid">
        @for (int t = 1; t <= 4; t++)
        {
            <div class="team-card">
                <div class="team-header">
                    <h3 style="margin: 0; color: var(--kg-primary);">Tổ @t</h3>
                    <span class="tag tag-gray">10 HS</span>
                </div>
                <div class="team-list">
                    <div class="team-member" style="background: var(--kg-accent-soft); border-color: var(--kg-accent-soft);">
                        <span class="material-icons-round" style="color: var(--kg-warning);">star</span>
                        <div style="flex: 1;">
                            <div style="font-weight: 600; font-size: 0.9rem;">Nguyễn Văn Tổ Trưởng @t</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">Tổ trưởng</div>
                        </div>
                    </div>
                    @for (int hs = 1; hs <= 4; hs++)
                    {
                        <div class="team-member">
                            <div class="avatar-sm"></div>
                            <div style="font-size: 0.9rem;">Thành viên @t.@hs</div>
                        </div>
                    }
                    <button class="add-member-btn"><span class="material-icons-round">add</span> Thêm học sinh vào tổ</button>
                </div>
            </div>
        }
    </div>
</div>



