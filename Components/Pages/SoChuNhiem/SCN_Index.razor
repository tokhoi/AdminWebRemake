<div class="scn-child-container animate-fade-in">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <div>
            <h2 style="margin: 0; font-size: 1.25rem; color: var(--text-main);">Tổng quan Lớp 10A1</h2>
            <span style="color: var(--text-muted); font-size: 0.9rem;">Giáo viên chủ nhiệm: Nguyễn Văn A | Sĩ số: 45 HS</span>
        </div>
        <button class="btn-export" @onclick="OpenCustomizeModal">
            <span class="material-icons-round">dashboard_customize</span> <span>Tùy chỉnh giao diện</span>
        </button>
    </div>

    <div class="stats-grid">
        <div class="stat-card" style="border-left: 4px solid var(--kg-primary);">
            <div class="stat-icon" style="background: var(--kg-primary-soft); color: var(--kg-primary);"><span class="material-icons-round">groups</span></div>
            <div>
                <div class="stat-title">Đi học hôm nay</div>
                <div class="stat-value" style="color: var(--kg-primary);">42/45 <span class="stat-unit">HS</span></div>
            </div>
        </div>
        <div class="stat-card" style="border-left: 4px solid var(--kg-primary);">
            <div class="stat-icon" style="background: var(--kg-primary-soft); color: var(--kg-primary);"><span class="material-icons-round">trending_up</span></div>
            <div>
                <div class="stat-title">Chuyên cần tuần</div>
                <div class="stat-value" style="color: var(--kg-primary);">98.5%</div>
            </div>
        </div>
        <div class="stat-card" style="border-left: 4px solid var(--kg-primary);">
            <div class="stat-icon" style="background: var(--kg-primary-soft); color: var(--kg-primary);"><span class="material-icons-round">warning_amber</span></div>
            <div>
                <div class="stat-title">Nhắc nhở / Kỷ luật</div>
                <div class="stat-value" style="color: var(--kg-primary);">3 <span class="stat-unit">Lượt</span></div>
            </div>
        </div>
        <div class="stat-card" style="border-left: 4px solid var(--kg-primary);">
            <div class="stat-icon" style="background: var(--kg-primary-soft); color: var(--kg-primary);"><span class="material-icons-round">assignment_late</span></div>
            <div>
                <div class="stat-title">Chưa đóng BHYT</div>
                <div class="stat-value" style="color: var(--kg-primary);">5 <span class="stat-unit">HS</span></div>
            </div>
        </div>
    </div>

    <div class="dashboard-widgets">

        <div class="widget-col-main">
            @if (ShowAttentionWidget)
            {
                <div class="widget-card animate-fade-in">
                    <div class="widget-header flex-between">
                        <h3 class="widget-title"><span class="material-icons-round" style="color: var(--kg-primary);">notifications_active</span> Học sinh cần chú ý hôm nay</h3>
                        <a href="#" class="widget-link">Xem tất cả</a>
                    </div>
                    <div class="widget-body" style="padding: 0;">
                        <table class="widget-table">
                            <tbody>
                                @foreach (var hs in AttentionStudents)
                                {
                                    <tr>
                                        <td style="width: 50px;">
                                            <div class="avatar-sm">@hs.Name.Substring(0, 1)</div>
                                        </td>
                                        <td>
                                            <div style="font-weight: 600; color: var(--text-main);">@hs.Name</div>
                                            <div style="font-size: 0.8rem; color: var(--text-muted);">Mã: @hs.Code</div>
                                        </td>
                                        <td>
                                            @if (hs.IssueType == "Vắng mặt")
                                            {
                                                <span class="tag tag-red">Vắng không phép</span>
                                            }
                                            else if (hs.IssueType == "Đi trễ")
                                            {

                                                <span class="tag tag-warning">Đi trễ 15p</span>
                                            }
                                            else
                                            {

                                                <span class="tag tag-gray">Vi phạm nội quy</span>
                                            }
                                        </td>
                                        <td style="text-align: right;">
                                            <button class="btn-action-sm">Liên hệ PH</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (ShowProgressWidget)
            {
                <div class="widget-card animate-fade-in">
                    <div class="widget-header">
                        <h3 class="widget-title"><span class="material-icons-round" style="color: var(--kg-primary);">flag</span> Thi đua tuần 20</h3>
                    </div>
                    <div class="widget-body">
                        <div class="progress-item">
                            <div class="flex-between" style="margin-bottom: 6px;">
                                <span class="fw-bold" style="font-size: 0.9rem;">Học tập (Hoa điểm 10)</span>
                                <span style="font-size: 0.85rem; color: var(--kg-text-main); font-weight: bold;">Đạt 85% mục tiêu</span>
                            </div>
                            <div class="progress-bar-bg"><div class="progress-bar-fill" style="width: 85%; background: var(--kg-primary);"></div></div>
                        </div>
                        <div class="progress-item mt-3">
                            <div class="flex-between" style="margin-bottom: 6px;">
                                <span class="fw-bold" style="font-size: 0.9rem;">Nề nếp & Kỷ luật</span>
                                <span style="font-size: 0.85rem; color: var(--kg-text-main); font-weight: bold;">Trừ 15 điểm</span>
                            </div>
                            <div class="progress-bar-bg"><div class="progress-bar-fill" style="width: 70%; background: var(--kg-primary);"></div></div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="widget-col-side">
            @if (ShowEventsWidget)
            {
                <div class="widget-card animate-fade-in">
                    <div class="widget-header">
                        <h3 class="widget-title"><span class="material-icons-round" style="color: var(--kg-primary);">cake</span> Sự kiện sắp tới</h3>
                    </div>
                    <div class="widget-body">
                        <div class="event-item">
                            <div class="event-date">
                                <span class="day">12</span><span class="month">Thg 3</span>
                            </div>
                            <div class="event-info">
                                <div class="event-title">Sinh nhật Lê Văn C</div>
                                <div class="event-desc">Học sinh tổ 2</div>
                            </div>
                        </div>
                        <div class="event-item">
                            <div class="event-date" style="background: var(--kg-primary-soft); color: var(--kg-primary);">
                                <span class="day">15</span><span class="month">Thg 3</span>
                            </div>
                            <div class="event-info">
                                <div class="event-title">Họp Hội đồng SP</div>
                                <div class="event-desc">14:00 tại Hội trường A</div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (ShowTodoWidget)
            {
                <div class="widget-card animate-fade-in">
                    <div class="widget-header">
                        <h3 class="widget-title"><span class="material-icons-round" style="color: var(--kg-primary);">task_alt</span> Công việc tuần này</h3>
                    </div>
                    <div class="widget-body">
                        <label class="todo-item">
                            <input type="checkbox" checked /> <span class="todo-text done">Cập nhật điểm 15 phút</span>
                        </label>
                        <label class="todo-item">
                            <input type="checkbox" /> <span class="todo-text">Liên hệ PH em Lê Hữu Nghĩa</span>
                        </label>
                        <label class="todo-item">
                            <input type="checkbox" /> <span class="todo-text">Nộp sổ chủ nhiệm tháng</span>
                        </label>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* ================= MODAL TÙY CHỈNH ================= *@
@if (IsCustomizeModalOpen)
{
    <div class="modal-backdrop" @onclick="CloseCustomizeModal">
        <div class="modal-content animate-slide-down" style="width: 400px;" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3 style="margin: 0; font-size: 1.1rem; display: flex; align-items: center; gap: 8px;">
                    <span class="material-icons-round" style="color: var(--primary);">dashboard_customize</span>
                    Tùy chỉnh Dashboard
                </h3>
                <button class="icon-btn" @onclick="CloseCustomizeModal"><span class="material-icons-round">close</span></button>
            </div>

            <div class="modal-body" style="padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;">
                <p style="margin: 0 0 10px 0; font-size: 0.9rem; color: var(--text-muted);">Bật/tắt các khối thông tin hiển thị trên màn hình chính của bạn.</p>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <span class="material-icons-round" style="color: var(--kg-danger);">notifications_active</span>
                        <span class="fw-bold">Học sinh cần chú ý</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="ShowAttentionWidget">
                        <span class="slider round"></span>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <span class="material-icons-round" style="color: var(--kg-primary);">flag</span>
                        <span class="fw-bold">Tiến độ thi đua</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="ShowProgressWidget">
                        <span class="slider round"></span>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <span class="material-icons-round" style="color: var(--kg-danger);">cake</span>
                        <span class="fw-bold">Sự kiện & Sinh nhật</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="ShowEventsWidget">
                        <span class="slider round"></span>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-info">
                        <span class="material-icons-round" style="color: var(--kg-purple);">task_alt</span>
                        <span class="fw-bold">Nhắc việc nhanh</span>
                    </div>
                    <label class="switch">
                        <input type="checkbox" @bind="ShowTodoWidget">
                        <span class="slider round"></span>
                    </label>
                </div>
            </div>

            <div class="modal-footer" style="padding: 1rem 1.5rem; background: var(--kg-bg-subtle); border-top: 1px solid var(--border); text-align: right;">
                <button class="btn-primary" @onclick="CloseCustomizeModal" style="background: var(--kg-success);">Hoàn tất</button>
            </div>
        </div>
    </div>
}

@code {
    // State quản lý hiển thị các Widget
    private bool ShowAttentionWidget = true;
    private bool ShowProgressWidget = true;
    private bool ShowEventsWidget = true;
    private bool ShowTodoWidget = true;

    // State Modal
    private bool IsCustomizeModalOpen = false;
    private void OpenCustomizeModal() => IsCustomizeModalOpen = true;
    private void CloseCustomizeModal() => IsCustomizeModalOpen = false;

    class AttentionStudent { public string Name { get; set; } = ""; public string Code { get; set; } = ""; public string IssueType { get; set; } = ""; }
    List<AttentionStudent> AttentionStudents = new()
    {
        new AttentionStudent { Name = "Trần Thị B", Code = "HS015", IssueType = "Vắng mặt" },
        new AttentionStudent { Name = "Lê Hữu Nghĩa", Code = "HS022", IssueType = "Đi trễ" },
        new AttentionStudent { Name = "Nguyễn Hoàng Nam", Code = "HS008", IssueType = "Vi phạm" }
    };
}


