@page "/learning/pointInput"
@rendermode InteractiveServer
@inject IJSRuntime JS

<div class="st-page-wrapper st-page-fixed score-sheet-page score-sheet-page--point-input">
    @* --- HEADER --- *@
    <div class="st-page-header">
        <div class="st-title-icon" style="background:var(--kg-primary)">
            <span class="material-icons-round">table_view</span>
        </div>
        <h4>Nhập điểm môn học</h4>
    </div>

    @* --- THÔNG BÁO --- *@
    @if (isSystemLocked)
    {
        <div class="st-alert st-alert-locked">
            <span class="material-icons-round" style="font-size:20px">warning_amber</span>
            <div>
                <b>Hệ thống đã khóa nhập liệu.</b><br />Đợt nhập điểm này đã kết thúc hoặc bị khóa bởi Quản trị viên. Bạn chỉ có quyền xem.
            </div>
        </div>
    }
    else if (isTeacherLocked)
    {
        <div class="st-alert st-alert-success">
            <span class="material-icons-round" style="font-size:20px">check_circle</span>
            <div>
                <b>Bạn đã hoàn tất và khóa sổ môn này.</b><br />Dữ liệu an toàn. Vui lòng liên hệ Admin nếu cần mở lại.
            </div>
            <button class="st-btn st-btn-outline st-ms-auto" @onclick="UnlockGradeSheet" style="border-color:var(--kg-success); color:var(--kg-success);">Xin mở lại</button>
        </div>
    }

    @* --- FILTER BAR --- *@
    <div class="st-filter-bar">
        <div class="st-filter-group"><label>Khối:</label><select class="st-form-control st-form-select-sm"><option>Khối 10</option></select></div>
        <div class="st-filter-group"><label>Lớp:</label><select class="st-form-control st-form-select-sm"><option>10A1</option></select></div>

        <div class="st-filter-group">
            <label>Môn:</label>
            <select value="@selectedSubjectId" @onchange="OnSubjectChanged" class="st-form-control st-form-select-sm st-select-highlight">
                @foreach (var sub in listSubjects)
                {
                    <option value="@sub.Id">@sub.Name</option>
                }
            </select>
        </div>

        <div class="st-filter-group">
            <label>Học kỳ:</label>
            <select @bind="hocKy" class="st-form-control st-form-select-sm st-select-highlight" disabled>
                <option value="1">Học kỳ 1</option>
                <option value="2">Học kỳ 2</option>
            </select>
        </div>

        <div class="st-filter-group st-ms-auto" style="position: relative; margin-left: 20px;">
            <label style="cursor:pointer; display:flex; align-items:center; gap:5px">
                <input type="checkbox" @bind="isAutoRound" disabled="@IsReadOnlyMode" class="st-check-input">
                <span style="@(IsReadOnlyMode ? "color:var(--kg-text-muted)" : "color:var(--kg-text-main)")">Tự động làm tròn</span>
            </label>
            @if (showTutorial)
            {
                <div class="st-popup-blue">
                    <div class="st-popup-arrow"></div>
                    <div style="display:flex; gap:8px;">
                        <span class="material-icons-round">info</span>
                        <div>Khi chọn ô hệ thống tự động làm tròn.<br />VD: <b>8.25</b> &rarr; <b>8.5</b></div>
                    </div>
                    <button class="st-popup-close" @onclick="() => showTutorial = false">Đã hiểu</button>
                </div>
            }
        </div>

        <div class="st-d-flex st-gap-2 st-ms-auto">
            @if (!IsReadOnlyMode)
            {
                <button class="st-btn st-btn-success" @onclick="SaveData">
                    <span class="material-icons-round">save</span> Lưu lại
                </button>
            }
            <button class="st-btn st-btn-warning" @onclick="LockGradeSheet">
                <span class="material-icons-round">lock</span> Khóa sổ
            </button>
            <button class="st-btn st-btn-primary">
                <span class="material-icons-round">file_download</span> Xuất Excel
            </button>
        </div>
    </div>

    @* --- EXCEL TABLE --- *@
    <div class="st-table-container">
        @if (isLoading)
        {
            <div style="padding: 20px; text-align: center; color: var(--kg-text-muted);">
                <div class="st-spin"><span class="material-icons-round">sync</span></div> Đang tải dữ liệu...
            </div>
        }
        else
        {
            <table class="st-excel-table">
                <thead>
                    <tr>
                        <th rowspan="2" class="st-sticky-col st-col-stt st-z-corner">STT</th>
                        <th rowspan="2" class="st-sticky-col st-col-view st-z-corner">Xem</th>
                        <th rowspan="2" class="st-sticky-col st-col-code st-z-corner">Mã ĐD</th>
                        <th rowspan="2" class="st-sticky-col st-col-name st-z-corner">Họ và tên</th>

                        <th colspan="@currentSubject.TxCols" class="st-th-group">ĐĐGtx (Hệ số 1)</th>

                        <th rowspan="2" class="st-col-score">Giữa kỳ</th>
                        <th rowspan="2" class="st-col-score">Cuối kỳ</th>

                        @if (hocKy == 1)
                        {
                            <th rowspan="2" class="st-col-score" style="background:var(--kg-primary); color:var(--kg-bg-card);">ĐTB HK1</th>
                            <th rowspan="2" class="st-col-note">Nhận xét HK1</th>
                        }
                        else
                        {
                            <th rowspan="2" class="st-col-score st-text-muted" style="background:var(--kg-bg-subtle);">ĐTB HK1</th>
                            <th rowspan="2" class="st-col-score" style="background:var(--kg-primary); color:var(--kg-bg-card);">ĐTB HK2</th>
                            <th rowspan="2" class="st-col-score" style="background:var(--kg-danger); color:var(--kg-bg-card);">Cả năm</th>
                            <th rowspan="2" class="st-col-note">Nhận xét HK2</th>
                            <th rowspan="2" class="st-col-note">Nhận xét CN</th>
                        }
                    </tr>
                    <tr>
                        @for (int i = 1; i <= currentSubject.TxCols; i++)
                        {
                            <th class="st-col-score">@i</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var st in currentStudents)
                    {
                        <tr>
                            <td class="st-sticky-col st-col-stt st-text-center">@st.Stt</td>
                            <td class="st-sticky-col st-col-view st-text-center">
                                <span class="material-icons-round st-text-muted" style="font-size:18px; cursor:pointer">visibility</span>
                            </td>
                            <td class="st-sticky-col st-col-code st-text-center">@st.Code</td>
                            <td class="st-sticky-col st-col-name" style="font-weight:600; color:var(--kg-text-main); padding-left:8px!important; text-align:left;">@st.Name</td>

                            @for (int c = 0; c < currentSubject.TxCols; c++)
                            {
                                int colIndex = c;
                                <td class="st-td-inp">
                                    <input class="st-inp @(st.Errors.Contains(colIndex) ? "st-err" : "")"
                                           disabled="@IsReadOnlyMode"
                                           value="@st.TxScores[colIndex]"
                                           @onchange="@(e => UpdateScore(st, colIndex, e.Value?.ToString()))" />
                                </td>
                            }

                            <td class="st-td-inp"><input class="st-inp" disabled="@IsReadOnlyMode" value="@st.GkScore" /></td>
                            <td class="st-td-inp"><input class="st-inp" disabled="@IsReadOnlyMode" value="@st.CkScore" /></td>

                            @if (hocKy == 1)
                            {
                                <td class="st-td-readonly">@st.AvgHK1</td>
                                <td class="st-td-inp"><input class="st-inp st-text-start px-2" disabled="@IsReadOnlyMode" value="@st.NoteHK1" /></td>
                            }
                            else
                            {
                                <td class="st-td-readonly st-text-muted">@st.AvgHK1</td>
                                <td class="st-td-readonly" style="font-weight:bold">@st.AvgHK2</td>
                                <td class="st-td-readonly st-text-danger" style="font-weight:bold">@st.AvgYear</td>
                                <td class="st-td-inp"><input class="st-inp st-text-start px-2" disabled="@IsReadOnlyMode" value="@st.NoteHK2" /></td>
                                <td class="st-td-inp"><input class="st-inp st-text-start px-2" disabled="@IsReadOnlyMode" value="@st.NoteCN" /></td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* --- FOOTER --- *@
    <div class="st-footer">
        <div class="st-pager">
            <button @onclick="() => LoadData(1)" disabled="@(currentPage == 1)">
                <span class="material-icons-round">first_page</span>
            </button>
            <button @onclick="() => LoadData(currentPage - 1)" disabled="@(currentPage == 1)">
                <span class="material-icons-round">chevron_left</span>
            </button>
            <span class="st-page-info">Trang @currentPage / @totalPages</span>
            <button @onclick="() => LoadData(currentPage + 1)" disabled="@(currentPage == totalPages)">
                <span class="material-icons-round">chevron_right</span>
            </button>
            <button @onclick="() => LoadData(totalPages)" disabled="@(currentPage == totalPages)">
                <span class="material-icons-round">last_page</span>
            </button>
        </div>
        <div style="font-size:13px; color:var(--kg-text-muted); font-weight: 500;">
            Tổng số: <b style="color:var(--kg-primary)">@totalItems</b> học sinh
        </div>
    </div>
</div>

@code {
    public class SubjectConfig { public string Id { get; set; } public string Name { get; set; } public int TxCols { get; set; } }
    List<SubjectConfig> listSubjects = new List<SubjectConfig>
    {
        new SubjectConfig { Id = "Toan", Name = "Toán", TxCols = 4 },
        new SubjectConfig { Id = "Van", Name = "Ngữ Văn", TxCols = 3 },
        new SubjectConfig { Id = "Anh", Name = "Tiếng Anh", TxCols = 4 },
        new SubjectConfig { Id = "Ly", Name = "Vật Lý", TxCols = 3 },
        new SubjectConfig { Id = "Hoa", Name = "Hóa Học", TxCols = 3 },
        new SubjectConfig { Id = "Sinh", Name = "Sinh Học", TxCols = 2 },
        new SubjectConfig { Id = "Su", Name = "Lịch Sử", TxCols = 2 }
    };

    bool isAutoRound = false, isLoading = false, showTutorial = true, isSystemLocked = false, isTeacherLocked = false;
    int hocKy = 1, currentPage = 1, pageSize = 20, totalItems = 0;
    string selectedSubjectId = "Toan";
    SubjectConfig currentSubject => listSubjects.First(s => s.Id == selectedSubjectId);
    bool IsReadOnlyMode => isSystemLocked || isTeacherLocked;
    int totalPages => (int)Math.Ceiling((double)totalItems / pageSize);

    List<Student> currentStudents = new List<Student>();
    class Student
    {
        public int Stt; public string Code;
        public string Name;
        public List<string> TxScores = new List<string> { "", "", "", "", "", "" };
        public HashSet<int> Errors = new HashSet<int>();
        public string GkScore; public string CkScore;
        public string AvgHK1 = "7.5";
        public string AvgHK2 = "8.2"; public string AvgYear = "7.9";
        public string NoteHK1; public string NoteHK2; public string NoteCN;
    }

    protected override async Task OnInitializedAsync()
    {
        await CheckActivePeriod(); await LoadData(1);
    }

    async Task CheckActivePeriod()
    {
        var activePeriod = new { Semester = 2, ToDate = DateTime.Now.AddDays(5), IsActive = true };
        hocKy = activePeriod.Semester;
        isSystemLocked = !activePeriod.IsActive || DateTime.Now > activePeriod.ToDate;
    }

    async Task OnSubjectChanged(ChangeEventArgs e)
    {
        selectedSubjectId = e.Value.ToString(); await LoadData(1);
    }

    async Task LoadData(int page)
    {
        if (page < 1) page = 1;
        isLoading = true; await Task.Delay(300);
        currentPage = page; totalItems = 55; currentStudents.Clear();
        int startStt = (page - 1) * pageSize + 1;
        int itemsToTake = Math.Min(pageSize, totalItems - (page - 1) * pageSize);
        for (int i = 0; i < itemsToTake; i++)
        {
            int realStt = startStt + i;
            currentStudents.Add(new Student { Stt = realStt, Code = "HS" + (2000 + realStt), Name = GetRandomName(realStt) });
        }
        isLoading = false;
    }

    async Task SaveData()
    {
        await Task.Delay(500); await JS.InvokeVoidAsync("alert", "Lưu dữ liệu thành công!");
    }
    async Task LockGradeSheet()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "XÁC NHẬN KHÓA SỔ?");
        if (confirmed) { await Task.Delay(300); isTeacherLocked = true; }
    }
    void UnlockGradeSheet()
    {
        JS.InvokeVoidAsync("alert", "Đã gửi yêu cầu mở khóa!");
    }

    void UpdateScore(Student st, int idx, string val)
    {
        if (IsReadOnlyMode) return;
        st.TxScores[idx] = val;
        if (string.IsNullOrWhiteSpace(val)) { st.Errors.Remove(idx); return; }
        if (double.TryParse(val, out double d))
        {
            if (d < 0 || d > 10) st.Errors.Add(idx);
            else
            {
                st.Errors.Remove(idx); if (isAutoRound) d = Math.Round(d * 2, MidpointRounding.AwayFromZero) / 2; st.TxScores[idx] = d.ToString("0.##");
            }
        }
        else st.Errors.Add(idx);
    }
    string GetRandomName(int i)
    {
        string[] ho = { "Nguyễn", "Trần", "Lê", "Phạm", "Huỳnh", "Hoàng" };
        string[] ten = { "Anh", "Bình", "Châu", "Dũng", "Em", "Giang", "Hân", "Khánh" };
        return $"{ho[i % ho.Length]} {ten[i % ten.Length]}";
    }
}





