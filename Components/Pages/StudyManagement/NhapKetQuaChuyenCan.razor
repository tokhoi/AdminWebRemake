@page "/learning/chuyen-can"

<div class="training-page score-attendance-page">
    @* --- HEADER SECTION --- *@
    <div class="header-section">
        <div class="page-title">
            <div class="icon-title"><i class="fa-solid fa-user-shield"></i></div>
            <h4>NHẬP KẾT QUẢ CHUYÊN CẦN</h4>
        </div>

        @* Alert Info *@
        <div class="alert-box info">
            <i class="fa-solid fa-circle-info me-2"></i>
            <div>
                <strong>Quy tắc tự động tính Cả năm:</strong>
                <ul class="mb-0 ps-3">
                    <li><b>Tổng ngày vắng Cả năm:</b> Bằng tổng số ngày vắng của Học kỳ 1 và Học kỳ 2 cộng lại.</li>
                    <li>Dữ liệu sẽ tự động được cộng dồn khi bạn nhập số liệu ở Học kỳ 2.</li>
                </ul>
            </div>
        </div>

        @* --- FILTER BAR --- *@
        <div class="filter-bar">
            <div class="group">
                <label>Khối:</label>
                <select class="select-highlight"><option>Khối 10</option></select>
            </div>
            <div class="group">
                <label>Lớp:</label>
                <select class="select-highlight"><option>10A1</option></select>
            </div>
            <div class="group">
                <label>Học kỳ:</label>
                <select class="select-highlight" @bind="selectedHocKy">
                    <option value="1">Học kỳ 1</option>
                    <option value="2">Học kỳ 2</option>
                </select>
            </div>

            @* Quick Actions *@
            <div class="actions-group ms-auto">
                <button class="btn-custom btn-primary" @onclick="OpenImportModal" title="Nhập dữ liệu từ file Excel">
                    <i class="fa-solid fa-file-import"></i> Nhập dữ liệu (FILE EXCEL)
                </button>
                <button class="btn-custom btn-save">
                    <i class="fa-solid fa-floppy-disk"></i> Lưu lại
                </button>
                <button class="btn-excel">
                    <i class="fa-solid fa-file-excel"></i> Xuất Excel
                </button>
            </div>
        </div>

        @* Class Info Bar *@
        <div class="class-info-bar">
            <i class="fa-solid fa-folder-tree"></i> Khối 10 &nbsp;|&nbsp;
            <i class="fa-solid fa-users"></i> Lớp: 10A1 &nbsp;|&nbsp;
            <i class="fa-solid fa-user-graduate"></i> Sĩ số: @Students.Count
        </div>
    </div>

    @* --- TABLE CONTAINER --- *@
    <div class="table-container">
        <table class="excel-table">
            <thead>
                <tr>
                    <th rowspan="2" class="sticky-col col-stt z-corner text-center">STT</th>
                    <th rowspan="2" class="sticky-col col-code z-corner text-center">Mã HS</th>
                    <th rowspan="2" class="sticky-col col-name z-corner text-left">Họ và tên</th>
                    <th rowspan="2" class="sticky-col col-dob z-corner text-center">Ngày sinh</th>

                    @* --- HEADER --- *@
                    @if (selectedHocKy == "1")
                    {
                        <th colspan="2" class="th-group text-center">HỌC KỲ I</th>
                    }
                    else
                    {
                        <th colspan="2" class="th-group text-center text-muted-header">HỌC KỲ I</th>
                        <th colspan="2" class="th-group text-center">HỌC KỲ II</th>
                        <th colspan="2" class="th-group text-center text-muted-header">CẢ NĂM</th>
                    }

                    <th rowspan="2" class="text-center" style="min-width:200px">Ghi chú</th>
                </tr>
                <tr>
                    @if (selectedHocKy == "1")
                    {
                        <th class="sub-th text-center" width="80">Vắng có phép</th>
                        <th class="sub-th text-center" width="80">Vắng không phép</th>
                    }
                    else
                    {
                        <th class="sub-th text-center" width="80">Vắng có phép</th>
                        <th class="sub-th text-center" width="80">Vắng không phép</th>

                        <th class="sub-th text-center" width="80">Vắng có phép</th>
                        <th class="sub-th text-center" width="80">Vắng không phép</th>

                        <th class="sub-th text-center" width="80">Vắng có phép</th>
                        <th class="sub-th text-center" width="80">Vắng không phép</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var s in PagedStudents)
                {
                    <tr>
                        <td class="sticky-col col-stt text-center">@s.Stt</td>
                        <td class="sticky-col col-code text-center"><span class="code-tag">@s.Code</span></td>
                        <td class="sticky-col col-name font-name text-left">@s.Name</td>
                        <td class="sticky-col col-dob text-center">@s.Dob</td>

                        @if (selectedHocKy == "1")
                        {
                            <td class="td-inp">
                                <input type="number" min="0" class="seamless-input text-center" @bind="s.VangCoPhepHK1" />
                            </td>
                            <td class="td-inp">
                                <input type="number" min="0" class="seamless-input text-center" @bind="s.VangKhongPhepHK1" />
                            </td>
                        }
                        else
                        {
                            <td class="text-center td-readonly bg-gray">@s.VangCoPhepHK1</td>
                            <td class="text-center td-readonly bg-gray">@s.VangKhongPhepHK1</td>

                            <td class="td-inp">
                                <input type="number" min="0" class="seamless-input text-center" @bind="s.VangCoPhepHK2" />
                            </td>
                            <td class="td-inp">
                                <input type="number" min="0" class="seamless-input text-center" @bind="s.VangKhongPhepHK2" />
                            </td>

                            <td class="text-center td-readonly bg-gray font-weight-bold">@s.VangCoPhepCN</td>
                            <td class="text-center td-readonly bg-gray font-weight-bold">@s.VangKhongPhepCN</td>
                        }

                        <td class="td-inp">
                            <input type="text" class="seamless-input note-input" @bind="s.GhiChu" placeholder="Nhập ghi chú..." />
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* --- FOOTER --- *@
    <div class="footer-section">
        <div class="pager">
            <button disabled><i class="fa-solid fa-angle-left"></i></button>
            <span class="page-info">Trang 1 / 1</span>
            <button disabled><i class="fa-solid fa-angle-right"></i></button>
        </div>
        <div class="total-info">
            Tổng số: <b>@Students.Count</b> học sinh
        </div>
    </div>
</div>

@* ========================================= *@
@* MODAL IMPORT EXCEL                        *@
@* ========================================= *@
@if (showImportModal)
{
    <div class="modal-overlay" @onclick="CloseImportModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h5><i class="fa-solid fa-file-excel text-success"></i> Nhập dữ liệu từ Excel</h5>
                <button class="btn-close" @onclick="CloseImportModal"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="modal-body">
                <div class="alert-box info mb-3">
                    <i class="fa-solid fa-circle-info me-2"></i>
                    <div>
                        Vui lòng tải <a href="#" class="font-weight-bold">file mẫu tại đây</a> để xem cấu trúc chuẩn trước khi nhập. Hệ thống chỉ nhận định dạng <b>.xlsx</b> hoặc <b>.xls</b>.
                    </div>
                </div>

                <div class="upload-zone">
                    <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                    <p class="mb-2">Nhấn vào nút bên dưới để chọn file của bạn</p>

                    @* Blazor InputFile *@
                    <InputFile OnChange="HandleFileSelected" accept=".xlsx, .xls" class="file-input-hidden" id="excelUpload" />
                    <label for="excelUpload" class="btn-custom btn-outline">
                        <i class="fa-solid fa-folder-open"></i> Chọn file Excel
                    </label>

                    @if (!string.IsNullOrEmpty(selectedFileName))
                    {
                        <div class="file-name mt-3 text-success">
                            <i class="fa-solid fa-circle-check"></i> Đã chọn: <b>@selectedFileName</b>
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-custom btn-secondary" @onclick="CloseImportModal">Hủy bỏ</button>
                <button class="btn-custom btn-primary" @onclick="ProcessImport" disabled="@string.IsNullOrEmpty(selectedFileName)">
                    <i class="fa-solid fa-check"></i> Xác nhận nhập
                </button>
            </div>
        </div>
    </div>
}
@code {
    string selectedHocKy = "1";

    // --- BIẾN TRẠNG THÁI CHO MODAL ---
    bool showImportModal = false;
    string selectedFileName = "";

    class StudentChuyenCan
    {
        public int Stt { get; set; }
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Dob { get; set; } = "";

        public int VangCoPhepHK1 { get; set; } = 0;
        public int VangKhongPhepHK1 { get; set; } = 0;
        public int VangCoPhepHK2 { get; set; } = 0;
        public int VangKhongPhepHK2 { get; set; } = 0;

        public int VangCoPhepCN => VangCoPhepHK1 + VangCoPhepHK2;
        public int VangKhongPhepCN => VangKhongPhepHK1 + VangKhongPhepHK2;

        public string GhiChu { get; set; } = "";
    }

    List<StudentChuyenCan> Students = new() {
        new StudentChuyenCan { Stt=1, Code="HS001", Name="Nguyễn Văn A", Dob="12/05/2010", VangCoPhepHK1 = 1, VangKhongPhepHK1 = 0, VangCoPhepHK2 = 0, VangKhongPhepHK2 = 0 },
        new StudentChuyenCan { Stt=2, Code="HS002", Name="Trần Thị B", Dob="20/10/2010", VangCoPhepHK1 = 0, VangKhongPhepHK1 = 2, VangCoPhepHK2 = 1, VangKhongPhepHK2 = 0 },
        new StudentChuyenCan { Stt=3, Code="HS003", Name="Lê Văn C", Dob="01/01/2010", VangCoPhepHK1 = 0, VangKhongPhepHK1 = 0, VangCoPhepHK2 = 0, VangKhongPhepHK2 = 3 },
    };

    List<StudentChuyenCan> PagedStudents => Students;

    // --- LOGIC XỬ LÝ MODAL ---
    private void OpenImportModal()
    {
        showImportModal = true;
        selectedFileName = ""; // Reset tên file mỗi lần mở
    }

    private void CloseImportModal()
    {
        showImportModal = false;
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        // Nhận tên file khi người dùng chọn file
        var file = e.File;
        if (file != null)
        {
            selectedFileName = file.Name;
        }
    }

    private async Task ProcessImport()
    {
        // TODO: Xử lý logic đọc stream từ file Excel ở đây bằng ClosedXML / EPPlus
        // var file = ...

        // Mô phỏng thời gian chờ xử lý file
        await Task.Delay(500);

        // Sau khi import xong thì đóng modal
        CloseImportModal();

        // Cập nhật lại UI (thông báo thành công)
        Console.WriteLine("Import thành công!");
    }
}


