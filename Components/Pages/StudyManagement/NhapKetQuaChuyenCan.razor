@code {
    string selectedHocKy = "1";

    // --- BIẾN TRẠNG THÁI CHO MODAL ---
    bool showImportModal = false;
    string selectedFileName = "";

    class StudentChuyenCan
    {
        public int Stt { get; set; }
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string Dob { get; set; } = "";

        public int VangCoPhepHK1 { get; set; } = 0;
        public int VangKhongPhepHK1 { get; set; } = 0;
        public int VangCoPhepHK2 { get; set; } = 0;
        public int VangKhongPhepHK2 { get; set; } = 0;

        public int VangCoPhepCN => VangCoPhepHK1 + VangCoPhepHK2;
        public int VangKhongPhepCN => VangKhongPhepHK1 + VangKhongPhepHK2;

        public string GhiChu { get; set; } = "";
