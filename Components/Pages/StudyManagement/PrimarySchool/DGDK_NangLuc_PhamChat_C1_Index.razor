@page "/learning/ratingtalent"

<div class="point-page score-grade-page score-grade-page--talent">
    <div class="page-title">
        <div class="icon-title"><i class="fa-solid fa-user-graduate"></i></div>
        <h4>ĐÁNH GIÁ ĐỊNH KỲ NĂNG LỰC PHẨM CHẤT</h4>
    </div>

    @* --- BỘ LỌC CỐ ĐỊNH --- *@
    <div class="filter-bar">
        <div class="group">
            <label>Năm học:</label>
            <select class="select-highlight" @bind="SelectedNamHoc">
                <option value="2025-2026">2025-2026</option>
                <option value="2024-2025">2024-2025</option>
            </select>
        </div>
        <div class="group">
            <label>Học kỳ:</label>
            <select class="select-highlight" @bind="SelectedHocKy">
                <option value="1">Học kỳ 1</option>
                <option value="2">Học kỳ 2</option>
            </select>
        </div>
        <div class="group">
            <label>Khối:</label>
            <select class="select-highlight" @bind="SelectedKhoi">
                @for (int i = 1; i <= 5; i++)
                {
                    <option value="Khối @i">Khối @i</option>
                }
            </select>
        </div>
        <div class="group">
            <label>Lớp:</label>
            <select class="select-highlight" @bind="SelectedLop">
                <option value="1/1">1/1</option>
                <option value="4A1">4A1</option>
            </select>
        </div>
        <div class="actions-group" style="display:flex; gap:0.75rem">
            <button class="btn-custom @(CurrentView == "GK" ? "btn-primary" : "btn-outline")" @onclick='() => SwitchView("GK")'>Giữa kỳ (GK)</button>
            <button class="btn-custom @(CurrentView == "CK" ? "btn-primary" : "btn-outline") ms-2" @onclick='() => SwitchView("CK")'>Cuối kỳ (CK)</button>
        </div>
        <div class="actions-group ms-auto">
            <button class="btn-custom btn-primary" @onclick="LoadData"><i class="fa-solid fa-search me-1"></i> Tìm kiếm</button>
        </div>
    </div>

    @* --- VÙNG NỘI DUNG --- *@
    <div class="content-area-wrapper">
        @if (CurrentView == "GK")
        {
            <DGDK_NangLuc_PhamChat_GKView SelectedNamHoc="@SelectedNamHoc" SelectedKhoi="@SelectedKhoi" SelectedLop="@SelectedLop" SelectedHocKy="@SelectedHocKy" IsLoading="@isLoading" />
        }
        else
        {
            <DGDK_NangLuc_PhamChat_CKView SelectedNamHoc="@SelectedNamHoc" SelectedKhoi="@SelectedKhoi" SelectedLop="@SelectedLop" SelectedHocKy="@SelectedHocKy" IsLoading="@isLoading" />
        }
    </div>
</div>

@code {
    private bool isLoading = false;
    private string SelectedNamHoc = "2025-2026";
    private string SelectedHocKy = "1";
    private string SelectedKhoi = "Khối 1";
    private string SelectedLop = "1/1";
    private string CurrentView = "GK";

    private async Task LoadData() { isLoading = true; await Task.Delay(300); isLoading = false; }
    private void SwitchView(string v) => CurrentView = v;
}


