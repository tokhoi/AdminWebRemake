        width: 100%;
        border: none;
        text-align: center;
        background: transparent;
    }

    .inp-nd {
        width: 100%;
        border: none;
        min-height: 32px;
        padding: 4px;
        font-size: 11px;
        resize: both;
        display: block;
        background: transparent;
        line-height: 1.4;
    }

    .col-v {
        width: 55px;
    }

    .col-m {
        width: 45px;
    }

    .col-nd {
        width: 180px;
    }

    .modal-backdrop-custom {
        position: fixed;
        top: 0;
        left: 0;
