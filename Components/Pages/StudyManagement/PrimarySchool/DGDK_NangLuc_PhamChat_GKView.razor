<div class="view-container">
    <div class="class-info-bar">
        <span><i class="fa-solid fa-list me-2"></i> KẾT QUẢ ĐÁNH GIÁ NĂNG LỰC & PHẨM CHẤT GIỮA KỲ</span>
        <span class="ms-auto text-muted">@SelectedKhoi - Lớp: @SelectedLop - Học kỳ: @SelectedHocKy</span>
        <div class="action-bar" style="display: flex; padding-left: 0.325rem; padding-right:0.325rem; gap: 0.75rem;">
            <button class="btn-tool btn-excel" @onclick="() => showDownloadModal = true">
                <i class="fa-solid fa-file-excel me-1"></i> Tải file mẫu
            </button>

            <button class="btn-tool btn-upload" @onclick="() => showUploadModal = true">
                <i class="fa-solid fa-upload me-1"></i> Tải file điểm
            </button>

            <button class="btn-tool btn-print" @onclick="() => showPrintModal = true">
                <i class="fa-solid fa-print me-1"></i> In báo cáo
            </button>
            <div class="lock-toggle ms-3">
                <div class="form-check form-switch mb-0">
                    <input class="form-check-input" type="checkbox" role="switch" id="lockGK" @bind="isLocked" />
                    <label class="form-check-label fw-bold ms-1" for="lockGK">Khóa sổ điểm</label>
                </div>
            </div>
            <button class="btn-tool btn-submit ms-auto" @onclick="() => showSubmitModal = true">
                <i class="fa-solid fa-paper-plane me-1"></i> Nộp điểm lên Sở
            </button>
        </div>
    </div>

    @if (isLocked)
    {
        <div class="lock-banner"><i class="fa-solid fa-lock me-2"></i> Sổ điểm đã được khóa - Chế độ chỉ xem dữ liệu.</div>
    }

    <div class="toolbar-actions">
        
        @if (!isLocked)
        {
            <div class="quick-fill-panel">
                <div class="q-group">NL Chung: <button @onclick='() => Fill("NLC", "T")'>T</button><button @onclick='() => Fill("NLC", "Đ")'>Đ</button><button @onclick='() => Fill("NLC", "C")'>C</button></div>
                <div class="q-group">NL Đặc thù: <button @onclick='() => Fill("NLD", "T")'>T</button><button @onclick='() => Fill("NLD", "Đ")'>Đ</button><button @onclick='() => Fill("NLD", "C")'>C</button></div>
                <div class="q-group">Phẩm chất: <button @onclick='() => Fill("PC", "T")'>T</button><button @onclick='() => Fill("PC", "Đ")'>Đ</button><button @onclick='() => Fill("PC", "C")'>C</button></div>
            </div>
        }
    </div>

    <div class="table-scroll-area">
        <table class="excel-table">
            <thead>
                <tr>
                    <th rowspan="3" class="sticky-col col-stt z-corner r1">STT</th>
                    <th rowspan="3" class="sticky-col col-name z-corner r1">HỌ TÊN</th>
                    <th rowspan="3" class="sticky-col col-dob z-corner r1">NGÀY SINH</th>
                    <th colspan="8" class="h-main r1">NĂNG LỰC CỐT LÕI</th>
                    <th colspan="5" class="h-main r1">PHẨM CHẤT CHỦ YẾU</th>
                    <th colspan="2" class="h-main r1">NX NĂNG LỰC CHUNG</th>
                    <th colspan="2" class="h-main r1">NX NĂNG LỰC ĐẶC THÙ</th>
                    <th colspan="2" class="h-main r1">NX PHẨM CHẤT</th>
                </tr>
                <tr>
                    <th colspan="3" class="h-sub r2">NL CHUNG</th>
                    <th colspan="5" class="h-sub r2">NL ĐẶC THÙ</th>
                    <th colspan="5" class="h-sub r2">PHẨM CHẤT</th>
                    <th rowspan="2" class="h-sub r2 col-m">MÃ</th>
                    <th rowspan="2" class="h-sub r2 col-nd">NỘI DUNG</th>
                    <th rowspan="2" class="h-sub r2 col-m">MÃ</th>
                    <th rowspan="2" class="h-sub r2 col-nd">NỘI DUNG</th>
                    <th rowspan="2" class="h-sub r2 col-m">MÃ</th>
                    <th rowspan="2" class="h-sub r2 col-nd">NỘI DUNG</th>
                </tr>
                <tr class="h-sub">
                    <th class="sticky-col col-v r3">TỰ CHỦ - TỰ HỌC</th>
                    <th class="sticky-col col-v r3">GIAO TIẾP - HỢP TÁC</th>
                    <th class="sticky-col col-v r3">GIẢI QUYẾT VẤN ĐỀ VÀ SÁNG TẠO</th>
                    <th class="sticky-col col-v r3">NGÔN NGỮ</th>
                    <th class="sticky-col col-v r3">TÍNH TOÁN</th>
                    <th class="sticky-col col-v r3">KHOA HỌC</th>
                    <th class="sticky-col col-v r3">THẨM MĨ</th>
                    <th class="sticky-col col-v r3">THỂ CHẤT</th>
                    <th class="sticky-col col-v r3">YÊU NƯỚC</th>
                    <th class="sticky-col col-v r3">NHÂN ÁI</th>
                    <th class="sticky-col col-v r3">CHĂM CHỈ</th>
                    <th class="sticky-col col-v r3">TRUNG THỰC</th>
                    <th class="sticky-col col-v r3">TRÁCH NHIỆM</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var hs in listHs)
                {
                    var d = GetD(hs.Ma);
                    <tr class="@(isLocked ? "row-locked" : "")">
                        <td class="sticky-col col-stt text-center">@(listHs.IndexOf(hs) + 1)</td>
                        <td class="sticky-col col-name">@hs.Ten</td>
                        <td class="sticky-col col-dob text-center">@hs.Ns.ToString("dd/MM/yyyy")</td>
                        @RSelect(d, "Nl1") @RSelect(d, "Nl2") @RSelect(d, "Nl3")
                        @RSelect(d, "Nd1") @RSelect(d, "Nd2") @RSelect(d, "Nd3") @RSelect(d, "Nd4") @RSelect(d, "Nd5")
                        @RSelect(d, "Pc1") @RSelect(d, "Pc2") @RSelect(d, "Pc3") @RSelect(d, "Pc4") @RSelect(d, "Pc5")
                        <td><input class="inp-m" @bind="d.M1" disabled="@isLocked"></td>
                        <td><textarea class="inp-nd" @bind="d.N1" disabled="@isLocked"></textarea></td>
                        <td><input class="inp-m" @bind="d.M2" disabled="@isLocked"></td>
                        <td><textarea class="inp-nd" @bind="d.N2" disabled="@isLocked"></textarea></td>
                        <td><input class="inp-m" @bind="d.M3" disabled="@isLocked"></td>
                        <td><textarea class="inp-nd" @bind="d.N3" disabled="@isLocked"></textarea></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* --- 1. MODAL TẢI FILE MẪU --- *@
@if (showDownloadModal)
{
    <div class="modal-backdrop-custom show" @onclick="() => showDownloadModal = false">
        <div class="modal-content-custom" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <h5 class="modal-title-custom"><i class="fa-solid fa-file-excel me-2"></i>Tải file mẫu Excel</h5>
                <button class="btn-close-custom" @onclick="() => showDownloadModal = false"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body-custom text-center py-4">
                <i class="fa-solid fa-file-arrow-down mb-3 text-success" style="font-size: 50px;"></i>
                <p>Hệ thống sẽ xuất file Excel danh sách học sinh lớp <strong>@SelectedLop</strong>.</p>
                <p class="text-muted small">Bạn có thể dùng file này để nhập điểm offline và tải lên sau.</p>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-custom btn-secondary-custom" @onclick="() => showDownloadModal = false">Hủy bỏ</button>
                <button class="btn-custom btn-excel" @onclick="() => showDownloadModal = false">Tải về ngay</button>
            </div>
        </div>
    </div>
}

@* --- 2. MODAL TẢI FILE ĐIỂM --- *@

@if (showUploadModal)
{
    <div class="modal-backdrop-custom show" @onclick="() => showUploadModal = false">
        <div class="modal-content-custom" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <h5 class="modal-title-custom"><i class="fa-solid fa-upload me-2"></i>Tải lên file điểm</h5>
                <button class="btn-close-custom" @onclick="() => showUploadModal = false"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body-custom">
                <div class="upload-zone">
                    <i class="fa-solid fa-cloud-arrow-up upload-icon"></i>
                    <h6>Kéo thả file vào đây hoặc Click để chọn file</h6>
                    <p class="text-muted mb-0 small">Hỗ trợ định dạng: .xls, .xlsx</p>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-custom btn-secondary-custom" @onclick="() => showUploadModal = false">Đóng</button>
                <button class="btn-custom btn-upload" @onclick="() => showUploadModal = false">Xác nhận tải lên</button>
            </div>
        </div>
    </div>
}

@* --- 3. MODAL IN BÁO CÁO --- *@

@if (showPrintModal)
{
    <div class="modal-backdrop-custom show" @onclick="() => showPrintModal = false">
        <div class="modal-content-custom" @onclick:stopPropagation>
            <div class="modal-header-custom">
                <h5 class="modal-title-custom"><i class="fa-solid fa-print me-2"></i>Tùy chọn in báo cáo</h5>
                <button class="btn-close-custom" @onclick="() => showPrintModal = false"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body-custom">
                <div class="mb-3">
                    <label class="fw-bold mb-2">Chọn mẫu in:</label>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="printOption" id="p1" checked>
                        <label class="form-check-label" for="p1">Bảng tổng hợp kết quả đánh giá (Thông tư 27)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="printOption" id="p2">
                        <label class="form-check-label" for="p2">Danh sách khen thưởng dự kiến</label>
                    </div>
                </div>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-custom btn-secondary-custom" @onclick="() => showPrintModal = false">Đóng</button>
                <button class="btn-custom btn-primary" @onclick="() => showPrintModal = false"><i class="fa-solid fa-print me-1"></i>Thực hiện in</button>
            </div>
        </div>
    </div>
}

@* --- 4. MODAL NỘP ĐIỂM --- *@

@if (showSubmitModal)
{
    <div class="modal-backdrop-custom show" @onclick="() => showSubmitModal = false">
        <div class="modal-content-custom modal-sm-custom" @onclick:stopPropagation>
            <div class="modal-header-custom bg-warning text-white">
                <h5 class="modal-title-custom text-white"><i class="fa-solid fa-triangle-exclamation me-2"></i>Xác nhận nộp điểm</h5>
                <button class="btn-close-custom text-white" @onclick="() => showSubmitModal = false"><i class="fa-solid fa-times"></i></button>
            </div>
            <div class="modal-body-custom py-4 text-center">
                <p>Bạn có chắc chắn muốn <strong>nộp điểm lên Sở</strong> không?</p>
                <p class="text-danger small"><i class="fa-solid fa-circle-info me-1"></i>Sau khi nộp, sổ điểm sẽ tự động bị khóa và không thể chỉnh sửa.</p>
            </div>
            <div class="modal-footer-custom">
                <button class="btn-custom btn-secondary-custom" @onclick="() => showSubmitModal = false">Hủy</button>
                <button class="btn-custom btn-submit" @onclick="ConfirmSubmit">Xác nhận nộp</button>
            </div>
        </div>
    </div>
}


@code {
    [Parameter] public string SelectedNamHoc { get; set; }
    [Parameter] public string SelectedKhoi { get; set; }
    [Parameter] public string SelectedLop { get; set; }
    [Parameter] public string SelectedHocKy { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    private bool showDownloadModal = false;
    private bool showUploadModal = false;
    private bool showPrintModal = false;
    private bool showSubmitModal = false;
    private void ConfirmSubmit()
    {
        showSubmitModal = false;
        isLocked = true;
    }

    private bool isLocked = false;
    private List<Hs> listHs = new();
    private Dictionary<string, Data> cache = new();

    protected override void OnInitialized()
    {
        for (int i = 1; i <= 30; i++) listHs.Add(new Hs { Ma = $"H{i}", Ten = $"Học sinh {i}", Ns = new DateTime(2019, 9, 29) });
    }

    private void Fill(string t, string v)
    {
        if (isLocked) return;
        foreach (var h in listHs)
        {
            var d = GetD(h.Ma);
            // Gán trực tiếp vào Property
            if (t == "NLC") { d.Nl1 = d.Nl2 = d.Nl3 = v; }
            else if (t == "NLD") { d.Nd1 = d.Nd2 = d.Nd3 = d.Nd4 = d.Nd5 = v; }
            else { d.Pc1 = d.Pc2 = d.Pc3 = d.Pc4 = d.Pc5 = v; }
        }
        StateHasChanged(); // Ép UI cập nhật sau khi Fill
    }

    private RenderFragment RSelect(Data d, string p) => __builder =>
    {
        <td>
            <select class="cell-s" @onchange='(e) => Set(d, p, e.Value?.ToString())' value="@Get(d, p)" disabled="@isLocked">
                <option value=""></option>
                <option value="T">T</option>
                <option value="Đ">Đ</option>
                <option value="C">C</option>
            </select>
        </td>
    };

    private Data GetD(string id) => cache.TryGetValue(id, out var v) ? v : (cache[id] = new Data { Ma = id });

    // Cần sử dụng PropertyInfo thay vì FieldInfo
    private void Set(Data d, string p, string v) => d.GetType().GetProperty(p)?.SetValue(d, v);
    private string Get(Data d, string p) => d.GetType().GetProperty(p)?.GetValue(d)?.ToString() ?? "";

    public class Hs { public string Ma, Ten; public DateTime Ns; }

    // QUAN TRỌNG: Đổi sang PROPERTY { get; set; } để Reflection hoạt động
    public class Data
    {
        public string Ma { get; set; }
        public string Nl1 { get; set; }
        public string Nl2 { get; set; }
        public string Nl3 { get; set; }
        public string Nd1 { get; set; }
        public string Nd2 { get; set; }
        public string Nd3 { get; set; }
        public string Nd4 { get; set; }
        public string Nd5 { get; set; }
        public string Pc1 { get; set; }
        public string Pc2 { get; set; }
        public string Pc3 { get; set; }
        public string Pc4 { get; set; }
        public string Pc5 { get; set; }
        public string M1 { get; set; }
        public string N1 { get; set; }
        public string M2 { get; set; }
        public string N2 { get; set; }
        public string M3 { get; set; }
        public string N3 { get; set; }
    }
}

<style>
    .view-container {
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
    }

    .class-info-bar {
        display: flex;
        align-items: center;
        padding: 10px;
        background: #eef7ff;
        color: #1e3c72;
        font-weight: 700;
        border: 1px solid #b3d7ff;
        border-radius: 4px;
        flex-shrink: 0;
        margin-bottom: 5px;
    }

    .lock-banner {
        background: #fff3cd;
        color: #856404;
        padding: 8px 12px;
        border: 1px solid #ffeeba;
        border-radius: 4px;
        margin-bottom: 8px;
        flex-shrink: 0;
        font-size: 13px;
    }

    .toolbar-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 10px;
        flex-shrink: 0;
    }

    .btn-tool {
        padding: 4px 12px;
        border-radius: 4px;
        border: 1px solid #ddd;
        background: white;
        font-weight: 600;
        font-size: 12px;
        cursor: pointer;
    }

    .btn-excel {
        background: #198754;
        color: white;
        border: none;
    }

        .btn-excel:hover {
            background: #21b772;
            color: white;
            border: none;
        }

    .btn-upload {
        background: #20558a;
        color: white;
        border: none;
    }

        .btn-upload:hover {
            background: #0b5ed7;
            color: white;
            border: none;
        }


    .btn-print {
        background: #6c757d;
        color: white;
        border: none;
    }

        .btn-print:hover {
            background: #fff;
            color: #6c757d;
            border-color: #6c757d;
        }

    .btn-submit {
        background: #fd7e14;
        color: white;
        border: none;
    }

    .quick-fill-panel {
        display: flex;
        gap: 15px;
        background: #f8f9fa;
        padding: 6px 15px;
        border-radius: 20px;
        border: 1px solid #ddd;
        width: fit-content;
    }

    .q-group {
        display: flex;
        gap: 3px;
        align-items: center;
        font-weight: 700;
        font-size: 11px;
    }

        .q-group button {
            width: 22px;
            height: 22px;
            border: 1px solid #ccc;
            background: white;
            cursor: pointer;
            border-radius: 3px;
            font-weight: 700;
        }

    .table-scroll-area {
        flex: 1;
        overflow: auto;
        border: 1px solid #ccc;
        background: white;
        border-radius: 4px;
        position: relative;
    }

    .excel-table {
        border-collapse: separate;
        border-spacing: 0;
        width: max-content;
        min-width: 100%;
    }

        .excel-table th, .excel-table td {
            border-right: 1px solid #ddd;
            border-bottom: 1px solid #ddd;
            vertical-align: middle;
            height: 32px;
            font-size: 12px;
        }

    /* STICKY HEADER MỚI */
    .h-main, .h-sub {
        position: sticky;
        z-index: 10;
        color: white;
        text-align: center;
    }

    .r1 {
        top: 0;
        background: #1e3c72 !important;
        height: 32px;
    }

    .r2 {
        top: 32px;
        background: #2c5ea9 !important;
        height: 32px;
    }

    .r3 {
        top: 64px;
        background: #2c5ea9 !important;
        height: 32px;
    }

    /* STICKY COLUMNS */
    .sticky-col {
        position: sticky;
        background: white;
        z-index: 5;
    }

    .col-stt {
        left: 0;
        width: 40px;
    }

