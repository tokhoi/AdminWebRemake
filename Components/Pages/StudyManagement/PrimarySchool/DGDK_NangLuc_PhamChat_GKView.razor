        max-width: 95%;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
        display: flex;
        flex-direction: column;
        animation: slideDown 0.3s ease;
        overflow: hidden;
    }

    .modal-sm-custom {
        width: 400px;
    }

    .modal-header-custom {
        padding: 12px 20px;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8f9fa;
    }

    .modal-title-custom {
        margin: 0;
        font-size: 15px;
        font-weight: 700;
        color: #1e3c72;
    }

    .modal-body-custom {
        padding: 20px;
        font-size: 14px;
    }

    .modal-footer-custom {
        padding: 12px 20px;
        border-top: 1px solid #ddd;
        background: #f8f9fa;
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    .btn-secondary-custom {
        background: #6c757d;
        color: white;
    }

    @* CSS Animation *@
    @@keyframes fadeIn {
        from

    {
        opacity: 0;
    }

    to {
        opacity: 1;
    }

    }

    @@keyframes slideDown {
        from {
            transform: translateY(-20px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }
</style>