            @* ================= HÀNG 2 ================= *@

            @* 2. KHỐI ĐIỂM DANH (Bên Trái) *@
            <div class="tk-card tk-attendance-section tk-grid-col-left tk-card-flex">
                <div class="tk-card-header">
                    <div>
                        <h3 class="tk-section-title">
                            <span class="tk-title-indicator"></span> Tình hình Điểm danh
                        </h3>
                        <p class="tk-section-subtitle">@DateTime.Now.ToString("dddd, dd/MM/yyyy", new CultureInfo("vi-VN"))</p>
                    </div>
                    <div class="tk-header-actions">
                        <button class="tk-btn-icon tk-btn-blue" @onclick="RefreshData" title="Làm mới số liệu ngẫu nhiên">
                            <span class="material-symbols-outlined">sync</span>
                        </button>
                        <button class="tk-btn-icon tk-btn-blue" @onclick="OpenCalendarModal" title="Chọn ngày">
                            <span class="material-symbols-outlined">calendar_month</span>
                        </button>
                    </div>
                </div>
                <div class="tk-attendance-grid">
                    @* Cột Buổi sáng *@
                    <div class="tk-att-col">
                        <div class="tk-bg-icon"><span class="material-symbols-outlined">wb_sunny</span></div>
                        <div class="tk-att-content">
                            <div class="tk-att-header">
                                <div class="tk-icon-circle tk-icon-orange"><span class="material-symbols-outlined">wb_sunny</span></div>
                                <div>
                                    <h4 class="tk-att-title">Buổi Sáng</h4>
                                    <span class="tk-badge tk-badge-green">Đã chốt sổ</span>
                                </div>
                            </div>

                            <div class="tk-progress-group">
                                <div class="tk-progress-header">
                                    <div class="tk-progress-label"><span class="material-symbols-outlined">groups</span> Học sinh</div>
                                    <div class="tk-progress-percent">@MorningStudentPercent%</div>
                                </div>
                                <div class="tk-progress-bar">
                                    <div class="tk-progress-fill tk-fill-green" style="width: @GetCssWidth(MorningStudentPercent); transition: width 0.8s ease-in-out;"></div>
                                </div>
                                <div class="tk-progress-stats">
                                    <span>Có mặt: <b>@MorningPresentStudents.ToString("N0")</b>/@TotalStudents.ToString("N0")</span>
                                    <span>Vắng: <b class="tk-text-red">@MorningAbsentStudents.ToString("N0")</b></span>
                                </div>
                            </div>

                            <div class="tk-progress-group">
                                <div class="tk-progress-header">
                                    <div class="tk-progress-label"><span class="material-symbols-outlined">person_apron</span> Giáo viên</div>
                                    <div class="tk-progress-percent">@MorningTeacherPercent%</div>
                                </div>
                                <div class="tk-progress-bar">
                                    <div class="tk-progress-fill tk-fill-blue" style="width: @GetCssWidth(MorningTeacherPercent); transition: width 0.8s ease-in-out;"></div>
                                </div>
                                <div class="tk-progress-stats">
                                    <span>Có mặt: <b>@MorningPresentTeachers</b>/@TotalTeachers</span>
                                    <span>Vắng: <b class="tk-text-red">@MorningAbsentTeachers</b></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Cột Buổi chiều *@
                    <div class="tk-att-col @(IsAfternoonStarted ? "" : "tk-bg-gray")">
                        <div class="tk-bg-icon"><span class="material-symbols-outlined">nights_stay</span></div>
                        <div class="tk-att-content @(IsAfternoonStarted ? "" : "tk-opacity-70")">
                            <div class="tk-att-header">
                                <div class="tk-icon-circle tk-icon-indigo"><span class="material-symbols-outlined">partly_cloudy_day</span></div>
                                <div>
                                    <h4 class="tk-att-title">Buổi Chiều</h4>
                                    @if (IsAfternoonStarted)
                                    {
                                        <span class="tk-badge tk-badge-green" style="background-color: var(--tk-primary-light); color: var(--tk-primary);">Đang diễn ra</span>
                                    }
                                    else
                                    {
                                        <span class="tk-badge tk-badge-gray">Chưa bắt đầu</span>
                                    }
                                </div>
                            </div>

                            <div class="tk-progress-group">
                                <div class="tk-progress-header">
                                    <div class="tk-progress-label"><span class="material-symbols-outlined">groups</span> Học sinh</div>
                                    <div class="tk-progress-percent @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                        @(IsAfternoonStarted ? $"{AfternoonStudentPercent}%" : "--%")
                                    </div>
                                </div>
                                <div class="tk-progress-bar">
                                    <div class="tk-progress-fill @(IsAfternoonStarted ? "tk-fill-green" : "tk-fill-gray")" style="width: @(IsAfternoonStarted? GetCssWidth(AfternoonStudentPercent) : "0%"); transition: width 0.8s ease-in-out;"></div>
                                </div>
                                <div class="tk-progress-stats @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                    @if (IsAfternoonStarted)
                                    {
                                        <span>Có mặt: <b>@AfternoonPresentStudents.ToString("N0")</b>/@TotalStudents.ToString("N0")</span>
                                        <span>Vắng: <b class="tk-text-red">@AfternoonAbsentStudents.ToString("N0")</b></span>
                                    }
                                    else
                                    {
                                        <span>Dự kiến: <b>@TotalStudents.ToString("N0")</b></span>
                                        <span>---</span>
                                    }
                                </div>
                            </div>

                            <div class="tk-progress-group">
                                <div class="tk-progress-header">
                                    <div class="tk-progress-label"><span class="material-symbols-outlined">person_apron</span> Giáo viên</div>
                                    <div class="tk-progress-percent @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                        @(IsAfternoonStarted ? $"{AfternoonTeacherPercent}%" : "--%")
                                    </div>
                                </div>
                                <div class="tk-progress-bar">
                                    <div class="tk-progress-fill @(IsAfternoonStarted ? "tk-fill-blue" : "tk-fill-gray")" style="width: @(IsAfternoonStarted? GetCssWidth(AfternoonTeacherPercent) : "0%"); transition: width 0.8s ease-in-out;"></div>
                                </div>
                                <div class="tk-progress-stats @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                    @if (IsAfternoonStarted)
                                    {
                                        <span>Có mặt: <b>@AfternoonPresentTeachers</b>/@TotalTeachers</span>
                                        <span>Vắng: <b class="tk-text-red">@AfternoonAbsentTeachers</b></span>
                                    }
                                    else
                                    {
                                        <span>Dự kiến: <b>@TotalTeachers</b></span>
                                        <span>---</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* PHÍM TẮT (Bên Phải) *@
            <div class="tk-card tk-grid-col-right tk-card-flex">
                <div class="tk-card-header tk-border-bottom">
                    <h3 class="tk-section-title tk-text-md">
                        <span class="material-symbols-outlined tk-text-blue" style="margin-right: 4px;">bolt</span> Phím tắt nhanh
                    </h3>
                </div>
                <div class="tk-card-body tk-card-body-center" style="padding: 1rem;">
                    <div class="tk-shortcuts-grid">
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-blue"><span class="material-symbols-outlined">person_add</span></div>
                            <span class="tk-shortcut-text">Thêm học sinh</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-green"><span class="material-symbols-outlined">send</span></div>
                            <span class="tk-shortcut-text">Gửi thông báo</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-purple"><span class="material-symbols-outlined">calendar_month</span></div>
                            <span class="tk-shortcut-text">Xem lịch học</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-orange"><span class="material-symbols-outlined">restaurant_menu</span></div>
                            <span class="tk-shortcut-text">Thực đơn</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-red">
                                <span class="material-symbols-outlined">
                                    assignment
                                </span>
                            </div>
                            <span class="tk-shortcut-text">Đơn nghỉ phép</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-gray"><span class="material-symbols-outlined">more_horiz</span></div>
                            <span class="tk-shortcut-text">Khác</span>
                        </a>
                    </div>
                </div>
            </div>

            @* ================= HÀNG 3 ================= *@

            @* KHỐI TIN TỨC SỞ GIÁO DỤC (Bên Trái) *@
            <div class="tk-card tk-grid-col-full tk-card-flex">
                <div class="tk-card-header tk-border-bottom">
                    <h3 class="tk-section-title">
                        <span class="tk-title-indicator"></span> Tin tức Sở Giáo dục & Đào tạo
                    </h3>
                    <a class="tk-link-blue">Xem tất cả</a>
                </div>
                <div class="tk-news-list">
                    @* Card 1 *@
                    <div class="tk-news-card">
                        <div class="tk-news-image">
                            <img src="https://picsum.photos/seed/school1/400/200" alt="Thumbnail" />
                        </div>
                        <div class="tk-news-info">
                            <h4 class="tk-news-title">Hướng dẫn thực hiện nhiệm vụ giáo dục Tiểu học năm học 2026-2027</h4>
                            <span class="tk-news-meta">Sở GD&ĐT • 05/03/2026</span>
                        </div>
                    </div>

                    @* Card 2 *@
                    <div class="tk-news-card">
                        <div class="tk-news-image">
                            <img src="https://picsum.photos/seed/school2/400/200" alt="Thumbnail" />
                        </div>
                        <div class="tk-news-info">
                            <h4 class="tk-news-title">Kế hoạch tổ chức Hội thi Giáo viên dạy giỏi cấp Thành phố</h4>
                            <span class="tk-news-meta">Sở GD&ĐT • 02/03/2026</span>
                        </div>
                    </div>

                    @* Card 3 *@
                    <div class="tk-news-card">
                        <div class="tk-news-image">
                            <img src="https://picsum.photos/seed/school3/400/200" alt="Thumbnail" />
                        </div>
                        <div class="tk-news-info">
                            <h4 class="tk-news-title">Công văn về việc tăng cường công tác đảm bảo an toàn thực phẩm trong trường học</h4>
                            <span class="tk-news-meta">Bộ GD&ĐT • 28/02/2026</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@* =================== MODAL LỊCH ================= *@
@if (IsCalendarModalOpen)
{
    <div class="tk-modal-backdrop" @onclick="CloseCalendarModal">
        <div class="tk-modal-container" @onclick:stopPropagation="true">
            <div class="tk-modal-header">
                <h3 class="tk-modal-title">Chọn ngày</h3>
                <button class="tk-modal-close" @onclick="CloseCalendarModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="tk-modal-body">
                <div class="tk-calendar-card tk-calendar-in-modal">
                    <div class="tk-calendar-header">
                        <div class="tk-cal-nav-row">
                            <h3 class="tk-cal-month">Tháng @CurrentDisplayDate.Month, @CurrentDisplayDate.Year</h3>
                            <div class="tk-cal-actions">
                                <button class="tk-cal-btn" @onclick="PrevMonth"><span class="material-symbols-outlined">chevron_left</span></button>
                                <button class="tk-cal-btn" @onclick="NextMonth"><span class="material-symbols-outlined">chevron_right</span></button>
                            </div>
                        </div>
                        <div class="tk-cal-grid tk-cal-weekdays">
                            <span>CN</span><span>T2</span><span>T3</span><span>T4</span><span>T5</span><span>T6</span><span>T7</span>
                        </div>
                        <div class="tk-cal-grid tk-cal-days">
                            @foreach (var d in CalendarDays)
                            {
                                bool isCurrentMonth = d.Month == CurrentDisplayDate.Month;
                                bool isSelected = d.Date == SelectedDate.Date;
                                bool hasEvent = d.Day % 5 == 0 && isCurrentMonth;

                                if (!isCurrentMonth)
                                {
                                    <span class="tk-cal-day tk-fade">@d.Day</span>
                                }
                                else if (isSelected)
                                {
                                    <span class="tk-cal-day tk-selected" @onclick="() => SelectDate(d)">@d.Day</span>
                                }
                                else
                                {
                                    <span class="tk-cal-day tk-normal" @onclick="() => SelectDate(d)">
                                        @d.Day
                                        @if (hasEvent)
                                        {
                                            <div class="tk-cal-dot"></div>
                                        }
                                    </span>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // === DỮ LIỆU ĐỘNG CHO DASHBOARD ===
    private int TotalStudents = 1500;
    private int TotalTeachers = 84;

    // Dữ liệu buổi sáng
    private int MorningPresentStudents = 1325;
    private int MorningAbsentStudents => TotalStudents - MorningPresentStudents;
    private double MorningStudentPercent => TotalStudents == 0 ? 0 : Math.Round((double)MorningPresentStudents / TotalStudents * 100, 1);

    private int MorningPresentTeachers = 82;
    private int MorningAbsentTeachers => TotalTeachers - MorningPresentTeachers;
    private double MorningTeacherPercent => TotalTeachers == 0 ? 0 : Math.Round((double)MorningPresentTeachers / TotalTeachers * 100, 1);

    // Dữ liệu buổi chiều
    private bool IsAfternoonStarted = false;
    private int AfternoonPresentStudents = 0;
    private int AfternoonAbsentStudents => TotalStudents - AfternoonPresentStudents;
    private double AfternoonStudentPercent => TotalStudents == 0 ? 0 : Math.Round((double)AfternoonPresentStudents / TotalStudents * 100, 1);

    private int AfternoonPresentTeachers = 0;
    private int AfternoonAbsentTeachers => TotalTeachers - AfternoonPresentTeachers;
    private double AfternoonTeacherPercent => TotalTeachers == 0 ? 0 : Math.Round((double)AfternoonPresentTeachers / TotalTeachers * 100, 1);

    // Trình trợ giúp chuyển % sang CSS an toàn 
    private string GetCssWidth(double percent) => $"{percent.ToString("0.0", CultureInfo.InvariantCulture)}%";

    // Cập nhật số liệu để test UI hoạt động
    private void RefreshData()
    {
        var rnd = new Random();

        // Random số liệu sáng
        MorningPresentStudents = rnd.Next(1000, TotalStudents);
        MorningPresentTeachers = rnd.Next(60, TotalTeachers);

        // Kích hoạt buổi chiều và random số liệu
        IsAfternoonStarted = true;
        AfternoonPresentStudents = rnd.Next(1000, TotalStudents);
        AfternoonPresentTeachers = rnd.Next(60, TotalTeachers);
    }

    // === LOGIC LỊCH ===
    private bool IsCalendarModalOpen = false;
    private void OpenCalendarModal() => IsCalendarModalOpen = true;
    private void CloseCalendarModal() => IsCalendarModalOpen = false;

    private DateTime SelectedDate = DateTime.Today;
    private DateTime CurrentDisplayDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private List<DateTime> CalendarDays = new List<DateTime>();

    protected override void OnInitialized()
    {
        GenerateCalendar();
    }

    private void GenerateCalendar()
    {
        CalendarDays.Clear();
        var startOfMonth = new DateTime(CurrentDisplayDate.Year, CurrentDisplayDate.Month, 1);
        int daysToSubtract = (int)startOfMonth.DayOfWeek;
        var startDate = startOfMonth.AddDays(-daysToSubtract);

        for (int i = 0; i < 42; i++)
        {
            CalendarDays.Add(startDate.AddDays(i));
        }
    }

    private void PrevMonth()
    {
        CurrentDisplayDate = CurrentDisplayDate.AddMonths(-1);
        GenerateCalendar();
    }

    private void NextMonth()
    {
        CurrentDisplayDate = CurrentDisplayDate.AddMonths(1);
        GenerateCalendar();
    }

    private void SelectDate(DateTime date)
    {
        SelectedDate = date;
    }
}

