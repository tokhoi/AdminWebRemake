                        <div class="tk-bg-icon"><span class="material-symbols-outlined">nights_stay</span></div>
                        <div class="tk-att-content @(IsAfternoonStarted ? "" : "tk-opacity-70")">
                            <div class="tk-att-header">
                                <div class="tk-icon-circle tk-icon-indigo"><span class="material-symbols-outlined">partly_cloudy_day</span></div>
                                <div>
                                    <h4 class="tk-att-title">Buổi Chiều</h4>
                                    @if (IsAfternoonStarted)
                                    {
                                        <span class="tk-badge tk-badge-green" style="background-color: var(--tk-primary-light); color: var(--tk-primary);">Đang diễn ra</span>
                                    }
                                    else
                                    {
