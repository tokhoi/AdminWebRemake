                        <div class="tk-notif-icon tk-bg-blue"><span class="material-symbols-outlined">mail</span></div>
                        <div class="tk-notif-content">
                            <p class="tk-notif-title">Thông báo lịch nghỉ lễ</p>
                            <p class="tk-notif-time">Phòng hành chính • 2 giờ trước</p>
                        </div>
                    </div>
                    <div class="tk-notif-item">
                        <div class="tk-notif-icon tk-bg-green"><span class="material-symbols-outlined">update</span></div>
                        <div class="tk-notif-content">
                            <p class="tk-notif-title">Cập nhật hệ thống v2.0</p>
                            <p class="tk-notif-time">Ban kỹ thuật • Hôm qua</p>
                        </div>
                    </div>
                    <div class="tk-notif-item">
                        <div class="tk-notif-icon tk-bg-orange"><span class="material-symbols-outlined">warning</span></div>
                        <div class="tk-notif-content">
                            <p class="tk-notif-title">Cảnh báo thời tiết xấu</p>
                            <p class="tk-notif-time">BGH • Hôm qua</p>
                        </div>
