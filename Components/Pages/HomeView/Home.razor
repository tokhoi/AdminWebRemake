@page "/"
@using System.Globalization
@rendermode InteractiveServer

<PageTitle>Trang Tổng Quan Hệ Thống - TitKul</PageTitle>

<div class="tk-dashboard-wrapper">
    <div class="tk-container">
        <div class="tk-grid-layout">

            @* ================= HÀNG 1 ================= *@

            @* 1. BANNER (Bên Trái) *@
            <div class="tk-banner tk-banner-slim tk-grid-col-left">

                <div class="tk-banner-bg-wrapper">
                    <div class="tk-blob tk-blob-1"></div>
                    <div class="tk-blob tk-blob-2"></div>

                    <div class="tk-bubble tk-bubble-1"></div>
                    <div class="tk-bubble tk-bubble-2"></div>
                    <div class="tk-bubble tk-bubble-3"></div>
                    <div class="tk-bubble tk-bubble-4"></div>
                    <div class="tk-bubble tk-bubble-5"></div>
                    <div class="tk-bubble tk-bubble-6"></div>
                    <div class="tk-bubble tk-bubble-7"></div>
                </div>

                <div class="tk-banner-content">
                    <h2 class="tk-banner-title">Xin chào, Admin!</h2>
                    <p class="tk-banner-subtitle">Chúc bạn một ngày làm việc hiệu quả tại Trường ABC.</p>

                    <div class="tk-banner-stats">
                        <div class="tk-stat-pill">
                            <span class="material-symbols-outlined tk-icon-lg">groups</span>
                            <div class="tk-stat-info">
                                <div class="tk-stat-number">@MorningPresentStudents.ToString("N0")</div>
