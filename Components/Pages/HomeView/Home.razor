                        </button>
                    </div>
                </div>
                <div class="tk-attendance-grid">
                    @* Cột Buổi sáng *@
                    <div class="tk-att-col">
                        <div class="tk-bg-icon"><span class="material-symbols-outlined">wb_sunny</span></div>
                        <div class="tk-att-content">
                            <div class="tk-att-header">
                                <div class="tk-icon-circle tk-icon-orange"><span class="material-symbols-outlined">wb_sunny</span></div>
                                <div>
                                    <h4 class="tk-att-title">Buổi Sáng</h4>
