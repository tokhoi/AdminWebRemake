                            </div>
                        </div>
                        <div class="tk-stat-pill">
                            <span class="material-symbols-outlined tk-icon-lg">person</span>
                            <div class="tk-stat-info">
                                <div class="tk-stat-number">@TotalTeachers.ToString("N0")</div>
