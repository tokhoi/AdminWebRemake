@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Tổng quan</PageTitle>

<div class="page-home-dashboard animate-fade-in">
    <div class="std-card" style="flex: 0 0 auto; padding: 1rem 1.5rem; margin-bottom: 1.5rem;">
        <div class="flex-between">
            <div class="card-title" style="font-size: 1.25rem; margin:0;">
                <div class="tea-icon"><span class="material-icons-round">dashboard</span></div>
                Tổng quan
            </div>
            <div class="action-group">
                <button class="btn btn-primary" @onclick="() => IsCalendarOpen = true">
                    <span class="material-icons-round">calendar_month</span>
                    <span>@SelectedDate.ToString("dd/MM/yyyy")</span>
                    <span class="material-icons-round" style="font-size: 16px;">expand_more</span>
                </button>
            </div>
        </div>
    </div>

    <div class="home-stats-row">
        <div class="stat-card" style="background: var(--grad-blue);">
            <div class="stat-icon-box"><span class="material-icons-round">school</span></div>
            <div class="stat-info"><p class="stat-label">Học sinh</p><p class="stat-value">1384</p></div>
            <div class="blob-1"></div>
        </div>
        <div class="stat-card" style="background: var(--grad-orange);">
            <div class="stat-icon-box"><span class="material-icons-round">person</span></div>
            <div class="stat-info"><p class="stat-label">Giáo viên</p><p class="stat-value">76</p></div>
            <div class="blob-1"></div>
        </div>
        <div class="stat-card" style="background: var(--grad-green);">
            <div class="stat-icon-box"><span class="material-icons-round">apartment</span></div>
            <div class="stat-info"><p class="stat-label">Khối</p><p class="stat-value">5</p></div>
            <div class="blob-1"></div>
        </div>
        <div class="stat-card" style="background: var(--grad-purple);">
            <div class="stat-icon-box"><span class="material-icons-round">domain</span></div>
            <div class="stat-info"><p class="stat-label">Lớp học</p><p class="stat-value">35</p></div>
            <div class="blob-1"></div>
        </div>
    </div>

    <div class="home-charts-grid">
        <div class="std-card home-chart-card">
            <div class="card-header">
                <div class="card-title" style="font-size: 1rem;">
                    <div class="bar-indicator" style="background: #3b82f6;"></div>
                    Điểm danh học sinh
                </div>
                <div class="session-tabs">
                    <span class="@(StudentSession == "AM" ? "active" : "")" @onclick='() => ChangeStudentSession("AM")'>Sáng</span>
                    <span class="@(StudentSession == "PM" ? "active" : "")" @onclick='() => ChangeStudentSession("PM")'>Chiều</span>
                </div>
            </div>

            <div class="home-chart-body flex-center" style="flex-direction: column;">
                <div class="chart-wrapper">
                    <canvas id="studentAttendanceChart" style="width: 180px; height: 180px;"></canvas>
                    <div class="chart-center">
                        @{
                            var sData = StudentSession == "AM" ? StudentDataAM : StudentDataPM;
                            double sTotal = sData.Present + sData.Late + sData.Absent;
                            double sRate = sTotal > 0 ? Math.Round((sData.Present + sData.Late) / sTotal * 100, 1) : 0;
                        }
                        <span class="c-main" style="font-size: 2.5rem; font-weight: 900; color: #1e293b;">@sRate%</span>
                    </div>
                </div>
                <div class="chart-legend-compact">
                    <div class="legend-item" title="Có mặt">
                        <span class="legend-dot" style="background: #22c55e;"></span>
                        <span class="legend-text"><b>@sData.Present</b></span>
                    </div>
                    <div class="legend-item" title="Đi trễ">
                        <span class="legend-dot" style="background: #eab308;"></span>
                        <span class="legend-text"><b>@sData.Late</b></span>
                    </div>
                    <div class="legend-item" title="Vắng">
                        <span class="legend-dot" style="background: #ef4444;"></span>
                        <span class="legend-text"><b>@sData.Absent</b></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="std-card home-chart-card">
            <div class="card-header">
                <div class="card-title" style="font-size: 1rem;">
                    <div class="bar-indicator" style="background: #f97316;"></div>
                    Điểm danh giáo viên
                </div>
                <div class="session-tabs">
                    <span class="@(TeacherSession == "AM" ? "active" : "")" @onclick='() => ChangeTeacherSession("AM")'>Sáng</span>
                    <span class="@(TeacherSession == "PM" ? "active" : "")" @onclick='() => ChangeTeacherSession("PM")'>Chiều</span>
                </div>
            </div>

            <div class="home-chart-body flex-center" style="flex-direction: column;">
                <div class="chart-wrapper">
                    <canvas id="teacherAttendanceChart" style="width: 180px; height: 180px;"></canvas>
                    <div class="chart-center">
                        @{
                            var tData = TeacherSession == "AM" ? TeacherDataAM : TeacherDataPM;
                            double tTotal = tData.Present + tData.Late + tData.Absent;
                            double tRate = tTotal > 0 ? Math.Round((tData.Present + tData.Late) / tTotal * 100, 1) : 0;
                        }
                        <span class="c-main" style="font-size: 2.5rem; font-weight: 900; color: #1e293b;">@tRate%</span>
                    </div>
                </div>
                <div class="chart-legend-compact">
                    <div class="legend-item" title="Có mặt">
                        <span class="legend-dot" style="background: #22c55e;"></span>
                        <span class="legend-text"><b>@tData.Present</b></span>
                    </div>
                    <div class="legend-item" title="Đi trễ">
                        <span class="legend-dot" style="background: #eab308;"></span>
                        <span class="legend-text"><b>@tData.Late</b></span>
                    </div>
                    <div class="legend-item" title="Vắng">
                        <span class="legend-dot" style="background: #ef4444;"></span>
                        <span class="legend-text"><b>@tData.Absent</b></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="std-card home-list-card-small">
            <div class="card-header">
                <div class="card-title" style="font-size: 1rem;">
                    <div class="bar-indicator" style="background: var(--c-green)"></div>
                    Chi tiết khối
                </div>
                @if (SelectedGrade != null)
                {
                    <button class="btn-icon" @onclick="BackToOverview"><span class="material-icons-round text-red">keyboard_return</span></button>
                }
            </div>
            <div class="home-list-scroll-small">
                @if (SelectedGrade == null)
                {
                    @foreach (var item in GradeStats)
                    {
                        <div class="progress-row-small" @onclick="() => SelectGrade(item)">
                            <div class="grade-icon-small" style="background: @item.Color;">@item.ShortName</div>
                            <div class="p-content-small">
                                <div class="flex-between" style="gap: 8px; margin-bottom: 4px;"><span class="p-name-small">@item.Name</span><span class="p-val-small">@item.Present/@item.Total</span></div>
                                <div class="p-bar-small">
                                    <div class="p-fill" style="width: @Math.Round((double)item.Present / item.Total * 100)%; background: @item.Color; height: 100%;"></div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    @foreach (var cls in DetailClasses)
                    {
                        <div class="progress-row-small cursor-default">
                            <div class="grade-icon-small" style="background: #f1f5f9; color: #333; font-size: 0.6rem;">@cls.ClassName</div>
                            <div class="p-content-small">
                                <div class="flex-between" style="gap: 8px; margin-bottom: 4px;"><span class="p-name-small">Lớp @cls.ClassName</span><span class="p-val-small">@cls.Present/@cls.Total</span></div>
                                <div class="p-bar-small">
                                    <div class="p-fill" style="width: @Math.Round((double)cls.Present / cls.Total * 100)%; background: @SelectedGrade.Color; height: 100%;"></div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@if (IsCalendarOpen)
{
    <div class="modal-overlay show" @onclick="() => IsCalendarOpen = false">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="flex-between mb-4"><h3 style="margin:0; font-weight:700;">Chọn ngày</h3><span class="material-icons-round cursor-pointer" @onclick="() => IsCalendarOpen = false">close</span></div>
            <div class="flex-between mb-4">
                <span class="material-icons-round cursor-pointer text-primary" @onclick="PrevMonth">chevron_left</span>
                <span style="font-weight:700; color:var(--primary);">Tháng @CurrentDisplayDate.Month, @CurrentDisplayDate.Year</span>
                <span class="material-icons-round cursor-pointer text-primary" @onclick="NextMonth">chevron_right</span>
            </div>
            <div class="calendar-grid">
                <div class="cal-head text-red" style="color:#ef4444;">CN</div><div class="cal-head">T2</div><div class="cal-head">T3</div><div class="cal-head">T4</div><div class="cal-head">T5</div><div class="cal-head">T6</div><div class="cal-head text-red" style="color:#ef4444;">T7</div>
                @foreach (var d in CalendarDays)
                {
                    <div class="cal-cell @(d.Date == SelectedDate.Date ? "active" : "")" @onclick="() => OnDateSelect(d)">@d.Day</div>
                }
            </div>
        </div>
    </div>
}


@code {
    // --- State ---
    bool IsCalendarOpen = false;
    DateTime SelectedDate = DateTime.Today;
    DateTime CurrentDisplayDate = DateTime.Today;
    List<DateTime> CalendarDays = new List<DateTime>();

    // Tách 2 biến session riêng biệt
    string StudentSession = "AM";
    string TeacherSession = "AM";

    // --- Data Models ---
    class AttendanceData { public int Present { get; set; } public int Late { get; set; } public int Absent { get; set; } }
    class GradeStat { public string Name { get; set; } public string ShortName { get; set; } public int Total { get; set; } public int Present { get; set; } public string Color { get; set; } }
    class ClassStat { public string ClassName { get; set; } public int Total { get; set; } public int Present { get; set; } }

    // --- Mock Data ---
    AttendanceData StudentDataAM = new() { Present = 1200, Late = 50, Absent = 134 };
    AttendanceData StudentDataPM = new() { Present = 1150, Late = 80, Absent = 154 };

    AttendanceData TeacherDataAM = new() { Present = 70, Late = 4, Absent = 2 };
    AttendanceData TeacherDataPM = new() { Present = 72, Late = 1, Absent = 3 };

    GradeStat? SelectedGrade = null;
    List<ClassStat> DetailClasses = new List<ClassStat>();

    List<GradeStat> GradeStats = new List<GradeStat> {
        new GradeStat { Name="Khối 1", ShortName="K1", Total=350, Present=342, Color="#ef4444" },
        new GradeStat { Name="Khối 2", ShortName="K2", Total=300, Present=285, Color="#f97316" },
        new GradeStat { Name="Khối 3", ShortName="K3", Total=250, Present=248, Color="#eab308" },
        new GradeStat { Name="Khối 4", ShortName="K4", Total=200, Present=195, Color="#22c55e" },
        new GradeStat { Name="Khối 5", ShortName="K5", Total=284, Present=280, Color="#3b82f6" }
    };

    // --- Lifecycle ---
    protected override void OnInitialized() { GenerateCalendar(); }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(500);
            // Vẽ lần đầu cả 2 biểu đồ
            await RenderStudentChart();
            await RenderTeacherChart();
        }
    }

    // --- Logic Chuyển Tab Học Sinh ---
    private async Task ChangeStudentSession(string session)
    {
        if (StudentSession != session)
        {
            StudentSession = session;
            await RenderStudentChart(); // Chỉ vẽ lại chart học sinh
        }
    }

    // --- Logic Chuyển Tab Giáo Viên ---
    private async Task ChangeTeacherSession(string session)
    {
        if (TeacherSession != session)
        {
            TeacherSession = session;
            await RenderTeacherChart(); // Chỉ vẽ lại chart giáo viên
        }
    }

    // Hàm vẽ chart Học sinh
    private async Task RenderStudentChart()
    {
        try
        {
            var sData = StudentSession == "AM" ? StudentDataAM : StudentDataPM;
            await JS.InvokeVoidAsync("initializeChart", "studentAttendanceChart", sData.Present, sData.Late, sData.Absent);
        }
        catch { }
    }

    // Hàm vẽ chart Giáo viên
    private async Task RenderTeacherChart()
    {
        try
        {
            var tData = TeacherSession == "AM" ? TeacherDataAM : TeacherDataPM;
            await JS.InvokeVoidAsync("initializeChart", "teacherAttendanceChart", tData.Present, tData.Late, tData.Absent);
        }
        catch { }
    }

    // --- Calendar Logic ---
    void GenerateCalendar()
    {
        CalendarDays.Clear();
        var start = new DateTime(CurrentDisplayDate.Year, CurrentDisplayDate.Month, 1);
        var offset = start.AddDays(-(int)start.DayOfWeek);
        for (int i = 0; i < 42; i++) CalendarDays.Add(offset.AddDays(i));
    }
    void PrevMonth() { CurrentDisplayDate = CurrentDisplayDate.AddMonths(-1); GenerateCalendar(); }
    void NextMonth() { CurrentDisplayDate = CurrentDisplayDate.AddMonths(1); GenerateCalendar(); }
    async Task OnDateSelect(DateTime d)
    {
        SelectedDate = d;
        if (d.Month != CurrentDisplayDate.Month) { CurrentDisplayDate = d; GenerateCalendar(); }
        // Load lại cả 2 chart khi đổi ngày
        await RenderStudentChart();
        await RenderTeacherChart();
        IsCalendarOpen = false;
    }

    void SelectGrade(GradeStat g)
    {
        SelectedGrade = g;
        DetailClasses = Enumerable.Range(1, 8).Select(i => new ClassStat { ClassName = $"{g.ShortName.Replace("K", "")}A{i}", Total = 35, Present = 33 }).ToList();
    }
    void BackToOverview() => SelectedGrade = null;
}