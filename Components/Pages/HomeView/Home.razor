                                    }
                                </div>
                            </div>

                            <div class="tk-progress-group">
                                <div class="tk-progress-header">
                                    <div class="tk-progress-label"><span class="material-symbols-outlined">groups</span> Học sinh</div>
                                    <div class="tk-progress-percent @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                        @(IsAfternoonStarted ? $"{AfternoonStudentPercent}%" : "--%")
                                    </div>
                                </div>
                                <div class="tk-progress-bar">
                                    <div class="tk-progress-fill @(IsAfternoonStarted ? "tk-fill-green" : "tk-fill-gray")" style="width: @(IsAfternoonStarted? GetCssWidth(AfternoonStudentPercent) : "0%"); transition: width 0.8s ease-in-out;"></div>
                                </div>
                                <div class="tk-progress-stats @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                    @if (IsAfternoonStarted)
                                    {
                                        <span>Có mặt: <b>@AfternoonPresentStudents.ToString("N0")</b>/@TotalStudents.ToString("N0")</span>
                                        <span>Vắng: <b class="tk-text-red">@AfternoonAbsentStudents.ToString("N0")</b></span>
                                    }
                                    else
                                    {
                                        <span>Dự kiến: <b>@TotalStudents.ToString("N0")</b></span>
                                        <span>---</span>
                                    }
                                </div>
                            </div>

                            <div class="tk-progress-group">
                                <div class="tk-progress-header">
                                    <div class="tk-progress-label"><span class="material-symbols-outlined">person_apron</span> Giáo viên</div>
                                    <div class="tk-progress-percent @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                        @(IsAfternoonStarted ? $"{AfternoonTeacherPercent}%" : "--%")
                                    </div>
                                </div>
                                <div class="tk-progress-bar">
                                    <div class="tk-progress-fill @(IsAfternoonStarted ? "tk-fill-blue" : "tk-fill-gray")" style="width: @(IsAfternoonStarted? GetCssWidth(AfternoonTeacherPercent) : "0%"); transition: width 0.8s ease-in-out;"></div>
                                </div>
                                <div class="tk-progress-stats @(IsAfternoonStarted ? "" : "tk-text-gray")">
                                    @if (IsAfternoonStarted)
                                    {
                                        <span>Có mặt: <b>@AfternoonPresentTeachers</b>/@TotalTeachers</span>
                                        <span>Vắng: <b class="tk-text-red">@AfternoonAbsentTeachers</b></span>
                                    }
                                    else
                                    {
                                        <span>Dự kiến: <b>@TotalTeachers</b></span>
                                        <span>---</span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* PHÍM TẮT (Bên Phải) *@
            <div class="tk-card tk-grid-col-right tk-card-flex">
                <div class="tk-card-header tk-border-bottom">
                    <h3 class="tk-section-title tk-text-md">
                        <span class="material-symbols-outlined tk-text-blue" style="margin-right: 4px;">bolt</span> Phím tắt nhanh
                    </h3>
                </div>
                <div class="tk-card-body tk-card-body-center" style="padding: 1rem;">
                    <div class="tk-shortcuts-grid">
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-blue"><span class="material-symbols-outlined">person_add</span></div>
                            <span class="tk-shortcut-text">Thêm học sinh</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-green"><span class="material-symbols-outlined">send</span></div>
                            <span class="tk-shortcut-text">Gửi thông báo</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-purple"><span class="material-symbols-outlined">calendar_month</span></div>
                            <span class="tk-shortcut-text">Xem lịch học</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-orange"><span class="material-symbols-outlined">restaurant_menu</span></div>
                            <span class="tk-shortcut-text">Thực đơn</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-red">
                                <span class="material-symbols-outlined">
                                    assignment
                                </span>
                            </div>
                            <span class="tk-shortcut-text">Đơn nghỉ phép</span>
                        </a>
                        <a class="tk-shortcut-item">
                            <div class="tk-shortcut-icon tk-bg-gray"><span class="material-symbols-outlined">more_horiz</span></div>
                            <span class="tk-shortcut-text">Khác</span>
                        </a>
                    </div>
                </div>
            </div>

            @* ================= HÀNG 3 ================= *@

            @* KHỐI TIN TỨC SỞ GIÁO DỤC (Bên Trái) *@
            <div class="tk-card tk-grid-col-full tk-card-flex">
                <div class="tk-card-header tk-border-bottom">
                    <h3 class="tk-section-title">
                        <span class="tk-title-indicator"></span> Tin tức Sở Giáo dục & Đào tạo
                    </h3>
                    <a class="tk-link-blue">Xem tất cả</a>
                </div>
                <div class="tk-news-list">
                    @* Card 1 *@
                    <div class="tk-news-card">
