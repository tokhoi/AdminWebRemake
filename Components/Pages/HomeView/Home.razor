                        </div>
                    </div>

                    @* Card 2 *@
                    <div class="tk-news-card">
                        <div class="tk-news-image">
                            <img src="https://picsum.photos/seed/school2/400/200" alt="Thumbnail" />
                        </div>
                        <div class="tk-news-info">
                            <h4 class="tk-news-title">Kế hoạch tổ chức Hội thi Giáo viên dạy giỏi cấp Thành phố</h4>
                            <span class="tk-news-meta">Sở GD&ĐT • 02/03/2026</span>
                        </div>
                    </div>

                    @* Card 3 *@
                    <div class="tk-news-card">
                        <div class="tk-news-image">
                            <img src="https://picsum.photos/seed/school3/400/200" alt="Thumbnail" />
                        </div>
                        <div class="tk-news-info">
                            <h4 class="tk-news-title">Công văn về việc tăng cường công tác đảm bảo an toàn thực phẩm trong trường học</h4>
                            <span class="tk-news-meta">Bộ GD&ĐT • 28/02/2026</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@* =================== MODAL LỊCH ================= *@
@if (IsCalendarModalOpen)
{
    <div class="tk-modal-backdrop" @onclick="CloseCalendarModal">
        <div class="tk-modal-container" @onclick:stopPropagation="true">
            <div class="tk-modal-header">
                <h3 class="tk-modal-title">Chọn ngày</h3>
                <button class="tk-modal-close" @onclick="CloseCalendarModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="tk-modal-body">
                <div class="tk-calendar-card tk-calendar-in-modal">
                    <div class="tk-calendar-header">
                        <div class="tk-cal-nav-row">
                            <h3 class="tk-cal-month">Tháng @CurrentDisplayDate.Month, @CurrentDisplayDate.Year</h3>
                            <div class="tk-cal-actions">
                                <button class="tk-cal-btn" @onclick="PrevMonth"><span class="material-symbols-outlined">chevron_left</span></button>
                                <button class="tk-cal-btn" @onclick="NextMonth"><span class="material-symbols-outlined">chevron_right</span></button>
                            </div>
                        </div>
                        <div class="tk-cal-grid tk-cal-weekdays">
                            <span>CN</span><span>T2</span><span>T3</span><span>T4</span><span>T5</span><span>T6</span><span>T7</span>
                        </div>
                        <div class="tk-cal-grid tk-cal-days">
                            @foreach (var d in CalendarDays)
                            {
                                bool isCurrentMonth = d.Month == CurrentDisplayDate.Month;
                                bool isSelected = d.Date == SelectedDate.Date;
                                bool hasEvent = d.Day % 5 == 0 && isCurrentMonth;

                                if (!isCurrentMonth)
                                {
                                    <span class="tk-cal-day tk-fade">@d.Day</span>
                                }
                                else if (isSelected)
                                {
                                    <span class="tk-cal-day tk-selected" @onclick="() => SelectDate(d)">@d.Day</span>
                                }
                                else
                                {
                                    <span class="tk-cal-day tk-normal" @onclick="() => SelectDate(d)">
                                        @d.Day
                                        @if (hasEvent)
                                        {
                                            <div class="tk-cal-dot"></div>
                                        }
                                    </span>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // === DỮ LIỆU ĐỘNG CHO DASHBOARD ===
    private int TotalStudents = 1500;
    private int TotalTeachers = 84;

    // Dữ liệu buổi sáng
    private int MorningPresentStudents = 1325;
    private int MorningAbsentStudents => TotalStudents - MorningPresentStudents;
    private double MorningStudentPercent => TotalStudents == 0 ? 0 : Math.Round((double)MorningPresentStudents / TotalStudents * 100, 1);

    private int MorningPresentTeachers = 82;
    private int MorningAbsentTeachers => TotalTeachers - MorningPresentTeachers;
    private double MorningTeacherPercent => TotalTeachers == 0 ? 0 : Math.Round((double)MorningPresentTeachers / TotalTeachers * 100, 1);

    // Dữ liệu buổi chiều
    private bool IsAfternoonStarted = false;
    private int AfternoonPresentStudents = 0;
    private int AfternoonAbsentStudents => TotalStudents - AfternoonPresentStudents;
    private double AfternoonStudentPercent => TotalStudents == 0 ? 0 : Math.Round((double)AfternoonPresentStudents / TotalStudents * 100, 1);

    private int AfternoonPresentTeachers = 0;
    private int AfternoonAbsentTeachers => TotalTeachers - AfternoonPresentTeachers;
    private double AfternoonTeacherPercent => TotalTeachers == 0 ? 0 : Math.Round((double)AfternoonPresentTeachers / TotalTeachers * 100, 1);

    // Trình trợ giúp chuyển % sang CSS an toàn 
    private string GetCssWidth(double percent) => $"{percent.ToString("0.0", CultureInfo.InvariantCulture)}%";

    // Cập nhật số liệu để test UI hoạt động
    private void RefreshData()
    {
        var rnd = new Random();

        // Random số liệu sáng
        MorningPresentStudents = rnd.Next(1000, TotalStudents);
        MorningPresentTeachers = rnd.Next(60, TotalTeachers);

        // Kích hoạt buổi chiều và random số liệu
        IsAfternoonStarted = true;
        AfternoonPresentStudents = rnd.Next(1000, TotalStudents);
        AfternoonPresentTeachers = rnd.Next(60, TotalTeachers);
    }

    // === LOGIC LỊCH ===
    private bool IsCalendarModalOpen = false;
    private void OpenCalendarModal() => IsCalendarModalOpen = true;
    private void CloseCalendarModal() => IsCalendarModalOpen = false;

    private DateTime SelectedDate = DateTime.Today;
    private DateTime CurrentDisplayDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private List<DateTime> CalendarDays = new List<DateTime>();

    protected override void OnInitialized()
    {
        GenerateCalendar();
    }

    private void GenerateCalendar()
    {
        CalendarDays.Clear();
        var startOfMonth = new DateTime(CurrentDisplayDate.Year, CurrentDisplayDate.Month, 1);
        int daysToSubtract = (int)startOfMonth.DayOfWeek;
        var startDate = startOfMonth.AddDays(-daysToSubtract);

        for (int i = 0; i < 42; i++)
        {
            CalendarDays.Add(startDate.AddDays(i));
        }
    }

    private void PrevMonth()
    {
        CurrentDisplayDate = CurrentDisplayDate.AddMonths(-1);
        GenerateCalendar();
    }

    private void NextMonth()
    {
        CurrentDisplayDate = CurrentDisplayDate.AddMonths(1);
        GenerateCalendar();
    }

    private void SelectDate(DateTime date)
    {
        SelectedDate = date;
    }
}

<style>
    /* ==========================================================================
               PURE CSS REFACTOR TỪ TAILWIND (DÀNH CHO TRANG TỔNG QUAN)
               ========================================================================== */
    :root {
        --tk-primary: #1b6ec2;
        --tk-primary-dark: #1565c0;
        --tk-primary-light: #e3f2fd;
        --tk-orange: #f97316;
        --tk-orange-light: #fff7ed;
        --tk-green: #22c55e;
        --tk-green-light: #f0fdf4;
        --tk-purple: #a855f7;
        --tk-purple-light: #faf5ff;
        --tk-red: #ef4444;
        --tk-red-light: #fef2f2;
        --tk-gray-50: #f9fafb;
        --tk-gray-100: #f3f4f6;
        --tk-gray-200: #e5e7eb;
        --tk-gray-400: #9ca3af;
        --tk-gray-500: #6b7280;
        --tk-gray-800: #1f2937;
        --tk-shadow-card: 0 2px 8px rgba(0,0,0,0.04), 0 0 1px rgba(0,0,0,0.08);
        --tk-shadow-hover: 0 10px 25px -5px rgba(0,0,0,0.1);
        --tk-radius-lg: 1.5rem;
        --tk-radius-md: 1rem;
    }

    /* Base Layout */
    .tk-dashboard-wrapper {
        font-family: 'Roboto', sans-serif;
        background-color: #f0f4f8;
        min-height: auto;
        padding: 1.5rem;
        color: var(--tk-gray-800);
        box-sizing: border-box;
    }

        .tk-dashboard-wrapper * {
            box-sizing: border-box;
        }

    .tk-container {
        max-width: auto;
        margin: 0 auto;
    }

    .tk-grid-layout {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @@media (min-width: 1024px) {
        .tk-grid-layout {
            grid-template-columns: repeat(12, 1fr);
            align-items: stretch;
        }

        .tk-grid-col-left {
            grid-column: span 8;
        }

        .tk-grid-col-right {
            grid-column: span 4;
        }

        .tk-grid-col-full {
            grid-column: span 12;
        }
    }

    @@media (min-width: 1280px) {
        .tk-grid-col-left {
            grid-column: span 9;
        }

        .tk-grid-col-right {
            grid-column: span 3;
        }
    }

    .tk-card {
        background-color: #ffffff;
