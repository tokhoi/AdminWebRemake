                                    <div class="tk-progress-percent">@MorningTeacherPercent%</div>
                                </div>
                                <div class="tk-progress-bar">
                                    <div class="tk-progress-fill tk-fill-blue" style="width: @GetCssWidth(MorningTeacherPercent); transition: width 0.8s ease-in-out;"></div>
                                </div>
                                <div class="tk-progress-stats">
