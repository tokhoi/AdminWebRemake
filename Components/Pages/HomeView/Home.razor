@page "/"
@using System.Globalization
@rendermode InteractiveServer

<PageTitle>Trang Tổng Quan Hệ Thống - TitKul</PageTitle>

<div class="tk-dashboard-wrapper">
    <div class="tk-container">
        <div class="tk-grid-layout">

            @* ================= HÀNG 1 ================= *@

            @* 1. BANNER (Bên Trái) *@
