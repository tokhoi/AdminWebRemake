                            </div>
                        </div>
                        <div class="tk-stat-pill">
                            <span class="material-symbols-outlined tk-icon-lg">person_off</span>
                            <div class="tk-stat-info">
                                <div class="tk-stat-number">@MorningAbsentTeachers.ToString("N0")</div>
                                <div class="tk-stat-label">Nghỉ</div>
                            </div>
                        </div>
                        <div class="tk-stat-pill">
                            <span class="material-symbols-outlined tk-icon-lg">block</span>
                            <div class="tk-stat-info">
                                <div class="tk-stat-number">2</div>
                                <div class="tk-stat-label">Nghỉ không phép</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tk-banner-illustration">
                    <img src="./images/banner-corner.png" alt="Students Illustration" class="tk-banner-img" />
                </div>
            </div>

            @* KHỐI THÔNG BÁO (Bên Phải) *@
            <div class="tk-card tk-grid-col-right tk-card-flex">
                <div class="tk-card-header tk-border-bottom">
