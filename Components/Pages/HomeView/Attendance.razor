@page "/student-attendance"
@rendermode InteractiveServer

<PageTitle>Điểm danh học sinh</PageTitle>

<div class="page-student-attendance animate-fade-in">
    <div class="std-card" style="flex: 0 0 auto; padding: 1rem 1.5rem; margin-bottom: 0;">
        <div class="flex-between">
            <div class="card-title" style="font-size: 1.25rem;">
                <div class="tea-icon"><span class="material-icons-round">school</span></div>
                Điểm danh học sinh
            </div>
        </div>
    </div>

    <div class="std-card att-filter-box">
        <div class="att-filters-row">
            <div class="att-f-item">
                <label class="form-label">Ngày điểm danh</label>
                <input type="date" class="form-input" @bind="SelectedDate" @bind:after="FilterData" />
            </div>

            <div class="att-f-item">
                <label class="form-label">Lớp học</label>
                <select class="form-input" @bind="SelectedClass" @bind:after="FilterData">
                    <option value="">Tất cả các lớp</option>
                    @foreach (var c in Classes)
                    {
                        <option value="@c">Lớp @c</option>
                    }
                </select>
            </div>

            <div class="att-f-item-wide">
                <label class="form-label">Tìm kiếm học sinh</label>
                <div class="input-wrapper">
                    <span class="material-icons-round input-icon">search</span>
                    <input class="form-input input-has-icon" placeholder="Nhập tên hoặc mã học sinh..." @bind="SearchTerm" @bind:event="oninput" @bind:after="FilterData" />
                </div>
            </div>
            <div class="action-group">
                <button class="btn btn-primary" @onclick="ToggleExportMenu">
                    <span class="material-icons-round">file_download</span> Thao tác
                    <span class="material-icons-round" style="font-size: 16px;">expand_more</span>
                </button>
                @if (_showExportMenu)
                {
                    <div class="dropdown-menu">
                        <button class="dropdown-item-btn"><span class="material-icons-round" style="color:#1b6ec2;">save</span> Lưu thay đổi</button>
                        <div style="border-top:1px solid #eee; margin:4px 0;"></div>
                        <button class="dropdown-item-btn"><span class="material-icons-round" style="color:#1D6F42;">table_view</span> Xuất Excel điểm danh </button>
                        <button class="dropdown-item-btn"><span class="material-icons-round" style="color:#f97316;">person_off</span> Xuất Excel vắng mặt </button>
                        <button class="dropdown-item-btn"><span class="material-icons-round" style="color:#1b6ec2;">dataset</span> Xuất Excel thống kê </button>
                    </div>
                    <div style="position:fixed; inset:0; z-index:40;" @onclick="ToggleExportMenu"></div>
                }
            </div>
        </div>
    </div>

    <div class="std-card att-table-box">
        <div class="att-header-row">
            <div class="card-title" style="font-size:1rem;">
                <div class="bar-indicator" style="background: var(--c-blue);"></div>
                Danh sách học sinh - <span style="font-size: 0.9rem; color: var(--text-muted); font-weight: 500;">Tổng số: @FilteredStudents.Count</span>
            </div>
            <div class="att-legend">
                <span class="status-badge" style="background: #dcfce7; color: #166534; gap: 8px;">
                    <span style="width: 8px; height: 8px; border-radius: 50%; background: #16a34a;"></span>
                    <span>Có mặt: <b>@CountPresent</b></span>
                </span>
                <span class="status-badge" style="background: #fef9c3; color: #854d0e; gap: 8px;">
                    <span style="width: 8px; height: 8px; border-radius: 50%; background: #eab308;"></span>
                    <span>Muộn: <b>@CountLate</b></span>
                </span>
                <span class="status-badge" style="background: #fee2e2; color: #991b1b; gap: 8px;">
                    <span style="width: 8px; height: 8px; border-radius: 50%; background: #dc2626;"></span>
                    <span>Vắng: <b>@CountAbsent</b></span>
                </span>
            </div>
        </div>

        <div class="table-wrapper att-table-content">
            <table class="data-table" style="table-layout: fixed;">
                <colgroup>
                    <col style="width: 50px;">
                    <col style="width: 70px;">
                    <col style="width: 180px;">
                    <col style="width: 60px;">
                    <col style="width: 70px;">
                    <col style="width: 90px;">
                    <col style="width: 70px;">
                    <col style="width: 70px;">
                    <col style="width: 90px;">
                    <col style="width: 60px;">
                    <col style="width: 50px;">
                </colgroup>
                <thead>
                    <tr style="background-color: #f8fafc;">
                        <th class="text-center col-fit">STT</th>
                        <th class="col-fit">Mã HS</th>
                        <th style="text-align: left;">Tên học sinh</th>
                        <th class="text-center col-fit">Lớp</th>
                        <th class="text-center col-fit">Ngày</th>
                        <th class="text-center col-fit">Trạng thái sáng</th>
                        <th class="text-center col-fit">Giờ vào</th>
                        <th class="text-center col-fit">Giờ ra</th>
                        <th class="text-center col-fit">Trạng thái chiều</th>
                        <th class="text-center col-fit">Ghi chú</th>
                        <th class="text-center col-fit">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (PaginatedStudents.Any())
                    {
                        var index = (CurrentPage - 1) * PageSize;
                        foreach (var s in PaginatedStudents)
                        {
                            index++;
                            <tr>
                                <td class="text-center text-muted" style="font-weight: 500;">@index</td>
                                <td style="font-family: monospace; color: var(--primary); font-weight: 600;">@s.Code</td>
                                <td style="font-weight: 600; color: var(--text-main); overflow: hidden; text-overflow: ellipsis;">@s.Name</td>
                                <td class="text-center">
                                    <span class="att-badge" style="background: #eff6ff; color: #1e40af; font-weight: 600;">
                                        @s.Class
                                    </span>
                                </td>
                                <td class="text-center" style="color: var(--text-muted); font-size: 0.9rem;">
                                    @SelectedDate.ToString("dd/MM/yyyy")
                                </td>
                                <td class="text-center">
                                    <span class="att-status-badge @GetStatusClass(s.AmStatus)">
                                        @GetStatusIcon(s.AmStatus) @s.AmStatus
                                    </span>
                                </td>
                                <td class="text-center" style="color: #ef4444; font-weight: 600; font-size: 0.9rem;">@(s.TimeIn ?? "-")</td>
                                <td class="text-center" style="color: #0ea5e9; font-weight: 600; font-size: 0.9rem;">@(s.TimeOut ?? "-")</td>
                                <td class="text-center">
                                    <span class="att-status-badge @GetStatusClass(s.PmStatus)" 
                                          style="cursor:pointer;" 
                                          @onclick="() => ToggleStatus(s)">
                                        @GetStatusIcon(s.PmStatus) @s.PmStatus
                                    </span>
                                </td>
                                <td class="text-center text-muted">-</td>
                                <td class="text-center">
                                    <button class="btn-icon" title="Chỉnh sửa"><span class="material-icons-round">edit</span></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="text-center" style="padding: 4rem;">
                                <span class="material-icons-round" style="font-size: 48px; color: #e2e8f0;">manage_search</span>
                                <div style="margin-top:8px; color: var(--text-muted);">Không tìm thấy dữ liệu</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="att-footer">
            <span class="text-muted" style="font-size: 0.85rem;">Hiển thị @PaginatedStudents.Count / @FilteredStudents.Count bản ghi</span>
            <div class="att-paging">
                <button class="btn-outline pg-btn" disabled="@(CurrentPage <= 1)" @onclick="() => ChangePage(CurrentPage - 1)">
                    <span class="material-icons-round">chevron_left</span>
                </button>
                <button class="btn-primary pg-btn">@CurrentPage</button>
                <button class="btn-outline pg-btn" disabled="@(CurrentPage >= TotalPages)" @onclick="() => ChangePage(CurrentPage + 1)">
                    <span class="material-icons-round">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    class Student 
    { 
        public string Code { get; set; } = ""; 
        public string Name { get; set; } = ""; 
        public string Class { get; set; } = ""; 
        public string AmStatus { get; set; } = "Có mặt";
        public string PmStatus { get; set; } = "Có mặt";
        public string? TimeIn { get; set; }
        public string? TimeOut { get; set; }
    }

    List<Student> AllStudents = new();
    List<Student> FilteredStudents = new();
    List<string> Classes = new() { "1A", "1B", "2A", "2B", "3A", "5B" };

    DateTime SelectedDate { get; set; } = DateTime.Today;
    string SelectedClass { get; set; } = "";
    string SearchTerm { get; set; } = "";
    bool _showExportMenu = false;
    int PageSize = 15;
    int CurrentPage = 1;

    protected override void OnInitialized()
    {
        var rnd = new Random();
        var names = new[] { "Nguyễn Văn Hùng", "Trần Thị Lan", "Lê Minh Tuấn", "Phạm Thu Hà", "Hoàng Đức Anh", "Vũ Thị Mai" };
        for (int i = 1; i <= 100; i++)
        {
            var amStatus = rnd.Next(0, 10) > 2 ? "Có mặt" : (rnd.Next(0, 10) > 5 ? "Đi muộn" : "Vắng CP");
            var timeIn = amStatus == "Đi muộn" ? "06:45" : (amStatus == "Có mặt" ? "06:20" : null);
            var timeOut = rnd.Next(0, 10) > 3 ? "17:30" : null;

            AllStudents.Add(new Student
            {
                Code = $"HS{i:000}",
                Name = $"{names[rnd.Next(names.Length)]} {i}",
                Class = Classes[rnd.Next(Classes.Count)],
                AmStatus = amStatus,
                PmStatus = rnd.Next(0, 10) > 1 ? "Có mặt" : "Vắng KP",
                TimeIn = timeIn,
                TimeOut = timeOut
            });
        }
        FilterData();
    }

    void FilterData()
    {
        FilteredStudents = AllStudents.Where(s =>
            (string.IsNullOrEmpty(SearchTerm) || s.Name.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) || s.Code.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(SelectedClass) || s.Class == SelectedClass)
        ).ToList();
        CurrentPage = 1;
    }

    List<Student> PaginatedStudents => FilteredStudents.Skip((CurrentPage - 1) * PageSize).Take(PageSize).ToList();
    int TotalPages => FilteredStudents.Count == 0 ? 1 : (int)Math.Ceiling((double)FilteredStudents.Count / PageSize);
    int CountPresent => FilteredStudents.Count(s => s.AmStatus == "Có mặt");
    int CountLate => FilteredStudents.Count(s => s.AmStatus.Contains("Đi muộn"));
    int CountAbsent => FilteredStudents.Count(s => s.AmStatus.Contains("Vắng"));
    void ChangePage(int p) { if (p >= 1 && p <= TotalPages) CurrentPage = p; }
    void ToggleStatus(Student s) { s.PmStatus = s.PmStatus == "Có mặt" ? "Vắng KP" : "Có mặt"; }
    void ToggleExportMenu() => _showExportMenu = !_showExportMenu;

    string GetStatusClass(string s) => s switch 
    { 
        string x when x.Contains("Vắng") => "status-absent",
        string x when x.Contains("muộn") || x.Contains("Muộn") => "status-late",
        _ => "status-present"
    };

    string GetStatusIcon(string s) => s switch 
    { 
        string x when x.Contains("Vắng") => "●",
        string x when x.Contains("muộn") || x.Contains("Muộn") => "●", 
        _ => "●" 
    };
}