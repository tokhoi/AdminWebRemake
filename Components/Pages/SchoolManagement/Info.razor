@page "/school/info"

<PageTitle>Thông tin trường học</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-card-header">
            <h2 class="sm-card-title">
                <span class="material-icons-round">school</span> THÔNG TIN TRƯỜNG HỌC
            </h2>
            <button class="sm-btn sm-btn-primary">
                <span class="material-icons-round" style="font-size: 18px;">edit</span> Chỉnh sửa
            </button>
        </div>

        <div style="padding: 30px;">
            <div style="display: grid; grid-template-columns: 240px 1fr; gap: 40px;">
                <div style="display: flex; flex-direction: column; gap: 20px; align-items: center;">
                    <div style="width: 100%; aspect-ratio: 1; border: 1px solid var(--sm-border); border-radius: 12px; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #f8fafc;">
                        <span class="material-icons-round" style="font-size: 64px; color: #cbd5e1;">school</span>
                        <div style="font-weight: 700; color: #94a3b8; margin-top: 8px;">LOGO TRƯỜNG</div>
                    </div>

                    <div style="width: 100%; height: 80px; border: 1px dashed var(--sm-border); border-radius: 8px; display: flex; align-items: center; justify-content: center; background: #fff;">
                        <span style="font-weight: 600; color: #cbd5e1;">LOGO ĐỐI TÁC</span>
                    </div>
                </div>

                <div>
                    <div style="margin-bottom: 30px;">
                        <h3 style="font-size: 0.95rem; font-weight: 700; color: var(--sm-primary); text-transform: uppercase; margin-bottom: 16px; border-bottom: 2px solid var(--sm-border); display: inline-block; padding-bottom: 6px;">
                            Thông tin chung
                        </h3>
                        <div class="sm-info-grid">
                            <div class="label">Tên trường:</div>
                            <div class="value fw-bold" style="color: var(--sm-text-main);">Trường Tiểu học Tân Hưng</div>

                            <div class="label">Địa chỉ:</div>
                            <div class="value">Số 123 Đường ABC, Quận X, TP.HCM</div>

                            <div class="label">Ca Sáng:</div>
                            <div class="value">06:30 AM - 11:00 AM</div>

                            <div class="label">Ca Chiều:</div>
                            <div class="value">01:30 PM - 04:30 PM</div>
                        </div>
                    </div>

                    <div>
                        <h3 style="font-size: 0.95rem; font-weight: 700; color: var(--sm-primary); text-transform: uppercase; margin-bottom: 16px; border-bottom: 2px solid var(--sm-border); display: inline-block; padding-bottom: 6px;">
                            Ban Giám Hiệu
                        </h3>
                        <div class="sm-info-grid">
                            <div class="label">Hiệu trưởng:</div>
                            <div class="value">Nguyễn Văn A</div>

                            <div class="label">Liên hệ:</div>
                            <div class="value">0909 000 111 - hieutruong@tanhung.edu.vn</div>
                        </div>
                    </div>

                    <div style="margin-top: 40px; font-size: 0.85rem; color: var(--sm-text-muted); font-style: italic;">
                        <span class="material-icons-round" style="font-size: 16px; vertical-align: middle;">history</span>
                        Cập nhật lần cuối: 05/01/2026
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Style cục bộ cho trang Info, sử dụng biến sm- */
    .sm-info-grid {
        display: grid;
        grid-template-columns: 180px 1fr;
        gap: 12px 24px;
    }

        .sm-info-grid .label {
            font-weight: 600;
            color: var(--sm-text-muted);
            font-size: 0.9rem;
        }

        .sm-info-grid .value {
            color: var(--sm-text-main);
            font-size: 0.9rem;
        }

    @@media (max-width: 768px) {
        div[style*="grid-template-columns: 240px 1fr"] {
            grid-template-columns: 1fr !important;
        }

        .sm-info-grid {
            grid-template-columns: 1fr;
            gap: 4px;
            margin-bottom: 16px;
        }

            .sm-info-grid .label {
                color: var(--sm-primary);
                margin-top: 8px;
            }
    }
</style>