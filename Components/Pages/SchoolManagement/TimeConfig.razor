@page "/school/time-config"

<PageTitle>Cấu hình thời gian</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-card-header">
            <h2 class="sm-card-title">Cấu hình thời gian điểm danh</h2>
        </div>

        <div style="padding: 24px;">
            <div class="sm-grid-2">
                <div style="background: #fffbeb; padding: 24px; border-radius: 12px; border: 1px solid #fcd34d;">
                    <h3 class="fw-bold" style="color:#d97706; margin-bottom:16px; display:flex; gap:8px; align-items:center;">
                        <span class="material-icons-round">wb_sunny</span> Buổi Sáng
                    </h3>
                    <div style="display:flex; flex-direction:column; gap:16px;">
                        <div class="sm-filter-group">
                            <label class="sm-label">Bắt đầu</label>
                            <input type="time" class="sm-form-control" value="06:30" />
                        </div>
                        <div class="sm-filter-group">
                            <label class="sm-label">Kết thúc</label>
                            <input type="time" class="sm-form-control" value="11:00" />
                        </div>
                    </div>
                </div>

                <div style="background: #eff6ff; padding: 24px; border-radius: 12px; border: 1px solid #bfdbfe;">
                    <h3 class="fw-bold" style="color:#1d4ed8; margin-bottom:16px; display:flex; gap:8px; align-items:center;">
                        <span class="material-icons-round">nights_stay</span> Buổi Chiều
                    </h3>
                    <div style="display:flex; flex-direction:column; gap:16px;">
                        <div class="sm-filter-group">
                            <label class="sm-label">Bắt đầu</label>
                            <input type="time" class="sm-form-control" value="13:30" />
                        </div>
                        <div class="sm-filter-group">
                            <label class="sm-label">Kết thúc</label>
                            <input type="time" class="sm-form-control" value="17:00" />
                        </div>
                    </div>
                </div>
            </div>

            <div style="margin-top: 24px; display: flex; justify-content: flex-end;">
                <button class="sm-btn sm-btn-primary">
                    <span class="material-icons-round">save</span> Lưu cấu hình
                </button>
            </div>
        </div>
    </div>
</div>