@page "/school/leaves"

<PageTitle>Duyệt đơn nghỉ phép</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-toolbar">
            <div class="sm-filter-group">
                <label class="sm-label">Năm học</label>
                <select class="sm-form-select"><option>2025-2026</option></select>
            </div>
            <div class="sm-filter-group">
                <label class="sm-label">Ngày</label>
                <input type="date" class="sm-form-control" value="2026-05-01" />
            </div>
            <div class="sm-filter-group" style="flex:2;">
                <label class="sm-label">Tìm kiếm</label>
                <div class="sm-input-icon-wrapper">
                    <span class="material-icons-round">search</span>
                    <input class="sm-form-control" placeholder="Tên học sinh..." />
                </div>
            </div>
            <button class="sm-btn sm-btn-primary">Tìm kiếm</button>
        </div>

        <div style="min-height: 300px; display: flex; flex-direction: column; align-items: center; justify-content: center;">
            <div style="background: var(--kg-bg-subtle); padding: 20px; border-radius: 50%; margin-bottom: 16px;">
                <span class="material-icons-round" style="font-size: 48px; color: var(--kg-border);">inbox</span>
            </div>
            <p class="sm-text-muted fw-bold">Không có đơn nghỉ phép nào trong ngày này</p>
        </div>
    </div>
</div>

