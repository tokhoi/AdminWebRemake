@page "/school/assignment"
@rendermode InteractiveServer

<div class="assign-wrap" style="@AssignWrapStyle">
    <div class="a-header">
        <div class="a-title-grp">
            <div class="a-icon">
                <span class="material-icons-round">admin_panel_settings</span>
            </div>
            <div>
                <h4>PHÂN CÔNG CHUYÊN MÔN</h4>
                <span class="sub">Quản lý phân công chủ nhiệm & giảng dạy</span>
            </div>
        </div>
        <div class="a-actions">
            <div class="year-box">
                <span>Năm học:</span>
                <select><option>2025-2026</option><option>2024-2025</option></select>
            </div>
            <button class="a-btn save">
                <span class="material-icons-round">save</span> Lưu thay đổi
            </button>
        </div>
    </div>

    <div class="a-tabs">
        <div class="tab @(activeTab == 1 ? "active" : "")" @onclick="() => ChangeTab(1)">
            <span class="material-icons-round">person_pin</span> Phân công Chủ nhiệm
        </div>
        <div class="tab @(activeTab == 2 ? "active" : "")" @onclick="() => ChangeTab(2)">
            <span class="material-icons-round">school</span> Phân công Giảng dạy
        </div>
    </div>

    <div class="a-content">
        @if (activeTab == 1)
        {
            <div class="a-toolbar">
                <div class="a-filter">
                    <label>Lọc Khối:</label>
                    <select class="a-input" @onchange="FilterByGrade">
                        <option value="">Tất cả</option>
                        <option value="10">Khối 10</option>
                        <option value="11">Khối 11</option>
                        <option value="12">Khối 12</option>
                    </select>
                </div>
                <div class="ms-auto text-green">
                    <span class="material-icons-round" style="vertical-align: middle;">check_circle</span> 
                    Đã phân công: <strong>@AssignedCount/@classes.Count</strong> lớp
                </div>
            </div>
            <div class="a-table-scroll">
                <table class="a-table">
                    <thead><tr><th class="text-center">#</th><th class="text-center">Khối</th><th>Lớp</th><th class="text-center">Sĩ số</th><th>Giáo viên chủ nhiệm</th><th>Ghi chú</th></tr></thead>
                    <tbody>
                        @{
                            int idx = (currentPage - 1) * pageSize + 1;
                        }
                        @foreach (var c in PagedClasses)
                        {
                            <tr>
                                <td class="text-center text-muted">@(idx++)</td>
                                <td class="text-center text-muted fw-bold">@c.Grade</td>
                                <td><span class="a-tag">@c.Name</span></td>
                                <td class="text-center">@c.Count</td>
                                <td>
                                    <div class="seamless-wrap @(string.IsNullOrEmpty(c.TeacherId) ? "empty" : "")">
                                        <select @bind="c.TeacherId">
                                            <option value="">-- Chưa phân công --</option>
                                            @foreach (var t in teacherList)
                                            {
                                                <option value="@t.Id">@t.Name</option>
                                            }
                                        </select>
                                        <span class="material-icons-round a-arrow">expand_more</span>
                                    </div>
                                </td>
                                <td><input class="seamless-inp" placeholder="Ghi chú..." @bind="c.Note" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="a-foot">
                <span>Trang @currentPage / @TotalPages</span>
                <div class="a-paging">
                    <button @onclick="() => ChangePage(currentPage - 1)" disabled="@(currentPage == 1)">
                        <span class="material-icons-round">chevron_left</span>
                    </button>
                    <button @onclick="() => ChangePage(currentPage + 1)" disabled="@(currentPage == TotalPages)">
                        <span class="material-icons-round">chevron_right</span>
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="a-toolbar">
                <div class="a-filter">
                    <label>Lớp học:</label>
                    <select class="a-input highlight" @bind="selectedClassId">
                        @foreach (var c in classes)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <button class="a-btn outline ms-auto">
                    <span class="material-icons-round">content_copy</span> Sao chép
                </button>
            </div>
            <div class="a-table-scroll">
                <table class="a-table">
                    <thead><tr><th class="text-center">#</th><th>Môn học</th><th class="text-center">Số tiết</th><th>Giáo viên</th><th class="text-center">Trạng thái</th></tr></thead>
                    <tbody>
                        @{
                            int idx2 = 1;
                        }
                        @foreach (var s in subjects)
                        {
                            <tr>
                                <td class="text-center text-muted">@(idx2++)</td>
                                <td class="fw-bold" style="color:#1b6ec2">@s.Name</td>
                                <td class="text-center"><span class="a-badge">@s.PeriodCount</span></td>
                                <td>
                                    <div class="seamless-wrap @(string.IsNullOrEmpty(s.AssignedTeacherId) ? "empty" : "")">
                                        <select @bind="s.AssignedTeacherId">
                                            <option value="">-- Chọn GV --</option>
                                            @foreach (var t in teacherList)
                                            {
                                                <option value="@t.Id">@t.Name</option>
                                            }
                                        </select>
                                        <span class="material-icons-round a-arrow">expand_more</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(s.AssignedTeacherId))
                                    {
                                        <span class="material-icons-round text-green">check_circle</span>
                                    }
                                    else
                                    {

                                        <span class="material-icons-round text-orange">warning</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    int activeTab = 1;
    string filterGrade = "";
    string selectedClassId = "1";
    int currentPage = 1; int pageSize = 10;

    class ClassData { public string Id { get; set; } = ""; public string Grade { get; set; } = ""; public string Name { get; set; } = ""; public int Count { get; set; } public string TeacherId { get; set; } = ""; public string Note { get; set; } = ""; }
    class SubjectData { public int Id { get; set; } public string Name { get; set; } = ""; public int PeriodCount { get; set; } public string AssignedTeacherId { get; set; } = ""; }
    class Teacher { public string Id { get; set; } = ""; public string Name { get; set; } = ""; }

    List<Teacher> teacherList = new() { new Teacher { Id = "GV01", Name = "Nguyễn Thúy Hằng" }, new Teacher { Id = "GV02", Name = "Trần Minh Tuấn" } };
    List<ClassData> classes = new();
    List<SubjectData> subjects = new();

    List<ClassData> FilteredClasses => classes.Where(c => string.IsNullOrEmpty(filterGrade) || c.Grade == filterGrade).ToList();
    List<ClassData> PagedClasses => FilteredClasses.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    int TotalPages => (int)Math.Ceiling((double)FilteredClasses.Count / pageSize);
    int AssignedCount => classes.Count(c => !string.IsNullOrEmpty(c.TeacherId));

    protected override void OnInitialized()
    {
        for (int i = 1; i <= 30; i++) classes.Add(new ClassData { Id = i.ToString(), Grade = (i % 3 + 10).ToString(), Name = $"1{i % 3}A{i}", Count = 45 });
        string[] subs = { "Toán", "Lý", "Hóa", "Văn", "Anh", "Sử", "Địa" };
        for (int i = 0; i < subs.Length; i++) subjects.Add(new SubjectData { Id = i + 1, Name = subs[i], PeriodCount = 3 });
    }

    void ChangeTab(int tab) { activeTab = tab; currentPage = 1; }
    void FilterByGrade(ChangeEventArgs e) { filterGrade = e.Value?.ToString() ?? ""; currentPage = 1; }
    void ChangePage(int p) { if (p >= 1 && p <= TotalPages) currentPage = p; }

    string AssignWrapStyle
    {
        get
        {
            if (activeTab == 2)
                return "height: calc(100vh - 200px);";
            else
                return "height: calc(100vh - 70px);";
        }
    }
}

