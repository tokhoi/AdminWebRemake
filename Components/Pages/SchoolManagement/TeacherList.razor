@page "/school/teachers"
@rendermode InteractiveServer

<PageTitle>Danh sách giáo viên</PageTitle>

    <div class="teacher-page">
    <!-- Header -->
    <div class="t-header">
        <div class="t-left">
            <div class="t-icon">
                <span class="material-icons-round">people</span>
            </div>
            <div class="t-title">
                <h4>DANH SÁCH GIÁO VIÊN</h4>
                <span>Quản lý hồ sơ nhân sự</span>
            </div>
        </div>
        <button class="t-btn t-btn-primary">
            <span class="material-icons-round">person_add</span> Thêm giáo viên
        </button>
    </div>

    <!-- Toolbar/Filter -->
    <div class="t-toolbar">
        <!-- Search Box -->


        <!-- Filters -->
        <div class="t-filters">
            <select class="t-select" @bind="filterDepartment">
                <option value="">-- Tất cả Tổ bộ môn --</option>
                <option value="Tổ Toán - Tin">Tổ Toán - Tin</option>
                <option value="Tổ Văn - Sử">Tổ Văn - Sử</option>
                <option value="Tổ Ngoại ngữ">Tổ Ngoại ngữ</option>
            </select>
            <select class="t-select">
                <option>-- Trạng thái --</option>
                <option>Đang công tác</option>
                <option>Đã nghỉ việc</option>
            </select>
        </div>
        <div class="t-search-wrapper">
            <div class="t-search">
                <span class="material-icons-round t-search-icon">search</span>
                <input type="text" placeholder="Tìm kiếm (Mã, Tên, SĐT)..." @bind="searchTerm" @bind:event="oninput" @onkeyup="ResetPaging" />
            </div>
        </div>

        <!-- Export Button -->
        <button class="t-btn t-btn-outline ms-auto">
            <span class="material-icons-round">download</span> Xuất Excel
        </button>
    </div>

    <!-- Table -->
    <div class="t-table-box">
        <table class="t-table">
            <thead>
                <tr>
                    <th width="30" class="text-center">STT</th>
                    <th width="60">Mã GV</th>
                    <th>Họ và tên</th>
                    <th>Tổ chuyên môn</th>
                    <th>Số điện thoại</th>
                    <th>Email</th>
                    <th width="160" class="text-center">Trạng thái</th>
                    <th width="100" class="text-end">Tác vụ</th>
                </tr>
            </thead>
            <tbody>
                @if (PagedTeachers.Any())
                {
                    int idx = (currentPage - 1) * pageSize + 1;
                    @foreach (var t in PagedTeachers)
                    {
                        <tr>
                            <td class="text-center text-muted">@(idx++)</td>
                            <td><span class="code-pill">@t.Code</span></td>
                            <td>
                                <div class="t-info">
                                    <div class="t-avatar @(idx % 2 == 0 ? "purple" : "")">@t.Name.Substring(0, 1)</div>
                                    <div>
                                        <div class="t-name">@t.Name</div>
                                        <div class="t-sub">@t.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td>@t.Department</td>
                            <td>@t.Phone</td>
                            <td>@t.Email</td>
                            <td class="text-center"><span class="badge-active">Đang công tác</span></td>
                            <td class="text-end">
                                <button class="icon-btn edit" title="Chỉnh sửa">
                                    <span class="material-icons-round">edit</span>
                                </button>
                                <button class="icon-btn delete" title="Xóa">
                                    <span class="material-icons-round">delete</span>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">
                            <span class="material-icons-round" style="font-size: 48px; opacity: 0.3; display: block; margin-bottom: 0.5rem;">search_off</span>
                            Không tìm thấy giáo viên phù hợp.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Footer -->
    <div class="t-footer">
        <span class="info">Hiển thị <strong>@PagedTeachers.Count</strong> trên <strong>@FilteredTeachers.Count</strong> giáo viên</span>
        <div class="t-pagination">
            <button @onclick="() => ChangePage(currentPage - 1)" disabled="@(currentPage == 1)">
                <span class="material-icons-round">chevron_left</span>
            </button>
            @for (int i = 1; i <= TotalPages; i++)
            {
                var p = i;
                <button class="@(currentPage == p ? "active" : "")" @onclick="() => ChangePage(p)">@p</button>
            }
            <button @onclick="() => ChangePage(currentPage + 1)" disabled="@(currentPage == TotalPages)">
                <span class="material-icons-round">chevron_right</span>
            </button>
        </div>
    </div>
</div>

@code {
    class Teacher 
    { 
        public string Code { get; set; } = ""; 
        public string Name { get; set; } = ""; 
        public string Department { get; set; } = ""; 
        public string Phone { get; set; } = ""; 
        public string Email { get; set; } = ""; 
    }

    List<Teacher> teachers = new();
    string searchTerm = "";
    string filterDepartment = "";

    // Pagination Logic
    int currentPage = 1;
    int pageSize = 10;

    List<Teacher> FilteredTeachers => teachers.Where(t =>
        (string.IsNullOrEmpty(searchTerm) || t.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || t.Code.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(filterDepartment) || t.Department == filterDepartment)
    ).ToList();

    List<Teacher> PagedTeachers => FilteredTeachers.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    int TotalPages => (int)Math.Ceiling((double)FilteredTeachers.Count / pageSize);

    protected override void OnInitialized()
    {
        // Mock 50 Teachers
        for (int i = 1; i <= 50; i++)
        {
            string dept = i % 3 == 0 ? "Tổ Ngoại ngữ" : (i % 2 == 0 ? "Tổ Văn - Sử" : "Tổ Toán - Tin");
            teachers.Add(new Teacher
            {
                Code = $"GV{i:000}",
                Name = $"Giáo viên mẫu {i}",
                Department = dept,
                Phone = $"090{i:0000000}",
                Email = $"gv{i}@school.edu.vn"
            });
        }
    }

    void ChangePage(int p) { if (p >= 1 && p <= TotalPages) currentPage = p; }
    void ResetPaging() => currentPage = 1;
}
