@page "/school/permissions"
@rendermode InteractiveServer

<PageTitle>Phân quyền hệ thống</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-card-header">
            <h2 class="sm-card-title">
                <span class="material-icons-round">security</span> Nhóm quyền người dùng
            </h2>
            <button class="sm-btn sm-btn-primary">
                <span class="material-icons-round">add_moderator</span> Tạo nhóm quyền
            </button>
        </div>

        <div class="sm-table-responsive">
            <table class="sm-table">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 60px;">STT</th>
                        <th>Tên nhóm quyền</th>
                        <th>Mô tả</th>
                        <th>Quyền hạn chính</th>
                        <th class="text-center">Thành viên</th>
                        <th class="text-center" style="width: 100px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-center">1</td>
                        <td class="fw-bold sm-text-danger">Hiệu trưởng</td>
                        <td class="sm-text-muted">Hiệu trưởng, Hiệu phó</td>
                        <td><span class="sm-badge sm-badge-danger">Toàn quyền</span></td>
                        <td class="text-center">2</td>
                        <td class="text-center"><button class="sm-btn-icon"><span class="material-icons-round">settings</span></button></td>
                    </tr>
                    <tr>
                        <td class="text-center">2</td>
                        <td class="fw-bold" style="color:var(--sm-primary);">Ban Giám Hiệu</td>
                        <td class="sm-text-muted">Giám thị, Thư ký</td>
                        <td>Xem báo cáo, Duyệt đơn, Quản lý nhân sự</td>
                        <td class="text-center">3</td>
                        <td class="text-center"><button class="sm-btn-icon"><span class="material-icons-round">settings</span></button></td>
                    </tr>
                    <tr>
                        <td class="text-center">3</td>
                        <td class="fw-bold sm-text-success">Giáo viên</td>
                        <td class="sm-text-muted">Giáo viên bộ môn & chủ nhiệm</td>
                        <td>Điểm danh, Nhập điểm, Xem lớp dạy</td>
                        <td class="text-center">76</td>
                        <td class="text-center"><button class="sm-btn-icon"><span class="material-icons-round">settings</span></button></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>