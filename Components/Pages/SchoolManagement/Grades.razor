@page "/school/grades"
@rendermode InteractiveServer

<PageTitle>Quản lý Khối</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-card-header">
            <h2 class="sm-card-title">
                <span class="material-icons-round">apartment</span> Danh sách Khối học
            </h2>
            <button class="sm-btn sm-btn-primary">
                <span class="material-icons-round">add</span> Thêm khối
            </button>
        </div>

        <div class="sm-table-responsive">
            <table class="sm-table">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th>Mã Khối</th>
                        <th>Tên Khối</th>
                        <th>Trưởng khối</th>
                        <th class="text-center">Số lượng lớp</th>
                        <th class="text-center">Tổng học sinh</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <tr>
                            <td class="text-center">@i</td>
                            <td><span class="sm-badge sm-badge-primary">KHOI_@i</span></td>
                            <td class="fw-bold" style="color:var(--sm-primary);">Khối @i</td>
                            <td>Nguyễn Thị Trưởng Khối @i</td>
                            <td class="text-center"><span class="sm-badge sm-badge-warning">8 lớp</span></td>
                            <td class="text-center"><span class="sm-badge sm-badge-primary">350 em</span></td>
                            <td class="text-center">
                                <button class="sm-btn-icon"><span class="material-icons-round">settings</span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>