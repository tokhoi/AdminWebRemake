@page "/school/parents"
@rendermode InteractiveServer

<PageTitle>Học sinh - Phụ huynh</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-card-header">
            <h2 class="sm-card-title">Thông tin liên lạc gia đình</h2>
            <div style="width: 300px;">
                <div class="sm-input-icon-wrapper">
                    <span class="material-icons-round">search</span>
                    <input class="sm-form-control" placeholder="Tìm tên HS hoặc PH..." style="height: 38px;" />
                </div>
            </div>
        </div>

        <div class="sm-table-responsive">
            <table class="sm-table">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 60px;">STT</th>
                        <th>Học sinh</th>
                        <th>Lớp</th>
                        <th>Họ tên Cha</th>
                        <th>Họ tên Mẹ</th>
                        <th>SĐT Liên lạc</th>
                        <th class="text-center">App PH</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 1; i <= 8; i++)
                    {
                        <tr>
                            <td class="text-center">@i</td>
                            <td class="fw-bold" style="color:var(--sm-text-main);">Trần Văn Học Sinh @i</td>
                            <td><span class="sm-badge sm-badge-purple">1A1</span></td>
                            <td>Trần Văn Cha</td>
                            <td>Nguyễn Thị Mẹ</td>
                            <td class="sm-font-mono">090912345@i</td>
                            <td class="text-center">
                                @if (i % 3 == 0)
                                {
                                    <span class="sm-badge sm-badge-gray">Chưa cài</span>
                                }
                                else
                                {
                                    <span class="sm-badge sm-badge-success"><span class="sm-badge-dot"></span> Đã kích hoạt</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="sm-pagination">
            <span class="sm-text-muted" style="font-size: 0.85rem;">Trang 1 / 5</span>
            <div style="display:flex; gap:6px;">
                <button class="sm-page-btn active">1</button>
                <button class="sm-page-btn">2</button>
                <button class="sm-page-btn">3</button>
            </div>
        </div>
    </div>
</div> 