@page "/school/classes"
@rendermode InteractiveServer

<PageTitle>Danh sách lớp học</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-grid-4">
        <div class="sm-stat-card">
            <div class="sm-stat-label">Tổng lớp</div>
            <div class="sm-stat-value">35</div>
        </div>
        <div class="sm-stat-card">
            <div class="sm-stat-label">Tổng học sinh</div>
            <div class="sm-stat-value">1384</div>
        </div>
        <div class="sm-stat-card">
            <div class="sm-stat-label">TB Học sinh/Lớp</div>
            <div class="sm-stat-value">39</div>
        </div>
        <div class="sm-stat-card">
            <div class="sm-stat-label">GV Chủ Nhiệm</div>
            <div class="sm-stat-value">35</div>
        </div>
    </div>

    <div class="sm-card">
        <div class="sm-card-header">
            <h2 class="sm-card-title">
                <span class="material-icons-round">class</span> Danh sách lớp học
            </h2>
            <button class="sm-btn sm-btn-primary">
                <span class="material-icons-round">add</span> Thêm lớp
            </button>
        </div>

        <div class="sm-toolbar">
            <div class="sm-filter-group">
                <label class="sm-label">Khối</label>
                <select class="sm-form-select"><option>Tất cả</option></select>
            </div>
            <div class="sm-filter-group" style="flex: 2;">
                <label class="sm-label">Tìm kiếm</label>
                <div class="sm-input-icon-wrapper">
                    <span class="material-icons-round">search</span>
                    <input class="sm-form-control" placeholder="Tìm tên lớp, mã lớp..." />
                </div>
            </div>
            <button class="sm-btn sm-btn-primary">Tìm kiếm</button>
        </div>

        <div class="sm-table-responsive">
            <table class="sm-table">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 60px;">STT</th>
                        <th>Mã Lớp</th>
                        <th>Tên Lớp</th>
                        <th>Khối</th>
                        <th>GV Chủ Nhiệm</th>
                        <th class="text-center">Sĩ số</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <tr>
                            <td class="text-center">@i</td>
                            <td><span class="sm-badge sm-badge-primary">LOP_1A@i</span></td>
                            <td class="fw-bold text-primary">Lớp 1A@i</td>
                            <td><span class="sm-badge sm-badge-purple">Khối 1</span></td>
                            <td>Nguyễn Thị Chủ Nhiệm</td>
                            <td class="text-center">35</td>
                            <td class="text-center">
                                <span class="sm-badge sm-badge-success"><span class="sm-badge-dot"></span> Hoạt động</span>
                            </td>
                            <td class="text-center">
                                <button class="sm-btn-icon" title="Sửa"><span class="material-icons-round">edit</span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>