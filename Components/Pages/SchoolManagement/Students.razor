@page "/school/students"
@rendermode InteractiveServer

<PageTitle>Danh sách học sinh</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-card-header">
            <div>
                <h2 class="sm-card-title">
                    <span class="material-icons-round">school</span> Hồ sơ học sinh
                </h2>
                <span class="sm-text-muted" style="font-size: 0.9rem; margin-left: 38px;">Quản lý thông tin học sinh</span>
            </div>
            <div style="display:flex; gap:10px;">
                <button class="sm-btn sm-btn-outline"><span class="material-icons-round">upload</span> Import</button>
                <button class="sm-btn sm-btn-primary"><span class="material-icons-round">person_add</span> Thêm mới</button>
            </div>
        </div>

        <div class="sm-toolbar">
            <div class="sm-filter-group">
                <label class="sm-label">Khối</label>
                <select class="sm-form-select"><option>Tất cả</option></select>
            </div>
            <div class="sm-filter-group">
                <label class="sm-label">Lớp</label>
                <select class="sm-form-select"><option>Tất cả</option></select>
            </div>
            <div class="sm-filter-group">
                <label class="sm-label">Trạng thái</label>
                <select class="sm-form-select"><option>Đang học</option></select>
            </div>
            <div class="sm-filter-group" style="grid-column: span 2;">
                <label class="sm-label">Tìm kiếm</label>
                <div class="sm-input-icon-wrapper">
                    <span class="material-icons-round">search</span>
                    <input class="sm-form-control" placeholder="Tìm tên, mã học sinh..." />
                </div>
            </div>
            <button class="sm-btn sm-btn-primary">Tìm kiếm</button>
        </div>

        <div class="sm-table-responsive">
            <table class="sm-table">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th>Mã HS</th>
                        <th>Họ và tên</th>
                        <th>Ngày sinh</th>
                        <th>Giới tính</th>
                        <th>Lớp</th>
                        <th>Phụ huynh</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 1; i <= 10; i++)
                    {
                        <tr>
                            <td class="text-center">@i</td>
                            <td><span class="sm-font-mono sm-text-primary fw-bold">HS202500@i</span></td>
                            <td>
                                <div style="display: flex; gap: 12px; align-items: center;">
                                    <div style="width: 32px; height: 32px; border-radius: 50%; background: #eef2ff; color: #4f46e5; display: flex; align-items: center; justify-content: center; font-weight: 700;">
                                        @((i + 5).ToString()[0])
                                    </div>
                                    <span class="fw-bold">Trần Văn Học Sinh @i</span>
                                </div>
                            </td>
                            <td class="sm-text-muted">15/08/2018</td>
                            <td>@(i % 2 == 0 ? "Nam" : "Nữ")</td>
                            <td><span class="sm-badge sm-badge-purple">1A1</span></td>
                            <td class="sm-text-muted">Nguyễn Văn Phụ Huynh</td>
                            <td class="text-center">
                                <span class="sm-badge sm-badge-success"><span class="sm-badge-dot"></span> Đang học</span>
                            </td>
                            <td class="text-center">
                                <button class="sm-btn-icon" title="Xem"><span class="material-icons-round">visibility</span></button>
                                <button class="sm-btn-icon" title="Sửa"><span class="material-icons-round">edit</span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="sm-pagination">
            <span class="sm-text-muted" style="font-size:0.85rem;">Hiển thị 1 - 10 trong 1384 học sinh</span>
            <div style="display:flex; gap:6px;">
                <button class="sm-page-btn active">1</button>
                <button class="sm-page-btn">2</button>
                <button class="sm-page-btn"><span class="material-icons-round">chevron_right</span></button>
            </div>
        </div>
    </div>
</div>