@page "/school/camera"

<PageTitle>Quản lý Camera</PageTitle>

<div class="sm-page-container sm-animate-fade-in">
    <div class="sm-card">
        <div class="sm-card-header">
            <h2 class="sm-card-title">
                <span class="material-icons-round">videocam</span> Camera Điểm Danh
            </h2>
        </div>
        <div class="sm-table-responsive">
            <table class="sm-table">
                <thead>
                    <tr>
                        <th class="text-center">#</th>
                        <th class="text-center">Trạng Thái</th>
                        <th>Tên Thiết Bị</th>
                        <th>Mã Thiết Bị</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 1; i <= 6; i++)
                    {
                        <tr>
                            <td class="text-center">@i</td>
                            <td class="text-center">
                                <span class="sm-badge sm-badge-success"><span class="sm-badge-dot"></span> Online</span>
                            </td>
                            <td class="fw-bold">Camera Cổng @i</td>
                            <td><span class="sm-font-mono sm-badge sm-badge-gray">CAM-00@i</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>