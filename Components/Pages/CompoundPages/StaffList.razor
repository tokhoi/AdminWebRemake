@page "/school/staffs"
@rendermode InteractiveServer

<PageTitle>Quản lý Nhân sự</PageTitle>

<div class="stf-container animate-fade-in">
    <div class="stf-header">
        <h2 class="stf-page-title"><span class="material-icons-round">groups</span> Quản lý Giáo viên & Nhân sự</h2>
        <div class="stf-tabs">
            <div class="stf-tab @(MainTab == 1 ? "active" : "")" @onclick="() => MainTab = 1">Hồ sơ & Điểm danh</div>
            <div class="stf-tab @(MainTab == 2 ? "active" : "")" @onclick="() => MainTab = 2">Phân công chuyên môn</div>
        </div>
    </div>

    <div class="stf-body">
        @if (MainTab == 1)
        {
            <div class="stf-card animate-fade-in">
                <div class="stf-toolbar">
                    <input type="date" class="stf-input" />
                    <select class="stf-input"><option>Tất cả trạng thái</option><option>Có mặt</option><option>Vắng mặt</option></select>
                    <input type="text" class="stf-input u-flex-1" placeholder="Tìm tên giáo viên..." @bind="SearchQuery" @bind:event="oninput" />
                </div>
                <div class="stf-table-wrapper">
                    <table class="stf-table">
                        <thead><tr><th>Mã GV</th><th>Họ tên</th><th class="u-text-center">Sáng</th><th class="u-text-center">Chiều</th><th>Thao tác</th></tr></thead>
                        <tbody>
                            @foreach (var t in Staffs.Where(x => string.IsNullOrEmpty(SearchQuery) || x.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)))
                            {
                                <tr>
                                    <td><span class="stf-tag">@t.Code</span></td>
                                    <td class="fw-bold">@t.Name</td>
                                    <td class="u-text-center"><span class="stf-tag @(t.AmStatus == "Có mặt" ? "stf-tag-green" : "stf-tag-red")">@t.AmStatus</span></td>
                                    <td class="u-text-center"><span class="stf-tag @(t.PmStatus == "Có mặt" ? "stf-tag-green" : "stf-tag-red")">@t.PmStatus</span></td>
                                    <td><button class="stf-icon-btn"><span class="material-icons-round">edit</span></button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else if (MainTab == 2)
        {
            <div class="stf-card animate-fade-in">
                <div class="stf-toolbar flex-between">
                    <div class="u-flex-gap-10">
                        <button class="stf-btn @(AssignTab == 1 ? "stf-btn-primary" : "stf-btn-outline")" @onclick="() => AssignTab = 1">Chủ nhiệm</button>
                        <button class="stf-btn @(AssignTab == 2 ? "stf-btn-primary" : "stf-btn-outline")" @onclick="() => AssignTab = 2">Giảng dạy</button>
                    </div>
                    <button class="stf-btn stf-btn-success"><span class="material-icons-round">save</span> Lưu phân công</button>
                </div>
                <table class="stf-table">
                    <thead>
                        <tr><th>Lớp / Môn</th><th>Sĩ số / Số tiết</th><th>Giáo viên phụ trách</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Assignments)
                        {
                            <tr>
                                <td class="fw-bold u-text-primary">@a.ClassName</td>
                                <td>@a.StudentCount học sinh</td>
                                <td>
                                    <select class="stf-input u-w-250" @bind="a.AssignedTeacher">
                                        <option value="">-- Chưa phân công --</option>
                                        @foreach (var teacher in Staffs)
                                        {
                                            <option value="@teacher.Name">@teacher.Name</option>
                                        }
                                    </select>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private int MainTab = 1;
    private int AssignTab = 1;
    private string SearchQuery = "";

    // Data Tab 1
    class Staff { public string Code { get; set; } = ""; public string Name { get; set; } = ""; public string AmStatus { get; set; } = ""; public string PmStatus { get; set; } = ""; }
    List<Staff> Staffs = new();

    // Data Tab 2
    class Assignment { public string ClassName { get; set; } = ""; public int StudentCount { get; set; } public string AssignedTeacher { get; set; } = ""; }
    List<Assignment> Assignments = new();

    // Data Tab 3
    // class LeaveReq { public string TeacherName { get; set; } = ""; public string Date { get; set; } = ""; public string Reason { get; set; } = ""; public string Status { get; set; } = ""; }
    // List<LeaveReq> Leaves = new();

    // int PendingLeaves => Leaves.Count(x => x.Status == "Chờ duyệt");

    protected override void OnInitialized()
    {
        for (int i = 1; i <= 10; i++)
        {
            Staffs.Add(new Staff { Code = $"GV{i:000}", Name = $"Giáo Viên {i}", AmStatus = i % 4 == 0 ? "Vắng mặt" : "Có mặt", PmStatus = "Có mặt" });
            if (i <= 6) Assignments.Add(new Assignment { ClassName = $"Lớp 1A{i}", StudentCount = 35, AssignedTeacher = i % 2 == 0 ? $"Giáo Viên {i}" : "" });
        }
    }
    //     Leaves.Add(new LeaveReq { TeacherName = "Giáo Viên 4", Date = "10/03/2026", Reason = "Khám bệnh", Status = "Chờ duyệt" });
    //     Leaves.Add(new LeaveReq { TeacherName = "Giáo Viên 8", Date = "12/03/2026", Reason = "Việc gia đình", Status = "Đã duyệt" });
    // }
}

