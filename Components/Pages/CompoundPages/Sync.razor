@page "/sync"

<div class="sync-wrapper sm-animate-fade-in">
    <div class="sync-header">
        <h2 class="sync-page-title">
            <span class="material-icons-round">sync</span> Quản lý đồng bộ
        </h2>
    </div>

    <div class="sync-tabs-grid">
        @foreach (var tab in TabList)
        {
            <div class="sync-tab-card @(activeTab == tab.Id ? "active" : "")" @onclick="() => SwitchTab(tab.Id)">
                <div class="sync-card-header">
                    <span class="sync-card-title">@tab.Title</span>
                    <span class="sync-status-badge @(tab.IsSynced ? "success" : "warning")">
                        @(tab.IsSynced ? "Đã đồng bộ" : "Chưa đồng bộ")
                    </span>
                </div>
                <div class="sync-card-body">
                    <div class="sync-stat-row">
                        <span class="sync-stat-label">Số lượng</span>
                        <span class="sync-stat-value">@tab.CountStr</span>
                    </div>
                </div>
                @if (activeTab == tab.Id)
                {
                    <div class="sync-active-indicator"></div>
                }
            </div>
        }
    </div>

    <div class="sync-toolbar-panel">
        <div class="sync-filters">
            @if (activeTab == 2)
            {
                <select class="sync-select"><option>Tất cả khối</option></select>
                <select class="sync-select"><option>Tất cả lớp</option></select>
            }
            else if (activeTab == 3 || activeTab == 4)
            {
                <select class="sync-select"><option>Tất cả lớp</option></select>
            }

            <div class="sync-search-group">
                <input type="text" class="sync-input" 
                       placeholder="@GetSearchPlaceholder()" 
                       @bind="SearchTerm" 
                       @bind:event="oninput" />
                <button class="sync-btn sync-btn-primary">
                    <span class="material-icons-round">search</span> Tìm kiếm
                </button>
            </div>
        </div>

        <div class="sync-actions">
            <button class="sync-btn sync-btn-success" @onclick="() => showLoginModal = true">
                <span class="material-icons-round">cached</span> Đồng bộ dữ liệu
            </button>
        </div>
    </div>

    @if (activeTab == 2)
    {
        <div class="sync-sub-nav">
            <button class="sync-sub-link @(subTab == 1 ? "active" : "")" @onclick="() => SwitchSubTab(1)">Phân công GVCN</button>
            <button class="sync-sub-link @(subTab == 2 ? "active" : "")" @onclick="() => SwitchSubTab(2)">Phân công giảng dạy</button>
            <button class="sync-sub-link @(subTab == 3 ? "active" : "")" @onclick="() => SwitchSubTab(3)">Phân công quản lý</button>
        </div>
    }

    <div class="sync-table-container">
        <table class="sync-table">
            <thead>
                <tr>
                    <th width="40" class="text-center"><input type="checkbox" class="sync-checkbox" /></th>
                    <th width="60" class="text-center">STT</th>
                    <th>Mã định danh</th>

                    @if (activeTab == 1) // Người dùng
                    {
                        <th>Họ và tên</th>
                        <th>CCCD/CMND</th>
                        <th>Tài khoản</th>
                        <th>Nhóm quyền</th>
                        <th>Trạng thái</th>
                    }
                    else if (activeTab == 2) // Phân công
                    {
                        @if (subTab == 1)
                        {
                            <th>Giáo viên chủ nhiệm</th>
                            <th>Lớp</th>
                            <th>Học kỳ</th>
                        }
                        else if (subTab == 2)
                        {
                            <th>Giáo viên</th>
                            <th>Môn dạy</th>
                            <th>Học kỳ</th>
                        }
                        else
                        {
                            <th>Giáo viên</th>
                            <th>Chức vụ</th>
                        }
                    }
                    else if (activeTab == 3) 
                    {
                        <th>Họ và tên học sinh</th>
                        <th>Ngày sinh</th>
                        <th>Giới tính</th>
                        <th>Trạng thái</th>
                    }
                    else 
                    {
                        <th>Họ và tên học sinh</th>
                        <th>Lớp</th>
                        <th>Điểm TB HK1</th>
                        <th>Hạnh kiểm</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (activeTab == 1)
                {
                    int stt = (currentPage - 1) * pageSize + 1;
                    foreach (var item in PagedUsers)
                    {
                        <tr>
                            <td class="text-center"><input type="checkbox" class="sync-checkbox" /></td>
                            <td class="text-center text-muted">@(stt++)</td>
                            <td class="font-mono text-primary">@item.Code</td>
                            <td class="fw-600">@item.FullName</td>
                            <td>@item.CCCD</td>
                            <td>@item.Username</td>
                            <td><span class="sync-badge">@item.Role</span></td>
                            <td><span class="sync-status-dot green"></span> Hoạt động</td>
                        </tr>
                    }
                }
                
                @if (activeTab == 2)
                {
                    int stt = (currentPage - 1) * pageSize + 1;
                    foreach (var item in PagedAssignments)
                    {
                        <tr>
                            <td class="text-center"><input type="checkbox" class="sync-checkbox" /></td>
                            <td class="text-center text-muted">@(stt++)</td>
                            <td class="font-mono text-primary">GV00@(stt + 100)</td>
                            <td class="fw-600">@item.TeacherName</td>
                            @if (subTab == 1)
                            {
                                <td><span class="sync-badge-class">@item.ClassName</span></td>
                                <td>@item.Semester</td>
                            }
                            else if (subTab == 2)
                            {
                                <td>@item.Subject</td>
                                <td>@item.Semester</td>
                            }
                            else
                            {
                                <td>@item.Position</td>
                            }
                        </tr>
                    }
                }

                @if (activeTab == 3 || activeTab == 4)
                {
                    if (IsTabSynced(activeTab))
                    {
                         <tr><td colspan="10" class="text-center p-4">Dữ liệu mẫu đã đồng bộ...</td></tr>
                    }
                    else
                    {
                         <tr>
                            <td colspan="10" class="sync-empty-state">
                                <span class="material-icons-round">cloud_off</span>
                                <p>Dữ liệu chưa được đồng bộ từ Sở</p>
                                <button class="sync-btn sync-btn-primary mt-2" @onclick="() => showLoginModal = true">
                                    Đồng bộ ngay
                                </button>
                            </td>
                        </tr>
                    }
                }

                @if (TotalItems == 0 && (activeTab == 1 || activeTab == 2))
                {
                    <tr>
                        <td colspan="10" class="sync-empty-state">
                            <span class="material-icons-round">search_off</span>
                            <p>Không tìm thấy kết quả phù hợp</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (TotalItems > 0)
    {
        <div class="sync-pagination">
            <div class="sync-page-info">
                Hiển thị <b>@((currentPage - 1) * pageSize + 1) - @Math.Min(currentPage * pageSize, TotalItems)</b> 
                trên tổng <b>@TotalItems</b> bản ghi
            </div>

            <div class="sync-page-controls">
                <button class="sync-page-btn prev-next" disabled="@(currentPage == 1)" @onclick="() => ChangePage(currentPage - 1)">
                    <span class="material-icons-round">chevron_left</span>
                </button>

                @foreach (var p in GetPaginationList())
                {
                    if (p == -1)
                    {
                        <span class="sync-page-dots">...</span>
                    }
                    else
                    {
                        <button class="sync-page-btn @(currentPage == p ? "active" : "")" @onclick="() => ChangePage(p)">@p</button>
                    }
                }

                <button class="sync-page-btn prev-next" disabled="@(currentPage == TotalPages)" @onclick="() => ChangePage(currentPage + 1)">
                    <span class="material-icons-round">chevron_right</span>
                </button>
            </div>
        </div>
    }

    @if (showLoginModal)
    {
        <div class="sync-modal-overlay">
            <div class="sync-login-box" @onclick:stopPropagation="true">
                <div class="sync-login-header">
                    <h3>Đăng nhập SSO</h3>
                    <button class="sync-btn-close" @onclick="() => showLoginModal = false">×</button>
                </div>
                <div class="sync-login-body">
                    <p class="text-muted u-mb-20">
                        Đăng nhập tài khoản Sở GD&ĐT để đồng bộ dữ liệu mới nhất về hệ thống.
                    </p>

                    <div class="sync-form-group">
                        <label>Tài khoản</label>
                        <input type="text" class="sync-input w-100" placeholder="admin_so_hanoi" value="admin_demo" />
                    </div>
                    <div class="sync-form-group">
                        <label>Mật khẩu</label>
                        <input type="password" class="sync-input w-100" placeholder="••••••" value="123456" />
                    </div>

                    <div class="sync-login-actions">
                        <button class="sync-btn sync-btn-light" @onclick="() => showLoginModal = false">Hủy bỏ</button>
                        <button class="sync-btn sync-btn-primary" @onclick="HandleLoginSync" disabled="@isSyncing">
                            @if (isSyncing)
                            {
                                <span class="sync-spinner"></span> <span>Đang tải dữ liệu...</span>
                            }
                            else
                            {
                                <span>Đăng nhập & Đồng bộ</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    // --- STATE ---
    private int activeTab = 1;
    private int subTab = 1;
    private bool showLoginModal = false;
    private bool isSyncing = false;
    private string SearchTerm { get; set; } = "";

    // --- PAGINATION ---
    private int currentPage = 1;
    private int pageSize = 10;

    // --- FAKE DATA MODELS ---
    public class UserData { public string Code { get; set; } = ""; public string FullName { get; set; } = ""; public string CCCD { get; set; } = ""; public string Username { get; set; } = ""; public string Role { get; set; } = ""; }
    public class AssignData { public string TeacherName { get; set; } = ""; public string ClassName { get; set; } = ""; public string Subject { get; set; } = ""; public string Semester { get; set; } = ""; public string Position { get; set; } = ""; public int Type { get; set; } } // Type: 1=GVCN, 2=Day, 3=QL
    
    // --- DATA STORE ---
    private List<UserData> ListUsers = new();
    private List<AssignData> ListAssignments = new();

    public class SyncTabInfo
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public string CountStr { get; set; } = "";
        public bool IsSynced { get; set; }
    }

    private List<SyncTabInfo> TabList = new List<SyncTabInfo> {
        new SyncTabInfo { Id = 1, Title = "Quản lý người dùng", CountStr = "379 / 379", IsSynced = true },
        new SyncTabInfo { Id = 2, Title = "Phân công nhân sự", CountStr = "689 / 689", IsSynced = true },
        new SyncTabInfo { Id = 3, Title = "Thông tin học sinh", CountStr = "0 / 0", IsSynced = false },
        new SyncTabInfo { Id = 4, Title = "Kết quả học tập", CountStr = "0 / 0", IsSynced = false }
    };

    // --- INITIALIZATION ---
    protected override void OnInitialized()
    {
        // Tạo dữ liệu giả cho User
        for (int i = 1; i <= 50; i++)
        {
            ListUsers.Add(new UserData { 
                Code = $"GV{1000+i}", FullName = $"Nguyễn Văn Giáo Viên {i}", CCCD = $"03429900{i:D4}", Username = $"gv_demo_{i}", Role = i % 10 == 0 ? "Ban Giám Hiệu" : "Giáo Viên" 
            });
        }

        // Tạo dữ liệu giả cho Phân công
        for (int i = 1; i <= 50; i++)
        {
            ListAssignments.Add(new AssignData { TeacherName = $"Trần Thị Cô {i}", ClassName = $"{6 + (i%4)}A{i%3 + 1}", Semester = "Học kỳ 1", Type = 1 }); // GVCN
            ListAssignments.Add(new AssignData { TeacherName = $"Lê Văn Thầy {i}", Subject = "Toán, Lý", Semester = "Học kỳ 1", Type = 2 }); // Giảng dạy
            if(i <= 5) ListAssignments.Add(new AssignData { TeacherName = $"Phạm Văn Sếp {i}", Position = "Hiệu trưởng", Type = 3 }); // Quản lý
        }
    }

    // --- COMPUTED PROPERTIES (FILTERING) ---
    private IEnumerable<UserData> FilteredUsers => ListUsers.Where(u => string.IsNullOrEmpty(SearchTerm) || u.FullName.ToLower().Contains(SearchTerm.ToLower()));
    private IEnumerable<AssignData> FilteredAssignments => ListAssignments.Where(a => a.Type == subTab && (string.IsNullOrEmpty(SearchTerm) || a.TeacherName.ToLower().Contains(SearchTerm.ToLower())));

    private int TotalItems => activeTab switch {
        1 => FilteredUsers.Count(),
        2 => FilteredAssignments.Count(),
        _ => 0
    };

    private int TotalPages => (int)Math.Ceiling((double)TotalItems / pageSize);

    // Lấy dữ liệu cho trang hiện tại
    private List<UserData> PagedUsers => FilteredUsers.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    private List<AssignData> PagedAssignments => FilteredAssignments.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();

    // --- ACTIONS ---
    private bool IsTabSynced(int tabId) => TabList.FirstOrDefault(t => t.Id == tabId)?.IsSynced ?? false;

    private void ChangePage(int newPage) { if (newPage >= 1 && newPage <= TotalPages) currentPage = newPage; }
    
    private void SwitchTab(int tabIndex) { 
        activeTab = tabIndex; currentPage = 1; SearchTerm = "";
        // Tự động chuyển subtab về 1 nếu sang tab Phân công
        if (activeTab == 2) subTab = 1;
    }
    
    private void SwitchSubTab(int index) { subTab = index; currentPage = 1; }

    private string GetSearchPlaceholder() => activeTab switch {
        1 => "Tìm theo tên, tài khoản...",
        2 => "Tìm giáo viên...",
        _ => "Tìm học sinh..."
    };

    private async Task HandleLoginSync()
    {
        isSyncing = true;
        await Task.Delay(2000); // Giả lập mạng chậm
        
        // Mô phỏng đồng bộ thành công cho Tab 3 & 4
        var tab3 = TabList.FirstOrDefault(t => t.Id == 3);
        if(tab3 != null) { tab3.IsSynced = true; tab3.CountStr = "1200 / 1200"; }
        
        var tab4 = TabList.FirstOrDefault(t => t.Id == 4);
        if(tab4 != null) { tab4.IsSynced = true; tab4.CountStr = "1200 / 1200"; }

        isSyncing = false;
        showLoginModal = false;
        StateHasChanged();
    }

    private List<int> GetPaginationList()
    {
        var pages = new List<int>();
        if (TotalPages <= 1) return pages;
        pages.Add(1);
        int start = Math.Max(2, currentPage - 1);
        int end = Math.Min(TotalPages - 1, currentPage + 1);
        if (start > 2) pages.Add(-1);
        for (int i = start; i <= end; i++) pages.Add(i);
        if (end < TotalPages - 1) pages.Add(-1);
        if (TotalPages > 1) pages.Add(TotalPages);
        return pages;
    }
}



