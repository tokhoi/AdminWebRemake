@page "/bantru"
@rendermode InteractiveServer

<PageTitle>Quản lý học sinh bán trú - TitKul</PageTitle>

<div class="tk-wrapper">
    <div class="tk-container">

        @* HEADER *@
        <div class="tk-card tk-p-4 tk-mb-4 flex-between">
            <h2 class="tk-page-title m-0 flex-align-center gap-2">
                <span class="material-symbols-outlined tk-text-blue u-font-28">restaurant_menu</span>
                Quản lý học sinh bán trú
            </h2>
            <div class="tk-actions">
                <button class="tk-btn tk-btn-outline-blue" @onclick="ReloadData">
                    <span class="material-symbols-outlined">sync</span> Đồng bộ
                </button>
                <button class="tk-btn tk-btn-blue" @onclick="SaveAllSelected" disabled="@(!SelectedStudents.Any())">
                    <span class="material-symbols-outlined">save</span> Lưu tất cả (@SelectedStudents.Count)
                </button>
            </div>
        </div>

        @* Bộ Lọc *@
        <div class="tk-card tk-p-4 tk-mb-4 tk-filter-bar">
            <div class="tk-form-group">
                <label class="tk-label">Năm học</label>
                <select class="tk-select" @bind="FilterNamHoc" @bind:after="ResetPage">
                    <option value="2025-2026">2025-2026</option>
                    <option value="2024-2025">2024-2025</option>
                </select>
            </div>

            <div class="tk-form-group">
                <label class="tk-label">Lớp</label>
                <select class="tk-select" @bind="FilterLop" @bind:after="ResetPage">
                    <option value="">-- Tất Cả --</option>
                    @foreach (var l in MockClasses)
                    {
                        <option value="@l">@l</option>
                    }
                </select>
            </div>

            <div class="tk-form-group">
                <label class="tk-label">Hình thức học</label>
                <select class="tk-select" @bind="FilterHinhThuc" @bind:after="ResetPage">
                    <option value="0">Tất cả</option>
                    <option value="2">Bán trú</option>
                    <option value="1">Bình thường</option>
                </select>
            </div>

            <div class="tk-form-group flex-fill">
                <label class="tk-label">Tìm kiếm</label>
                <div class="tk-search-wrapper">
                    <span class="material-symbols-outlined tk-search-icon">search</span>
                    <input class="tk-input-search" placeholder="Nhập tên học sinh hoặc mã định danh..."
                           @bind="SearchTerm" @bind:event="oninput" />
                </div>
            </div>
        </div>

        @* Bảng Dữ Liệu *@
        <div class="tk-card">
            <div class="tk-table-responsive">
                <table class="tk-table">
                    <thead>
                        <tr>
                            <th class="tk-text-center u-width-50">
                                <input type="checkbox" class="tk-checkbox" checked="@IsSelectAll" @onchange="ToggleSelectAll" />
                            </th>
                            <th class="tk-text-center u-width-60">STT</th>
                            <th class="u-width-100">Lớp</th>
                            <th>Họ và Tên / Mã định danh</th>
                            <th class="tk-text-center u-width-120">Ngày sinh</th>
                            <th class="tk-text-center u-width-100">Giới tính</th>
                            <th class="u-w-180">Hình thức học tập</th>
                            <th class="tk-text-center u-width-100">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr><td colspan="8" class="tk-text-center p-4">Đang tải dữ liệu...</td></tr>
                        }
                        else if (PagedList.Any())
                        {
                            int stt = (CurrentPage - 1) * PageSize + 1;
                            foreach (var item in PagedList)
                            {
                                <tr class="@(item.IsChecked ? "tk-row-selected" : "")">
                                    <td class="tk-text-center">
                                        <input type="checkbox" class="tk-checkbox" @bind="item.IsChecked" />
                                    </td>
                                    <td class="tk-text-center tk-text-muted">@(stt++)</td>
                                    <td><span class="tk-badge tk-badge-gray">@item.TenLop</span></td>
                                    <td>
                                        <div class="tk-font-bold tk-text-dark">@item.HoTen</div>
                                        <div class="tk-text-xs tk-text-muted">@item.MaHsSo</div>
                                    </td>
                                    <td class="tk-text-center">@item.NgaySinh.ToString("dd/MM/yyyy")</td>
                                    <td class="tk-text-center">@item.Phai</td>
                                    <td>
                                        <select class="tk-select-sm @(item.IdHinhThucHocTap == 2 ? "tk-select-bantru" : "")" @bind="item.IdHinhThucHocTap">
                                            <option value="2">Bán trú</option>
                                            <option value="1">Bình thường</option>
                                            <option value="0">-- Chưa chọn --</option>
                                        </select>
                                    </td>
                                    <td class="tk-text-center">
                                        <button class="tk-btn-icon tk-btn-icon-blue" @onclick="() => SaveStudent(item)" title="Lưu">
                                            <span class="material-symbols-outlined">save</span>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="tk-text-center tk-p-6">
                                    <span class="material-symbols-outlined tk-text-gray-300 u-font-48">inbox</span>
                                    <p class="tk-text-muted mt-2">Không tìm thấy học sinh nào phù hợp</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* PHÂN TRANG *@
            @if (FilteredList.Count > 0)
            {
                <div class="tk-pagination-bar">
                    <span class="tk-text-sm tk-text-muted">
                        Hiển thị <b>@PagedList.Count</b> trên tổng số <b>@FilteredList.Count</b> học sinh
                    </span>
                    <div class="tk-pagination-controls">
                        <button class="tk-page-btn" disabled="@(CurrentPage == 1)" @onclick="() => ChangePage(CurrentPage - 1)">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </button>

                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            var p = i;
                            if (p == 1 || p == TotalPages || Math.Abs(p - CurrentPage) <= 1)
                            {
                                <button class="tk-page-btn @(CurrentPage == p ? "active" : "")" @onclick="() => ChangePage(p)">@p</button>
                            }
                            else if (p == CurrentPage - 2 || p == CurrentPage + 2)
                            {
                                <span class="tk-page-dots">...</span>
                            }
                        }

                        <button class="tk-page-btn" disabled="@(CurrentPage == TotalPages)" @onclick="() => ChangePage(CurrentPage + 1)">
                            <span class="material-symbols-outlined">chevron_right</span>
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* TOAST THÔNG BÁO *@
@if (showToast)
{
    <div class="tk-toast @toastClass">
        <span class="material-symbols-outlined">check_circle</span>
        <span>@toastMessage</span>
    </div>
}
@code {
    // --- MOCK MODELS ---
    public class StudentVM
    {
        public bool IsChecked { get; set; } = false;
        public string MaHsSo { get; set; } = "";
        public string HoTen { get; set; } = "";
        public string TenLop { get; set; } = "";
        public DateTime NgaySinh { get; set; }
        public string Phai { get; set; } = "Nam";
        public int IdHinhThucHocTap { get; set; } = 1;
    }

    // --- STATE ---
    private List<StudentVM> AllStudents = new();
    private List<string> MockClasses = new() { "1A1", "1A2", "2A1", "3A1", "4A1", "5A1" };
    private bool isLoading = false;

    // Filters
    private string FilterNamHoc { get; set; } = "2025-2026";
    private string FilterLop { get; set; } = "";
    private int FilterHinhThuc { get; set; } = 0;

    private string _searchTerm = "";
    private string SearchTerm
    {
        get => _searchTerm;
        set { _searchTerm = value; CurrentPage = 1; }
    }

    // Pagination
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 10;

    // Computed Lists
    private List<StudentVM> FilteredList => AllStudents
        .Where(x =>
            (string.IsNullOrEmpty(FilterLop) || x.TenLop == FilterLop) &&
            (FilterHinhThuc == 0 || x.IdHinhThucHocTap == FilterHinhThuc) &&
            (string.IsNullOrEmpty(SearchTerm) || x.HoTen.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) || x.MaHsSo.Contains(SearchTerm))
        ).ToList();

    private List<StudentVM> PagedList => FilteredList.Skip((CurrentPage - 1) * PageSize).Take(PageSize).ToList();
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)FilteredList.Count / PageSize));

    // Checkbox Logic
    private List<StudentVM> SelectedStudents => FilteredList.Where(x => x.IsChecked).ToList();
    private bool IsSelectAll => PagedList.Any() && PagedList.All(x => x.IsChecked);

    // Toast Logic
    private bool showToast = false;
    private string toastMessage = "";
    private string toastClass = "tk-toast-success";

    // --- INIT ---
    protected override void OnInitialized()
    {
        GenerateMockData();
    }

    private void GenerateMockData()
    {
        AllStudents.Clear();
        var random = new Random();
        for (int i = 1; i <= 65; i++)
        {
            AllStudents.Add(new StudentVM
            {
                MaHsSo = $"HS{DateTime.Now.Year}{i:D4}",
                HoTen = $"Nguyễn Văn Học Sinh {i}",
                TenLop = MockClasses[random.Next(MockClasses.Count)],
                NgaySinh = new DateTime(2016, random.Next(1, 13), random.Next(1, 28)),
                Phai = i % 2 == 0 ? "N?" : "Nam",
                IdHinhThucHocTap = random.Next(1, 3)
            });
        }
    }

    private async Task ReloadData()
    {
        isLoading = true;
        await Task.Delay(500); 
        GenerateMockData();
        FilterLop = "";
        FilterHinhThuc = 0;
        SearchTerm = "";
        CurrentPage = 1;
        isLoading = false;
    }

    // --- LOGIC ---
    private void ToggleSelectAll(ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        foreach (var item in PagedList)
        {
            item.IsChecked = isChecked;
        }
    }

    private void ResetPage()
    {
        CurrentPage = 1;
    }

    private void ChangePage(int p)
    {
        if (p >= 1 && p <= TotalPages) CurrentPage = p;
    }

    private async Task SaveStudent(StudentVM item)
    {
        await ShowToastNoti($"Đã lưu hình thức học tập của {item.HoTen}");
    }

    private async Task SaveAllSelected()
    {
        int count = SelectedStudents.Count;
        foreach (var item in SelectedStudents)
        {
            item.IsChecked = false; 
        }
        await ShowToastNoti($"Đ? lưu thành công {count} học sinh!");
    }

    private async Task ShowToastNoti(string msg)
    {
        toastMessage = msg;
        showToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        showToast = false;
        StateHasChanged();
    }
}



