@page "/daily-activity"
@rendermode InteractiveServer

<PageTitle>Hoạt động hằng ngày - TitKul</PageTitle>

<div class="tk-da-wrapper">
    <div class="tk-da-container">
        <div class="tk-da-card tk-da-toolbar flex-between">
            <h2 class="tk-da-page-title m-0">Bảng tin trường học</h2>
        </div>

        <div class="tk-da-layout">
            <div class="tk-da-main">
                <div class="tk-da-card tk-da-creator">
                    <div class="tk-da-creator-top">
                        <div class="tk-da-avatar">A</div>
                        <textarea class="tk-da-input" placeholder="Bạn muốn chia sẻ điều gì với trường hôm nay?" @bind="newPostContent" @bind:event="oninput"></textarea>
                    </div>

                    @if (previewImages.Any())
                    {
                        <div class="tk-da-preview-container">
                            @foreach (var img in previewImages)
                            {
                                <div class="tk-da-preview-item">
                                    <img src="@img" alt="Preview" />
                                    <button class="tk-da-preview-remove" @onclick="() => RemovePreviewImage(img)">
                                        <span class="material-symbols-outlined">close</span>
                                    </button>
                                </div>
                            }
                        </div>
                    }

                    <div class="tk-da-creator-bottom">
                        <div class="tk-da-actions">
                            <label for="image-upload" class="tk-da-btn-action tk-text-green u-cursor-pointer">
                                <span class="material-symbols-outlined">image</span> Ảnh/Video
                            </label>
                            <InputFile id="image-upload" OnChange="HandleImageUpload" accept="image/*" multiple class="u-hidden" />

                            <div class="u-relative">
                                <button class="tk-da-btn-action tk-text-orange" @onclick="ToggleEmojiPicker">
                                    <span class="material-symbols-outlined">mood</span> Cảm xúc
                                </button>

                                @if (showEmojiPicker)
                                {
                                    <div class="tk-da-emoji-picker">
                                        @foreach (var emoji in popularEmojis)
                                        {
                                            <span class="tk-da-emoji-item" @onclick="() => InsertEmoji(emoji)">@emoji</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <button class="tk-da-btn-submit" @onclick="CreatePost" disabled="@(string.IsNullOrWhiteSpace(newPostContent) && !previewImages.Any())">
                            Đăng bài
                        </button>
                    </div>
                </div>

                @foreach (var post in Posts)
                {
                    <div class="tk-da-card tk-da-post">
                        <div class="tk-da-post-header">
                            <div class="tk-da-post-author">
                                <div class="tk-da-avatar tk-avatar-blue">@post.AuthorName.Substring(0, 1)</div>
                                <div>
                                    <h4 class="tk-da-author-name">@post.AuthorName</h4>
                                    <p class="tk-da-post-time">@post.TimeAgo</p>
                                </div>
                            </div>
                            <button class="tk-da-btn-icon tk-text-red" title="Xóa bài viết" @onclick="() => RequestDeletePost(post)">
                                <span class="material-symbols-outlined">delete</span>
                            </button>
                        </div>

                        <div class="tk-da-post-body">
                            <p>@post.Content</p>
                            @if (post.Images.Any())
                            {
                                <div class="tk-da-images @(post.Images.Count > 1 ? "grid-2" : "")">
                                    @foreach (var img in post.Images)
                                    {
                                        <img src="@img" alt="Post image" />
                                    }
                                </div>
                            }
                        </div>

                        <div class="tk-da-post-stats flex-between">
                            <span class="tk-da-stat-text">
                                <span class="material-symbols-outlined tk-text-blue u-fill-icon-16">thumb_up</span>
                                @post.Likes lượt thích
                            </span>
                            <span class="tk-da-stat-text cursor-pointer" @onclick="() => post.ShowComments = !post.ShowComments">
                                @post.Comments.Count bình luận
                            </span>
                        </div>

                        <div class="tk-da-post-actions">
                            <button class="tk-da-action-btn @(post.IsLiked ? "liked" : "")" @onclick="() => ToggleLike(post)">
                                <span class="material-symbols-outlined">thumb_up</span> Thích
                            </button>
                            <button class="tk-da-action-btn" @onclick="() => post.ShowComments = !post.ShowComments">
                                <span class="material-symbols-outlined">chat_bubble_outline</span> Bình luận
                            </button>
                        </div>

                        @if (post.ShowComments)
                        {
                            <div class="tk-da-comments-section">
                                @foreach (var cmt in post.Comments)
                                {
                                    <div class="tk-da-comment-item">
                                        <div class="tk-da-avatar-sm">@cmt.Author.Substring(0, 1)</div>
                                        <div class="tk-da-comment-box">
                                            <b>@cmt.Author</b>
                                            <p>@cmt.Text</p>
                                        </div>
                                    </div>
                                }
                                <div class="tk-da-comment-input-area">
                                    <div class="tk-da-avatar-sm">A</div>
                                    <div class="tk-da-input-wrapper">
                                        <input type="text" placeholder="Viết bình luận..." @bind="post.NewCommentText" @onkeyup="@(e => HandleCommentSubmit(e, post))" />
                                        <button class="tk-da-send-btn" @onclick="() => AddComment(post)"><span class="material-symbols-outlined">send</span></button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="tk-da-sidebar">
                <div class="tk-da-card">
                    <div class="tk-da-card-header">
                        <h3 class="tk-da-sidebar-title"><span class="material-symbols-outlined tk-text-orange">cake</span> Sinh nhật hôm nay</h3>
                    </div>
                    <div class="tk-da-card-body">
                        <div class="tk-da-sidebar-item">
                            <div class="tk-da-avatar-sm tk-bg-orange">H</div>
                            <div>
                                <p class="tk-da-font-bold">Nguyễn Văn Hải</p>
                                <p class="tk-da-text-sm tk-text-muted">Học sinh lớp 4A2</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tk-da-card">
                    <div class="tk-da-card-header">
                        <h3 class="tk-da-sidebar-title"><span class="material-symbols-outlined tk-text-blue">event</span> Sự kiện sắp tới</h3>
                    </div>
                    <div class="tk-da-card-body">
                        <div class="tk-da-sidebar-item">
                            <div class="tk-da-date-box tk-bg-blue"><b>26</b><span>T3</span></div>
                            <div>
                                <p class="tk-da-font-bold">Hội khỏe Phù Đổng</p>
                                <p class="tk-da-text-sm tk-text-muted">Sân vận động trường</p>
                            </div>
                        </div>
                        <div class="tk-da-sidebar-item mt-2">
                            <div class="tk-da-date-box tk-bg-green"><b>30</b><span>T4</span></div>
                            <div>
                                <p class="tk-da-font-bold">Nghỉ lễ 30/4 - 1/5</p>
                                <p class="tk-da-text-sm tk-text-muted">Toàn trường</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (showDeleteModal)
{
    <div class="tk-modal-overlay">
        <div class="tk-modal-box">
            <h3 class="tk-modal-title"><span class="material-symbols-outlined tk-text-red">warning</span> Xác nhận xóa</h3>
            <p class="tk-modal-text">Bạn có chắc chắn muốn xóa bài viết này không? Hành động này không thể hoàn tác.</p>
            <div class="tk-modal-actions">
                <button class="tk-btn-cancel" @onclick="CancelDelete">Hủy bỏ</button>
                <button class="tk-btn-confirm-delete" @onclick="ConfirmDelete">Xóa bài viết</button>
            </div>
        </div>
    </div>
}

@if (showToast)
{
    <div class="tk-toast @toastClass">
        <span class="material-symbols-outlined">@toastIcon</span>
        <span>@toastMessage</span>
    </div>
}

@code {
    private string newPostContent = "";
    private readonly List<string> previewImages = new();
    private bool showEmojiPicker;
    private readonly string[] popularEmojis =
    {
        "😀", "😄", "😍", "🥰", "👏", "🎉",
        "🌟", "📚", "🎨", "⚽", "💐", "❤️",
        "👍", "😊", "🥳", "🤝", "💡", "🎯"
    };

    private bool showDeleteModal;
    private Post? postToDelete;

    private bool showToast;
    private string toastMessage = "";
    private string toastClass = "";
    private string toastIcon = "";

    private sealed class Comment
    {
        public string Author { get; set; } = string.Empty;
        public string Text { get; set; } = string.Empty;
    }

    private sealed class Post
    {
        public string Id { get; set; } = Guid.NewGuid().ToString();
        public string AuthorName { get; set; } = string.Empty;
        public string TimeAgo { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public List<string> Images { get; set; } = new();
        public int Likes { get; set; }
        public bool IsLiked { get; set; }
        public bool ShowComments { get; set; }
        public string NewCommentText { get; set; } = string.Empty;
        public List<Comment> Comments { get; set; } = new();
    }

    private readonly List<Post> Posts = new();

    protected override void OnInitialized()
    {
        Posts.Add(new Post
        {
            AuthorName = "Cô Trần Uyên",
            TimeAgo = "2 giờ trước",
            Likes = 45,
            Content = "Sáng nay các con lớp 1A1 đã có một buổi trải nghiệm trồng cây rất vui và ý nghĩa. Cảm ơn các bậc phụ huynh đã hỗ trợ các con hoàn thành tốt nhiệm vụ nhé! 🌱💚",
            Images = { "https://images.unsplash.com/photo-1588075592446-265fd1e6e76f?auto=format&fit=crop&q=80&w=500" },
            Comments = { new Comment { Author = "Phụ huynh bé Bo", Text = "Tuyệt vời quá cô ơi!" } }
        });

        Posts.Add(new Post
        {
            AuthorName = "Nhà trường",
            TimeAgo = "Hôm qua lúc 15:30",
            Likes = 120,
            Content = "THÔNG BÁO: Lịch nghỉ lễ Giải phóng miền Nam 30/4 và Quốc tế Lao động 1/5.\nCác em học sinh sẽ được nghỉ từ ngày 29/04 đến hết ngày 03/05. Chúc các gia đình có kỳ nghỉ vui vẻ!"
        });
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        const int maxAllowedFiles = 4;
        foreach (var file in e.GetMultipleFiles(maxAllowedFiles))
        {
            var resizedImage = await file.RequestImageFileAsync(file.ContentType, 800, 800);
            var buffer = new byte[resizedImage.Size];
            await resizedImage.OpenReadStream().ReadAsync(buffer);
            var imageBase64 = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";
            previewImages.Add(imageBase64);
        }
    }

    private void RemovePreviewImage(string img) => previewImages.Remove(img);

    private async Task CreatePost()
    {
        if (string.IsNullOrWhiteSpace(newPostContent) && !previewImages.Any())
        {
            return;
        }

        Posts.Insert(0, new Post
        {
            AuthorName = "Admin",
            TimeAgo = "Vừa xong",
            Content = newPostContent,
            Likes = 0,
            Images = new List<string>(previewImages)
        });

        newPostContent = string.Empty;
        previewImages.Clear();

        await ShowToastNoti("Đăng bài viết thành công!", "success");
    }

    private void RequestDeletePost(Post p)
    {
        postToDelete = p;
        showDeleteModal = true;
    }

    private void CancelDelete()
    {
        showDeleteModal = false;
        postToDelete = null;
    }

    private async Task ConfirmDelete()
    {
        if (postToDelete is not null)
        {
            Posts.Remove(postToDelete);
            postToDelete = null;
        }

        showDeleteModal = false;
        await ShowToastNoti("Đã xóa bài viết", "danger");
    }

    private void ToggleLike(Post p)
    {
        p.IsLiked = !p.IsLiked;
        p.Likes += p.IsLiked ? 1 : -1;
    }

    private void AddComment(Post p)
    {
        if (string.IsNullOrWhiteSpace(p.NewCommentText))
        {
            return;
        }

        p.Comments.Add(new Comment { Author = "Admin", Text = p.NewCommentText });
        p.NewCommentText = string.Empty;
    }

    private void HandleCommentSubmit(KeyboardEventArgs e, Post p)
    {
        if (e.Key == "Enter")
        {
            AddComment(p);
        }
    }

    private void ToggleEmojiPicker() => showEmojiPicker = !showEmojiPicker;

    private void InsertEmoji(string emoji)
    {
        newPostContent += emoji;
        showEmojiPicker = false;
    }

    private async Task ShowToastNoti(string message, string type)
    {
        toastMessage = message;
        toastClass = type == "success" ? "tk-toast-success" : "tk-toast-danger";
        toastIcon = type == "success" ? "check_circle" : "delete";
        showToast = true;
        StateHasChanged();

        await Task.Delay(3000);

        showToast = false;
        StateHasChanged();
    }
}



