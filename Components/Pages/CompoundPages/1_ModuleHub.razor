@page "/apps"
@inject NavigationManager NavManager
@rendermode InteractiveServer

<PageTitle>Hệ sinh thái ứng dụng</PageTitle>

<div class="hub-wrapper animate-fade-in">
    <div class="hub-content">
        <div class="hub-toolbar">
            <div class="toolbar-info">
                <h2 class="m-0 flex-align-center gap-2">
                    <span class="material-icons-round cp-title-icon">create</span>
                    Quản lý ứng dụng và hệ thống
                </h2>
                <p class="text-muted">Các chức năng quản lý học vụ, truyền thông, nhân sự và cấu hình hệ thống.</p>
            </div>
        </div>

        <div class="hub-category">
            <h2 class="category-title"><span class="material-icons-round">school</span> Học vụ và lớp học</h2>
            <div class="hub-grid-vertical">

                <div class="hub-v-card" @onclick='() => NavigateTo("/school/students")'>
                    <div class="v-card-icon cp-icon-tone-secondary">
                        <span class="material-icons-round">account_tree</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Khối - Lớp - Học sinh</h3>
                        <p>Tra cứu cây tổ chức theo khối lớp, hồ sơ học sinh và phụ huynh.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/school/meal-plan")'>
                    <div class="v-card-icon cp-icon-tone-secondary">
                        <span class="material-icons-round">restaurant_menu</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Thực đơn tuần</h3>
                        <p>Theo dõi thực đơn bán trú theo từng ngày, từng bữa và nhập nhanh từ file Excel.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/school/up-menu")'>
                    <div class="v-card-icon cp-icon-tone-secondary">
                        <span class="material-icons-round">menu_book</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Quản lý thực đơn</h3>
                        <p>Soạn cuốn menu món ăn cho phụ huynh chọn trên miniapp, theo tuần áp dụng và ngày chốt món.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/school/ordered-meals")'>
                    <div class="v-card-icon cp-icon-tone-secondary">
                        <span class="material-icons-round">receipt_long</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Thực đơn đã đặt</h3>
                        <p>Xem chi tiết thực đơn phụ huynh đã chốt cho từng bé sau ngày khóa món trên miniapp.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/school/teaching-plan")'>
                    <div class="v-card-icon cp-icon-tone-secondary">
                        <span class="material-icons-round">description</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Kế hoạch giảng dạy</h3>
                        <p>Import file Word kế hoạch, tự tách tuần/ngày và rà soát tiến độ chuẩn bị bài dạy.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hub-category">
            <h2 class="category-title"><span class="material-icons-round">groups</span> Truyền thông và nhân sự</h2>
            <div class="hub-grid-vertical">
                <div class="hub-v-card" @onclick='() => NavigateTo("/school/staffs")'>
                    <div class="v-card-icon cp-icon-tone-primary">
                        <span class="material-icons-round">badge</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Quản lý nhân sự</h3>
                        <p>Quản lý hồ sơ giáo viên, phân công chuyên môn và theo dõi nhân sự.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/school/notices")'>
                    <div class="v-card-icon cp-icon-tone-primary">
                        <span class="material-icons-round">campaign</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Thông báo</h3>
                        <p>Đăng thông báo chung, báo bài dặn dò và truyền thông nội bộ.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hub-category">
            <h2 class="category-title"><span class="material-icons-round">settings_suggest</span> Quản trị hệ thống</h2>
            <div class="hub-grid-vertical">
                <div class="hub-v-card" @onclick='() => NavigateTo("/school/permissions")'>
                    <div class="v-card-icon cp-icon-tone-muted">
                        <span class="material-icons-round">admin_panel_settings</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Vai trò và phân quyền</h3>
                        <p>Thiết lập quyền truy cập theo vị trí để đảm bảo an toàn dữ liệu.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/school/settings")'>
                    <div class="v-card-icon cp-icon-tone-neutral">
                        <span class="material-icons-round">settings</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Cài đặt hệ thống</h3>
                        <p>Cấu hình thông tin trường, thời gian hệ thống và thiết bị liên quan.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/training/sem-sub")'>
                    <div class="v-card-icon cp-icon-tone-neutral">
                        <span class="material-symbols-outlined">subject</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Học kỳ và môn học</h3>
                        <p>Quản lý danh mục học kỳ, môn học áp dụng trong năm học.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card" @onclick='() => NavigateTo("/sync")'>
                    <div class="v-card-icon cp-icon-tone-neutral">
                        <span class="material-symbols-outlined">sync</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Đồng bộ dữ liệu</h3>
                        <p>Đồng bộ dữ liệu từ hệ thống ngoài về hệ thống quản trị nhà trường.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private void NavigateTo(string url)
    {
        NavManager.NavigateTo(url);
    }
}
