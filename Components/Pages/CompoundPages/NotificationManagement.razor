@page "/school/notices"
@rendermode InteractiveServer

<PageTitle>Thông báo & Truyền thông</PageTitle>

<div class="nt-page-container nt-animate-fade-in" style="padding: 1.5rem; background: #f4f7f9; min-height: 100vh;">

    <div class="nt-page-header">
        <div class="nt-header-icon">
            <span class="material-icons-round">campaign</span>
        </div>
        <div class="nt-header-text">
            <h2 class="nt-title">Trung tâm Truyền thông</h2>
            <p class="nt-subtitle">Quản lý các thông báo, báo bài và thực đơn gửi đến Phụ huynh.</p>
        </div>
    </div>
    <div class="nt-tabs-wrapper">
        <div class="nt-tab @(ActiveTab == 1 ? "active" : "")" @onclick="() => ActiveTab = 1">
            Thông báo chung
        </div>
        <div class="nt-tab @(ActiveTab == 2 ? "active" : "")" @onclick="() => ActiveTab = 2">
            Báo bài & Dặn dò
        </div>
        <div class="nt-tab @(ActiveTab == 3 ? "active" : "")" @onclick="() => ActiveTab = 3">
            Thực đơn tuần
        </div>
    </div>

    <div class="nt-tab-content">
        @if (ActiveTab == 1)
        {
            <AdminWebRemake.Components.Pages.Notification.GeneralNotice />
        }
        else if (ActiveTab == 2)
        {
            <AdminWebRemake.Components.Pages.Notification.AssignmentNotice />
        }
        else if (ActiveTab == 3)
        {
            <AdminWebRemake.Components.Pages.Notification.MenuNotice />
        }
    </div>

</div>

@code {
    private int ActiveTab = 1;
}

<style>
    .nt-page-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        background: #ffffff;
        padding: 1.25rem 1.5rem;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
        margin-bottom: 1.5rem;
        border-left: 4px solid #1b6ec2; 
    }

    .nt-header-icon {
        width: 50px;
        height: 50px;
        background: #eff6ff; 
        color: #1b6ec2; 
        border-radius: 12px;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-shrink: 0;
    }

        .nt-header-icon span {
            font-size: 26px;
        }

    .nt-header-text {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .nt-title {
        margin: 0 0 0.25rem 0;
        font-size: 1.3rem;
        font-weight: 800;
        color: #1e293b; 
        letter-spacing: -0.5px;
    }

    .nt-subtitle {
        margin: 0;
        font-size: 0.9rem;
        color: #64748b;
        font-weight: 500;
    }
    .nt-tabs-wrapper {
        display: flex;
        gap: 2rem;
        border-bottom: 2px solid #e5e7eb;
        margin-bottom: 1.5rem;
    }

    .nt-tab {
        padding: 0.75rem 0.5rem;
        font-weight: 600;
        color: #6b7280;
        cursor: pointer;
        border-bottom: 3px solid transparent;
        transform: translateY(2px);
        transition: all 0.2s ease;
        font-size: 0.95rem;
    }

        .nt-tab:hover {
            color: #1b6ec2;
        }

        .nt-tab.active {
            color: #1b6ec2;
            border-bottom-color: #1b6ec2;
        }
</style>