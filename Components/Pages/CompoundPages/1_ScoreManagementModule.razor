@page "/score"
@inject NavigationManager NavManager
@rendermode InteractiveServer

<PageTitle>Quản lý nhập điểm</PageTitle>

<div class="hub-wrapper score-module animate-fade-in">
    <div class="hub-content score-module__content">
        <div class="hub-toolbar score-module__toolbar">
            <div class="toolbar-info score-module__intro">
                <h2 class="m-0 flex-align-center gap-2">
                    <span class="material-icons-round cp-title-icon score-module__title-icon">create</span>
                    Quản lý điểm và đánh giá
                </h2>
                <p class="text-muted">Lựa chọn chức năng nhập liệu và cấu hình điểm số theo cấp học.</p>
            </div>
            <div class="toolbar-filter score-module__filter">
                <label>Góc nhìn cấp học (demo):</label>
                <select class="hub-select" @bind="CurrentLevel">
                    <option value="02">Cấp Tiểu học</option>
                    <option value="03">Cấp THCS</option>
                    <option value="04">Cấp THPT</option>
                </select>
            </div>
        </div>

        <div class="hub-category score-module__section">
            <h2 class="category-title score-module__section-title"><span class="material-icons-round">border_color</span> Chức năng nhập liệu</h2>
            <div class="hub-grid-vertical">
                @if (CurrentLevel == "02")
                {
                    <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/ratingsubject")'>
                        <div class="v-card-icon cp-icon-tone-primary">
                            <span class="material-icons-round">menu_book</span>
                        </div>
                        <div class="v-card-body">
                            <h3>Đánh giá định kỳ</h3>
                            <p>Nhập điểm và nhận xét định kỳ theo quy định hiện hành.</p>
                        </div>
                        <div class="v-card-footer">
                            <span>Mở phân hệ</span>
                            <span class="material-icons-round arrow">arrow_forward</span>
                        </div>
                    </div>

                    <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/ratingtalent")'>
                        <div class="v-card-icon cp-icon-tone-primary">
                            <span class="material-icons-round">stars</span>
                        </div>
                        <div class="v-card-body">
                            <h3>Năng lực và phẩm chất</h3>
                            <p>Đánh giá năng lực, phẩm chất theo từng học kỳ.</p>
                        </div>
                        <div class="v-card-footer">
                            <span>Mở phân hệ</span>
                            <span class="material-icons-round arrow">arrow_forward</span>
                        </div>
                    </div>
                }
                else
                {
                    <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/pointInput")'>
                        <div class="v-card-icon cp-icon-tone-primary">
                            <span class="material-icons-round">format_list_numbered</span>
                        </div>
                        <div class="v-card-body">
                            <h3>Sổ điểm môn học</h3>
                            <p>Nhập điểm thường xuyên, giữa kỳ và cuối kỳ cho các môn học.</p>
                        </div>
                        <div class="v-card-footer">
                            <span>Mở phân hệ</span>
                            <span class="material-icons-round arrow">arrow_forward</span>
                        </div>
                    </div>
                }

                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/nhap-diem/ket-qua-ren-luyen")'>
                    <div class="v-card-icon cp-icon-tone-primary">
                        <span class="material-icons-round">emoji_events</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Kết quả rèn luyện</h3>
                        <p>Đánh giá rèn luyện, hạnh kiểm theo từng học kỳ.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/chuyen-can")'>
                    <div class="v-card-icon cp-icon-tone-primary">
                        <span class="material-icons-round">fact_check</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Nhập chuyên cần</h3>
                        <p>Quản lý số buổi nghỉ phép/không phép theo tháng và học kỳ.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hub-category score-module__section">
            <h2 class="category-title score-module__section-title"><span class="material-icons-round">assessment</span> Báo cáo và tổng kết</h2>
            <div class="hub-grid-vertical">
                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/finalsummary")'>
                    <div class="v-card-icon cp-icon-tone-primary">
                        <span class="material-icons-round">functions</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Tính điểm tổng kết</h3>
                        <p>Tổng hợp điểm trung bình, xếp loại và xuất kết quả.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/khoaso")'>
                    <div class="v-card-icon cp-icon-tone-secondary">
                        <span class="material-icons-round">summarize</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Khóa sổ điểm</h3>
                        <p>Chốt dữ liệu điểm theo đợt và theo học kỳ.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="hub-category score-module__section">
            <h2 class="category-title score-module__section-title"><span class="material-icons-round">settings</span> Cấu hình hệ thống</h2>
            <div class="hub-grid-vertical">
                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/gradelock")'>
                    <div class="v-card-icon cp-icon-tone-muted">
                        <span class="material-icons-round">lock</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Quản lý khóa điểm</h3>
                        <p>Đóng/mở quyền chỉnh sửa điểm theo từng giai đoạn.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/period")'>
                    <div class="v-card-icon cp-icon-tone-muted">
                        <span class="material-icons-round">date_range</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Quản lý đợt nhập</h3>
                        <p>Thiết lập thời gian cho phép giáo viên nhập điểm.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/cot-diem")'>
                    <div class="v-card-icon cp-icon-tone-muted">
                        <span class="material-icons-round">view_week</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Cấu hình cột điểm</h3>
                        <p>Định nghĩa số lượng và hệ số cột điểm theo thông tư.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>

                <div class="hub-v-card score-module__card" @onclick='() => NavigateTo("/learning/lop-mon")'>
                    <div class="v-card-icon cp-icon-tone-muted">
                        <span class="material-icons-round">cast_for_education</span>
                    </div>
                    <div class="v-card-body">
                        <h3>Cấu hình lớp môn</h3>
                        <p>Thiết lập môn học theo lớp để phân quyền nhập điểm chính xác.</p>
                    </div>
                    <div class="v-card-footer">
                        <span>Mở phân hệ</span>
                        <span class="material-icons-round arrow">arrow_forward</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string CurrentLevel { get; set; } = "02";

    private void NavigateTo(string url)
    {
        NavManager.NavigateTo(url);
    }
}

