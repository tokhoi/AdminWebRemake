@page "/school/security"
@page "/school/permissions"
@rendermode InteractiveServer

<PageTitle>Vai trò & Phân quyền</PageTitle>

<div class="sec-container animate-fade-in">
    <div class="sec-role-list">
        <div class="sec-header flex-between">
            <h3 class="sec-title">Nhóm quyền</h3>
            <button class="sec-btn-icon" title="Thêm nhóm mới"><span class="material-icons-round">add_circle</span></button>
        </div>
        <div class="sec-list-body">
            @foreach (var role in Roles)
            {
                <div class="sec-role-item @(SelectedRoleId == role.Id ? "active" : "")" @onclick="() => SelectRole(role.Id)">
                    <div class="sec-role-info">
                        <span class="fw-bold">@role.Name</span>
                        <span class="sec-role-desc">@role.MemberCount thành viên</span>
                    </div>
                    <span class="material-icons-round u-icon-border-18">chevron_right</span>
                </div>
            }
        </div>
    </div>

    <div class="sec-perm-matrix">
        <div class="sec-header flex-between">
            <div>
                <h3 class="sec-title u-text-primary">Chi tiết quyền: @Roles.First(r => r.Id == SelectedRoleId).Name</h3>
                <span class="u-subtext">Tích chọn để cấp quyền cho nhóm này</span>
            </div>
            <div>
                @if (ShowSavedMessage)
                {
                    <span class="u-green-ok-right">Đã lưu!</span>
                }
                <button class="sec-btn sec-btn-primary" @onclick="SavePermissions"><span class="material-icons-round">save</span> Lưu phân quyền</button>
            </div>
        </div>
        <div class="sec-matrix-body">
            <table class="sec-table">
                <thead>
                    <tr>
                        <th>Tên Module chức năng</th>
                        <th class="u-text-center">Xem</th>
                        <th class="u-text-center">Thêm</th>
                        <th class="u-text-center">Sửa</th>
                        <th class="u-text-center">Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td colspan="5" class="sec-group-row">Học Sinh & Lớp Học</td></tr>
                    <tr>
                        <td>Quản lý danh sách Lớp</td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Class_View" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Class_Add" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Class_Edit" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Class_Del" /></td>
                    </tr>
                    <tr>
                        <td>Điểm danh Học sinh</td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.StdAtt_View" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.StdAtt_Add" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.StdAtt_Edit" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.StdAtt_Del" /></td>
                    </tr>

                    <tr><td colspan="5" class="sec-group-row">Nhân Sự & Giáo Viên</td></tr>
                    <tr>
                        <td>Quản lý danh sách Giáo viên</td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Teacher_View" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Teacher_Add" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Teacher_Edit" /></td>
                        <td class="u-text-center"><input type="checkbox" @bind="CurrentPerms.Teacher_Del" /></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    class Role { public int Id { get; set; } public string Name { get; set; } = ""; public int MemberCount { get; set; } }
    List<Role> Roles = new();

    // Class chứa Trạng thái Checkbox (Permission Matrix)
    class PermMatrix
    {
        public bool Class_View { get; set; }
        public bool Class_Add { get; set; }
        public bool Class_Edit { get; set; }
        public bool Class_Del { get; set; }
        public bool StdAtt_View { get; set; }
        public bool StdAtt_Add { get; set; }
        public bool StdAtt_Edit { get; set; }
        public bool StdAtt_Del { get; set; }
        public bool Teacher_View { get; set; }
        public bool Teacher_Add { get; set; }
        public bool Teacher_Edit { get; set; }
        public bool Teacher_Del { get; set; }
    }

    Dictionary<int, PermMatrix> MatrixData = new();

    int SelectedRoleId = 1;
    PermMatrix CurrentPerms => MatrixData.ContainsKey(SelectedRoleId) ? MatrixData[SelectedRoleId] : new PermMatrix();
    bool ShowSavedMessage = false;

    protected override void OnInitialized()
    {
        Roles = new List<Role> {
            new Role { Id = 1, Name = "Ban Giám Hiệu", MemberCount = 3 },
            new Role { Id = 2, Name = "Giáo viên", MemberCount = 76 },
            new Role { Id = 3, Name = "Nhân viên văn phòng", MemberCount = 2 }
        };

        // Mock data BGH (Full quyền)
        MatrixData[1] = new PermMatrix { Class_View = true, Class_Add = true, Class_Edit = true, Class_Del = true, StdAtt_View = true, StdAtt_Add = true, StdAtt_Edit = true, StdAtt_Del = true, Teacher_View = true, Teacher_Add = true, Teacher_Edit = true, Teacher_Del = true };
        // Mock data Giáo Viên (Chỉ có quyền xem và điểm danh)
        MatrixData[2] = new PermMatrix { Class_View = true, Class_Add = false, Class_Edit = false, Class_Del = false, StdAtt_View = true, StdAtt_Add = true, StdAtt_Edit = true, StdAtt_Del = false, Teacher_View = true, Teacher_Add = false, Teacher_Edit = false, Teacher_Del = false };
        // Mock data NVVP (Không được xóa)
        MatrixData[3] = new PermMatrix { Class_View = true, Class_Add = true, Class_Edit = true, Class_Del = false, StdAtt_View = true, StdAtt_Add = true, StdAtt_Edit = true, StdAtt_Del = false, Teacher_View = true, Teacher_Add = true, Teacher_Edit = true, Teacher_Del = false };
    }

    private void SelectRole(int id) { SelectedRoleId = id; ShowSavedMessage = false; }

    private async Task SavePermissions()
    {
        ShowSavedMessage = true;
        await Task.Delay(2000);
        ShowSavedMessage = false;
    }
}

