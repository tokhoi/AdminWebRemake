@page "/school/settings"
@rendermode InteractiveServer

<PageTitle>Cài đặt hệ thống</PageTitle>

<div class="set-container animate-fade-in">
    <div class="set-sidebar">
        <h3 class="set-sidebar-title">Cài đặt</h3>
        <ul class="set-nav">
            <li class="set-nav-item @(ActiveTab == "info" ? "active" : "")" @onclick='() => ActiveTab = "info"'>
                <span class="material-icons-round set-nav-icon">school</span> Thông tin trường
            </li>
            <li class="set-nav-item @(ActiveTab == "time" ? "active" : "")" @onclick='() => ActiveTab = "time"'>
                <span class="material-icons-round set-nav-icon">schedule</span> Cấu hình giờ
            </li>
            <li class="set-nav-item @(ActiveTab == "camera" ? "active" : "")" @onclick='() => ActiveTab = "camera"'>
                <span class="material-icons-round set-nav-icon">videocam</span> Tích hợp Camera AI
            </li>
        </ul>
    </div>

    <div class="set-content">
        @if (ActiveTab == "info")
        {
            <div class="set-card animate-fade-in">
                <div class="set-header flex-between">
                    <h2 class="set-title">Thông tin chung</h2>
                    <button class="set-btn @(IsEditingInfo ? "set-btn-success" : "set-btn-primary")" @onclick="ToggleEditInfo">
                        <span class="material-icons-round">@(IsEditingInfo ? "save" : "edit")</span> @(IsEditingInfo ? "Lưu thay đổi" : "Chỉnh sửa")
                    </button>
                </div>
                <div class="set-body">
                    <div class="set-info-layout">
                        <div class="set-logo-col">
                            <div class="set-logo-box">
                                <span class="material-icons-round u-font-64-muted">school</span>
                                <div>LOGO TRƯỜNG</div>
                            </div>
                        </div>
                        <div class="set-details-col">
                            <h3 class="set-group-title">Thông tin liên hệ</h3>
                            <div class="set-grid-2">
                                <div>
                                    <label class="set-label">Tên trường</label>
                                    @if (IsEditingInfo)
                                    {
                                        <input class="set-input" @bind="SchoolName" />
                                    }
                                    else
                                    {

                                        <div class="set-value fw-bold">@SchoolName</div>
                                    }
                                </div>
                                <div>
                                    <label class="set-label">Hiệu trường</label>
                                    @if (IsEditingInfo)
                                    {
                                        <input class="set-input" @bind="PrincipalName" />
                                    }
                                    else
                                    {

                                        <div class="set-value">@PrincipalName</div>
                                    }
                                </div>
                                <div class="u-grid-span-2">
                                    <label class="set-label">Địa chỉ</label>
                                    @if (IsEditingInfo)
                                    {
                                        <input class="set-input" @bind="Address" />
                                    }
                                    else
                                    {

                                        <div class="set-value">@Address</div>
                                    }
                                </div>
                                <div>
                                    <label class="set-label">Điện thoại</label>
                                    @if (IsEditingInfo)
                                    {
                                        <input class="set-input" @bind="Phone" />
                                    }
                                    else
                                    {

                                        <div class="set-value">@Phone</div>
                                    }
                                </div>
                                <div>
                                    <label class="set-label">Email</label>
                                    @if (IsEditingInfo)
                                    {
                                        <input class="set-input" @bind="Email" />
                                    }
                                    else
                                    {

                                        <div class="set-value">@Email</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (ActiveTab == "time")
        {
            <div class="set-card animate-fade-in">
                <div class="set-header">
                    <h2 class="set-title">Cấu hình thời gian điểm danh</h2>
                </div>
                <div class="set-body">
                    <div class="set-grid-2">
                        <div class="set-time-box u-bg-primary-soft-border">
                            <h3 class="u-heading-warning"><span class="material-icons-round">wb_sunny</span> Buổi Sáng</h3>
                            <div class="set-input-group mt-3">
                                <label class="set-label">Bắt đầu</label>
                                <input type="time" class="set-input" @bind="MorningStart" />
                            </div>
                            <div class="set-input-group mt-3">
                                <label class="set-label">Kết thúc</label>
                                <input type="time" class="set-input" @bind="MorningEnd" />
                            </div>
                        </div>
                        <div class="set-time-box u-bg-primary-soft-border">
                            <h3 class="u-heading-secondary"><span class="material-icons-round">nights_stay</span> Buổi Chiều</h3>
                            <div class="set-input-group mt-3">
                                <label class="set-label">Bắt đầu</label>
                                <input type="time" class="set-input" @bind="AfternoonStart" />
                            </div>
                            <div class="set-input-group mt-3">
                                <label class="set-label">Kết thúc</label>
                                <input type="time" class="set-input" @bind="AfternoonEnd" />
                            </div>
                        </div>
                    </div>
                    <div class="u-text-right-mt20">
                        <button class="set-btn set-btn-primary" @onclick="SaveTimeConfig"><span class="material-icons-round">save</span> Lưu cấu hình</button>
                        @if (ShowSavedMessage)
                        {
                            <span class="u-green-ok">Đã lưu thành công!</span>
                        }
                    </div>
                </div>
            </div>
        }
        else if (ActiveTab == "camera")
        {
            <div class="set-card animate-fade-in">
                <div class="set-header flex-between">
                    <h2 class="set-title">Quản lý thiết bị Camera AI</h2>
                    <button class="set-btn set-btn-primary"><span class="material-icons-round">add</span> Thêm thiết bị</button>
                </div>
                <div class="set-table-wrap">
                    <table class="set-table">
                        <thead><tr><th>#</th><th>Tên Thiết Bị</th><th>Mã Thiết Bị</th><th class="u-text-center">Trạng Thái</th><th class="u-text-center">Thao tác</th></tr></thead>
                        <tbody>
                            @for (int i = 0; i < Cameras.Count; i++)
                            {
                                var cam = Cameras[i];
                                <tr>
                                    <td>@(i + 1)</td>
                                    <td class="fw-bold">@cam.Name</td>
                                    <td><span class="set-tag">@cam.Id</span></td>
                                    <td class="u-text-center">
                                        @if (cam.IsOnline)
                                        {
                                            <span class="set-tag set-tag-success">Online</span>
                                        }
                                        else
                                        {

                                            <span class="set-tag set-tag-danger">Offline</span>
                                        }
                                    </td>
                                    <td class="u-text-center">
                                        <button class="set-btn-icon" @onclick="() => ToggleCamera(cam)"><span class="material-icons-round">power_settings_new</span></button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string ActiveTab = "info";

    // Data Tab 1
    private bool IsEditingInfo = false;
    private string SchoolName = "Trường Tiểu học Tân Hưng";
    private string PrincipalName = "Nguyễn Văn A";
    private string Address = "Số 123 Đường ABC, Quận X, TP.HCM";
    private string Phone = "0909 000 111";
    private string Email = "hieutruong@tanhung.edu.vn";

    private void ToggleEditInfo() { IsEditingInfo = !IsEditingInfo; }

    // ========================================================
    // TimeOnly dùng cho cấu hình giờ điểm danh
    // ========================================================
    private TimeOnly? MorningStart = new TimeOnly(6, 30);
    private TimeOnly? MorningEnd = new TimeOnly(11, 0);
    private TimeOnly? AfternoonStart = new TimeOnly(13, 30);
    private TimeOnly? AfternoonEnd = new TimeOnly(17, 0);
    private bool ShowSavedMessage = false;

    private async Task SaveTimeConfig()
    {
        ShowSavedMessage = true;
        await Task.Delay(2000);
        ShowSavedMessage = false;
    }

    // Data Tab 3
    class CameraDevice { public string Id { get; set; } = ""; public string Name { get; set; } = ""; public bool IsOnline { get; set; } }
    List<CameraDevice> Cameras = new()
    {
        new CameraDevice { Id = "CAM-001", Name = "Camera Cổng Chính", IsOnline = true },
        new CameraDevice { Id = "CAM-002", Name = "Camera Cổng Phụ", IsOnline = true },
        new CameraDevice { Id = "CAM-003", Name = "Camera Sảnh A", IsOnline = false },
        new CameraDevice { Id = "CAM-004", Name = "Camera Nhà xe", IsOnline = true }
    };

    private void ToggleCamera(CameraDevice cam) { cam.IsOnline = !cam.IsOnline; }
}


