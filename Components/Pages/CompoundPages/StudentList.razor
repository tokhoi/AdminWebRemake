@page "/school/students"
@rendermode InteractiveServer

<PageTitle>Hồ sơ Trường học - Explorer</PageTitle>

<div class="ex-container animate-fade-in">
    <div class="ex-sidebar">
        <div class="ex-sidebar-header">
            <div class="ex-icon-box"><span class="material-icons-round">account_tree</span></div>
            <span class="ex-sidebar-title">Cấu trúc trường</span>
        </div>
        
        <div class="ex-tree-wrapper">
            @* Nút Tổng quan (Root) *@
            <div class="ex-tree-item @(CurrentView == ViewMode.Overview ? "active" : "")" @onclick="ShowOverview">
                <span class="material-icons-round u-icon-primary">domain</span>
                <span class="ex-tree-text">Toàn trường</span>
            </div>

            <div class="ex-tree-divider"></div>

            @* Duyệt danh sách Khối *@
            @foreach (var grade in MockData.Grades)
            {
                <div class="ex-tree-node">
                    <div class="ex-tree-item @(CurrentView == ViewMode.Grade && SelectedGrade?.Id == grade.Id ? "active" : "")" 
                         @onclick="() => SelectGrade(grade)">
                        
                        <span class="material-icons-round ex-tree-toggle" @onclick:stopPropagation="true" @onclick="() => ToggleGrade(grade)">
                            @(grade.IsExpanded ? "expand_more" : "chevron_right")
                        </span>
                        
                        <span class="material-icons-round u-icon-primary">
                            @(grade.IsExpanded ? "folder_open" : "folder")
                        </span>
                        
                        <span class="ex-tree-text">@grade.Name</span>
                    </div>

                    @* Hiển thị danh sách Lớp nếu Khối được mở rộng *@
                    @if (grade.IsExpanded)
                    {
                        <div class="ex-tree-children">
                            @foreach (var cls in grade.Classes)
                            {
                                <div class="ex-tree-child-item @(CurrentView == ViewMode.Class && SelectedClass?.Id == cls.Id ? "active" : "")"
                                     @onclick="() => SelectClass(cls, grade)">
                                    <span class="material-icons-round u-icon-success-sm">class</span>
                                    <span class="ex-tree-text">Lớp @cls.Name</span>
                                    <span class="ex-tree-badge">@cls.Students.Count</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="ex-main-area">
        
        <div class="ex-breadcrumb">
            <span class="material-icons-round u-icon-muted-20">home</span>
            <span class="ex-bc-link" @onclick="ShowOverview">Trường TH Tân Hưng</span>
            
            @if (SelectedGrade != null && CurrentView != ViewMode.Overview)
            {
                <span class="material-icons-round ex-bc-sep">chevron_right</span>
                <span class="ex-bc-link" @onclick="() => SelectGrade(SelectedGrade)">@SelectedGrade.Name</span>
            }

            @if (SelectedClass != null && CurrentView == ViewMode.Class)
            {
                <span class="material-icons-round ex-bc-sep">chevron_right</span>
                <span class="ex-bc-active">Lớp @SelectedClass.Name</span>
            }
        </div>

        <div class="ex-content-body">
            
            @* ================= TRẠNG THÁI 1: TOÀN TRƯỜNG ================= *@
            @if (CurrentView == ViewMode.Overview)
            {
                <div class="ex-card">
                    <div class="ex-card-header">
                        <div class="ex-card-title">
                            <span class="material-icons-round u-text-primary">apartment</span>
                            Thống kê các Khối
                        </div>
                    </div>
                    <div class="ex-table-container">
                        <table class="ex-table">
                            <thead>
                                <tr>
                                    <th class="u-th-80">Mã Khối</th>
                                    <th>Tên Khối</th>
                                    <th>Trường khối</th>
                                    <th class="u-text-center">Số lượng lớp</th>
                                    <th class="u-text-center">Tổng học sinh</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach(var g in MockData.Grades)
                                {
                                    <tr @onclick="() => SelectGrade(g)">
                                        <td><span class="ex-tag ex-tag-gray">KHOI_@g.Id</span></td>
                                        <td class="u-title-primary">@g.Name</td>
                                        <td>@g.HeadTeacher</td>
                                        <td class="u-text-center"><span class="ex-tag ex-tag-warning">@g.Classes.Count lớp</span></td>
                                        <td class="u-text-center"><span class="ex-tag ex-tag-blue">@g.Classes.Sum(c => c.Students.Count) em</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* ================= TRẠNG THÁI 2: CHI TIẾT KHỐI ================= *@
            @if (CurrentView == ViewMode.Grade && SelectedGrade != null)
            {
                <div class="ex-stats-row">
                    <div class="ex-stat-box">
                        <div class="ex-stat-label">Tổng lớp</div>
                        <div class="ex-stat-value u-text-primary">@SelectedGrade.Classes.Count</div>
                    </div>
                    <div class="ex-stat-box">
                        <div class="ex-stat-label">Tổng học sinh</div>
                        <div class="ex-stat-value u-text-primary">@SelectedGrade.Classes.Sum(c => c.Students.Count)</div>
                    </div>
                    <div class="ex-stat-box">
                        <div class="ex-stat-label">Trường khối</div>
                        <div class="ex-stat-value u-stat-main">@SelectedGrade.HeadTeacher</div>
                    </div>
                </div>

                <div class="ex-card">
                    <div class="ex-card-header u-flex-between">
                        <div class="ex-card-title">
                            <span class="material-icons-round u-icon-primary">folder_open</span>
                            Các lớp thuộc @SelectedGrade.Name
                        </div>
                        <button class="btn btn-primary"><span class="material-icons-round">add</span> Thêm lớp</button>
                    </div>
                    <div class="ex-table-container">
                        <table class="ex-table">
                            <thead>
                                <tr>
                                    <th>Tên Lớp</th>
                                    <th>GV Chủ Nhiệm</th>
                                    <th class="u-text-center">Sĩ số</th>
                                    <th class="u-text-center">Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in SelectedGrade.Classes)
                                {
                                    <tr @onclick="() => SelectClass(c, SelectedGrade)">
                                        <td class="u-title-primary">
                                            <div class="u-flex-center-gap8">
                                                Lớp @c.Name
                                            </div>
                                        </td>
                                        <td>@c.Teacher</td>
                                        <td class="u-text-center"><b>@c.Students.Count</b></td>
                                        <td class="u-text-center"><span class="status-badge bg-green-light"><span class="dot dot-green"></span> Hoạt động</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @* ================= TRẠNG THÁI 3: CHI TIẾT LỚP ================= *@
            @if (CurrentView == ViewMode.Class && SelectedClass != null)
            {
                <div class="ex-card u-flex-col-fill">
                    <div class="ex-card-header u-flex-between">
                        <div>
                            <div class="ex-card-title u-mb-4">
                                <span class="material-icons-round u-icon-primary-strong">school</span>
                                Danh sách học sinh - Lớp @SelectedClass.Name
                            </div>
                            <div class="u-subtext">
                                GVCN: <b>@SelectedClass.Teacher</b> &nbsp;|&nbsp; Sĩ số: <b>@SelectedClass.Students.Count</b>
                            </div>
                        </div>
                        <div class="u-flex-gap-10">
                            <button class="btn btn-outline"><span class="material-icons-round">upload</span> Import</button>
                            <button class="btn btn-primary"><span class="material-icons-round">person_add</span> Thêm học sinh</button>
                        </div>
                    </div>

                    <div class="ex-table-toolbar">
                        <div class="input-wrapper u-search-width">
                            <span class="material-icons-round input-icon">search</span>
                            <input class="form-input input-has-icon" placeholder="Tìm tên học sinh hoặc phụ huynh..." />
                        </div>
                    </div>

                    <div class="ex-table-container u-flex-1">
                        <table class="ex-table">
                            <colgroup>
                                <col class="u-width-50">
                                <col class="u-width-12p">
                                <col class="u-col-25">
                                <col class="u-width-12p">
                                <col class="u-col-20">
                                <col class="u-width-15p">
                                <col class="u-width-120">
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="u-text-center">STT</th>
                                    <th>Mã HS</th>
                                    <th>Họ và tên</th>
                                    <th>Ngày sinh</th>
                                    <th>Thông tin Phụ huynh</th>
                                    <th>Điện thoại</th>
                                    <th class="u-text-center">App PH</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (s, index) in SelectedClass.Students.Select((v, i) => (v, i + 1)))
                                {
                                    <tr>
                                        <td class="u-text-center-muted">@index</td>
                                        <td><span class="ex-tag ex-tag-gray u-font-mono">@s.Code</span></td>
                                        <td>
                                            <div class="u-flex-center-gap8">
                                                <div class="ex-avatar">@s.Name.Substring(0, 1)</div>
                                                <span class="u-name-strong">@s.Name</span>
                                            </div>
                                        </td>
                                        <td class="u-text-muted">15/08/2015</td>
                                        <td>
                                            <div class="u-parent-info">
                                                <div><span class="u-text-muted-soft">Cha:</span> <span class="u-fw-500">@s.ParentName</span></div>
                                                <div><span class="u-text-muted-soft">Mẹ:</span> <span class="u-fw-500">Nguyễn Thị Mơ</span></div>
                                            </div>
                                        </td>
                                        <td class="u-font-mono-main">@s.Phone</td>
                                        <td class="u-text-center">
                                            @if (index % 3 == 0)
                                            {
                                                <span class="ex-tag ex-tag-gray">Chưa cài</span>
                                            }
                                            else
                                            {
                                                <span class="ex-tag ex-tag-green"><span class="material-icons-round u-font-14">check_circle</span> OK</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* ========================================================================= *@
@* CSS SCOPED (CHỈ CÓ TÁC DỤNG TRONG COMPONENT NÀY, KHÔNG BỊ BÊN NGOÀI ĐÈ) *@
@* ========================================================================= *@
@code {
    enum ViewMode { Overview, Grade, Class }
    private ViewMode CurrentView = ViewMode.Overview;
    private Grade? SelectedGrade;
    private ClassRoom? SelectedClass;

    private void ShowOverview()
    {
        CurrentView = ViewMode.Overview;
        SelectedGrade = null;
        SelectedClass = null;
    }

    private void SelectGrade(Grade g)
    {
        g.IsExpanded = true;
        SelectedGrade = g;
        SelectedClass = null;
        CurrentView = ViewMode.Grade;
    }

    private void ToggleGrade(Grade g)
    {
        g.IsExpanded = !g.IsExpanded;
    }

    private void SelectClass(ClassRoom c, Grade parentGrade)
    {
        SelectedGrade = parentGrade;
        parentGrade.IsExpanded = true;
        SelectedClass = c;
        CurrentView = ViewMode.Class;
    }

    // ==========================================
    // DATA MOCK
    // ==========================================
    public class Student { public string Code{get;set;} public string Name{get;set;} public string ParentName{get;set;} public string Phone{get;set;} }
    public class ClassRoom { public int Id{get;set;} public string Name{get;set;} public string Teacher{get;set;} public List<Student> Students{get;set;} = new(); }
    public class Grade { public int Id{get;set;} public string Name{get;set;} public string HeadTeacher{get;set;} public bool IsExpanded{get;set;} public List<ClassRoom> Classes{get;set;} = new(); }

    public static class MockData
    {
        public static List<Grade> Grades { get; set; } = new();
        static MockData()
        {
            var rnd = new Random();
            for (int i = 1; i <= 5; i++)
            {
                var g = new Grade { Id = i, Name = $"Khối {i}", HeadTeacher = $"Thầy Nguyễn Văn Trường Khối {i}" };
                for (int j = 1; j <= 4; j++)
                {
                    var c = new ClassRoom { Id = i*10+j, Name = $"{i}A{j}", Teacher = $"Cô Trần Thị {i}A{j}" };
                    for (int k = 1; k <= 35; k++)
                    {
                        c.Students.Add(new Student { Code = $"HS{i}{j}{k:000}", Name = $"Học Sinh Tên {k}", ParentName = $"Phụ Huynh {k}", Phone = $"0909{rnd.Next(100000,999999)}" });
                    }
                    g.Classes.Add(c);
                }
                Grades.Add(g);
            }
        }
    }
}



