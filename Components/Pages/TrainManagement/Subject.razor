@page "/training/subjects"
@rendermode InteractiveServer

<PageTitle>Quản lý Môn Học</PageTitle>

<div class="lm-page-container lm-animate-fade-in">
    <div class="lm-card">
        <div class="lm-card-header">
            <h2 class="lm-card-title">
                <span class="material-icons-round">library_books</span> Danh Sách Môn Học
            </h2>
            <button class="lm-btn lm-btn-primary" @onclick="OpenCreateModal">
                <span class="material-icons-round" style="font-size:18px; margin-right:4px;">add</span> Thêm Môn Học
            </button>
        </div>

        <div class="lm-toolbar">
            <div class="lm-filter-group">
                <label class="lm-label">Khối Lớp</label>
                <select class="lm-select">
                    <option>Tất cả</option>
                    <option>Khối 10</option>
                    <option>Khối 11</option>
                </select>
            </div>
            <div class="lm-filter-group">
                <label class="lm-label">Loại Môn</label>
                <select class="lm-select">
                    <option>Tất cả</option>
                    <option>Bắt buộc</option>
                    <option>Tự chọn</option>
                </select>
            </div>
            <div class="lm-filter-group" style="flex: 2;">
                <label class="lm-label">Tìm kiếm</label>
                <div class="lm-input-icon-wrapper">
                    <span class="material-icons-round">search</span>
                    <input class="lm-input" placeholder="Tìm tên môn, mã môn..." />
                </div>
            </div>
            <button class="lm-btn lm-btn-primary">Tìm kiếm</button>
        </div>

        <div class="lm-table-wrapper">
            <table class="lm-table">
                <thead>
                    <tr>
                        <th class="lm-text-center" style="width: 60px;">STT</th>
                        <th style="width: 120px;">Mã Môn</th>
                        <th>Tên Môn Học</th>
                        <th class="lm-text-center">Số Tín Chỉ</th>
                        <th>Loại Môn</th>
                        <th class="lm-text-center" style="width: 120px;">Thao Tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (PagedSubjects.Any())
                    {
                        int index = (CurrentPage - 1) * PageSize + 1;
                        foreach (var item in PagedSubjects)
                        {
                            <tr>
                                <td class="lm-text-center">@(index++)</td>
                                <td><span class="lm-badge lm-badge-gray" style="font-family: var(--font-body);">@item.Code</span></td>
                                <td style="font-weight: 600;">@item.Name</td>
                                <td class="lm-text-center">@item.Credits</td>
                                <td>
                                    @if (item.Type == "Lý thuyết")
                                    {
                                        <span style="color:var(--kg-primary);">Lý thuyết</span>
                                    }
                                    else
                                    {

                                        <span style="color:var(--kg-warning);">Thực hành</span>
                                    }
                                </td>
                                <td class="lm-text-center" style="display:flex; justify-content:center; gap:8px;">
                                    <button class="lm-btn-icon" title="Sửa"><span class="material-icons-round">edit</span></button>
                                    <button class="lm-btn-icon delete" title="Xóa"><span class="material-icons-round">delete</span></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="lm-text-center" style="padding: 20px; color: var(--lm-text-muted);">Không có dữ liệu</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="lm-pagination">
            <span style="font-size:0.85rem; color:var(--lm-text-muted);">
                Hiển thị @((CurrentPage - 1) * PageSize + 1) - @Math.Min(CurrentPage * PageSize, TotalItems) trong @TotalItems bản ghi
            </span>
            <div style="display:flex; gap:6px;">
                <button class="lm-page-btn" @onclick="PrevPage" disabled="@(CurrentPage == 1)" style="@(CurrentPage == 1 ? "opacity:0.5; cursor:default;" : "")">
                    <span class="material-icons-round">chevron_left</span>
                </button>

                @for (int i = 1; i <= TotalPages; i++)
                {
                    var pageNumber = i;
                    <button class="lm-page-btn @(CurrentPage == pageNumber ? "active" : "")" @onclick="() => GoToPage(pageNumber)">
                        @pageNumber
                    </button>
                }

                <button class="lm-page-btn" @onclick="NextPage" disabled="@(CurrentPage == TotalPages)" style="@(CurrentPage == TotalPages ? "opacity:0.5; cursor:default;" : "")">
                    <span class="material-icons-round">chevron_right</span>
                </button>
            </div>
        </div>
    </div>
</div>

@if (showModal) { /* ... Code Modal cũ ... */ }

@code {
    private bool showModal = false;
    private bool isEdit = false;
    private void OpenCreateModal() { showModal = true; isEdit = false; }

    // --- PAGINATION & DATA ---
    private int CurrentPage = 1;
    private int PageSize = 7; // Thử set 7 dòng/trang
    private List<SubjectModel> AllSubjects = new();

    private List<SubjectModel> PagedSubjects => AllSubjects
        .Skip((CurrentPage - 1) * PageSize)
        .Take(PageSize)
        .ToList();

    private int TotalItems => AllSubjects.Count;
    private int TotalPages => (int)Math.Ceiling((double)TotalItems / PageSize);

    protected override void OnInitialized()
    {
        // Mock Data: 20 môn học
        for (int i = 1; i <= 20; i++)
        {
            AllSubjects.Add(new SubjectModel
            {
                Id = i,
                Code = $"SUB_{i:D3}", // Format SUB_001
                Name = i % 2 == 0 ? $"Toán Cao Cấp {i}" : $"Lập Trình Web {i}",
                Credits = i % 3 + 2,
                Type = i % 3 == 0 ? "Thực hành" : "Lý thuyết"
            });
        }
    }

    private void NextPage() { if (CurrentPage < TotalPages) CurrentPage++; }
    private void PrevPage() { if (CurrentPage > 1) CurrentPage--; }
    private void GoToPage(int page) { CurrentPage = page; }

    public class SubjectModel
    {
        public int Id { get; set; }
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public int Credits { get; set; }
        public string Type { get; set; } = "";
    }
}


