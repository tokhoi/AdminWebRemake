@implements IDisposable
@inject NavigationManager NavManager
@rendermode InteractiveServer

<header class="layout-header">
    <div class="header-inner">
        <div class="brand-area">
            <button class="menu-toggle-btn" @onclick="ToggleMobileMenu">
                <span class="material-icons-round">menu</span>
            </button>

            <div class="logo-box">
                <img class="logo-img" src="https://placehold.co/400" alt="logo-truong" />
            </div>
            <h1 class="brand-name">Tên Trường</h1>
        </div>

        <div class="user-area">
            <div class="user-info">
                <span class="material-icons-round" style="color: #fde047;">person</span>
                <span>Admin</span>
            </div>
            <button class="year-btn">
                2025-2026 <span class="material-icons-round">expand_more</span>
            </button>
        </div>
    </div>

    <div class="main-nav-container desktop-only">
        <nav class="main-nav">
            @foreach (var item in MenuItems)
            {
                <div class="nav-item-wrap">
                    @{
                        bool hasSub = item.SubItems != null && item.SubItems.Any();
                    }
                    @if (hasSub)
                    {
                        var isActive = !string.IsNullOrEmpty(item.Link) && NavManager.Uri.Contains(item.Link);
                        <div class="nav-link @(isActive ? "active" : "")">
                            <span class="material-icons-round" style="font-size:18px; color: @item.IconColor;">@item.Icon</span> @item.Title
                            <span class="material-icons-round arrow-icon" style="font-size:14px; margin-left:2px;">expand_more</span>
                        </div>
                        <div class="nav-dropdown @(item.SubItems!.Count > 6 ? "two-cols" : "")">
                            @foreach (var sub in item.SubItems)
                            {
                                <NavLink href="@sub.Link" class="dropdown-item">
                                    <span class="material-icons-round sub-icon">@(string.IsNullOrEmpty(sub.Icon) ? "fiber_manual_record" : sub.Icon)</span> @sub.Title
                                </NavLink>
                            }
                        </div>
                    }
                    else
                    {
                        <NavLink href="@item.Link" Match="NavLinkMatch.All" class="nav-link">
                            <span class="material-icons-round" style="font-size:18px; color: @item.IconColor;">@item.Icon</span> @item.Title
                        </NavLink>
                    }
                </div>
            }
        </nav>
    </div>
</header>

<div class="mobile-wrapper @(_isMobileMenuOpen ? "open" : "")">
    <div class="mobile-backdrop" @onclick="CloseMobileMenu"></div>

    <div class="mobile-drawer">
        <div class="drawer-header">
            <div class="drawer-logo">
                <div class="logo-box" style="color:#333; background: #fff">TH</div>
                <span style="font-weight: 700; color: #fff;">Menu Chính</span>
            </div>
            <button class="drawer-close-btn" @onclick="CloseMobileMenu">
                <span class="material-icons-round">close</span>
            </button>
        </div>

        <div class="drawer-body">
            @foreach (var item in MenuItems)
            {
                bool hasSub = item.SubItems != null && item.SubItems.Any();
                bool isExpanded = expandedMenuTitle == item.Title;

                <div class="drawer-item-group @(isExpanded ? "expanded" : "")">
                    <div class="drawer-link-parent" @onclick="() => ToggleSubMenu(item.Title, hasSub, item.Link)">
                        <div style="display:flex; align-items:center; gap:10px;">
                            <span class="material-icons-round" style="color: @(item.IconColor == "white" ? "#666" : item.IconColor);">@item.Icon</span>
                            <span class="drawer-text">@item.Title</span>
                        </div>
                        @if (hasSub)
                        {
                            <span class="material-icons-round chevron">expand_more</span>
                        }
                    </div>

                    @if (hasSub && isExpanded)
                    {
                        <div class="drawer-sub-panel animate-slide-down">
                            @foreach (var sub in item.SubItems!)
                            {
                                <NavLink href="@sub.Link" class="drawer-sub-item" @onclick="CloseMobileMenu">
                                    <div class="sub-icon-box">
                                        <span class="material-icons-round">@(string.IsNullOrEmpty(sub.Icon) ? "fiber_manual_record" : sub.Icon)</span>
                                    </div>
                                    <span class="sub-text">@sub.Title</span>
                                </NavLink>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
