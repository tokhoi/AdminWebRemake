    // 6. Xử lý sự kiện Navigation & UI
    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (_isMobileMenuOpen)
        {
            _isMobileMenuOpen = false;
            expandedMenuTitle = null;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= HandleLocationChanged;
    }

    private void ToggleMobileMenu()
    {
        _isMobileMenuOpen = !_isMobileMenuOpen;
    }

    private void CloseMobileMenu()
    {
        _isMobileMenuOpen = false;
    }

    private void ToggleSubMenu(string title, bool hasSub, string link)
    {
        if (!hasSub)
        {
            NavManager.NavigateTo(link);
            CloseMobileMenu();
            return;
        }

        if (expandedMenuTitle == title)
        {
            expandedMenuTitle = null; 
        }
        else
        {
            expandedMenuTitle = title; // Mở cái mới
        }
    }

    // 7. Class Model cho Menu Item
    public class MenuItem
    {
        public string Title { get; set; } = "";
        public string Link { get; set; } = "#";
        public string Icon { get; set; } = "";
        public string IconColor { get; set; } = "white";
        public List<MenuItem>? SubItems { get; set; }
    }
